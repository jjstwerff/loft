// Probe 12 — u32 boundary values: verify every value in the u32
// range round-trips through storage, arithmetic, and comparison.
//
// Under Phase 2a, u32 = integer limit(0, 4_294_967_294) and promotes
// to Type::Long internally via the wide-limit-to-Long rule.

fn test_u32_zero() {
  p_z: u32 = 0;
  assert(p_z == 0, "zero");
}

fn test_u32_one() {
  p_o: u32 = 1;
  assert(p_o == 1, "one");
}

fn test_u32_i32_max() {
  p_i32m: u32 = 2147483647;
  assert(p_i32m == 2147483647, "i32::MAX");
}

fn test_u32_just_over_i32_max() {
  p_over: u32 = 2147483648;
  assert(p_over == 2147483648, "i32::MAX+1");
}

fn test_u32_u32_max_minus_one() {
  p_top: u32 = 4294967293;
  assert(p_top == 4294967293, "u32::MAX-1");
}

fn test_u32_top() {
  // 4_294_967_294 = u32::MAX - 1 (the highest non-null u32).
  p_top2: u32 = 4294967294;
  assert(p_top2 == 4294967294, "u32 top");
}

fn test_u32_arith_across_i32_boundary() {
  p_a: u32 = 2147483640;
  p_b: u32 = p_a + 10;
  assert(p_b == 2147483650, "add across i32::MAX");
}

fn test_u32_mul_safe() {
  // 65536 * 65536 = 2^32, overflows i32 but fits in i64.
  // u32 = long internally, so this is i64 arithmetic.
  p_m: u32 = 65536;
  p_r: long = p_m * 65536;
  assert(p_r == 4294967296l, "square of 2^16");
}

fn test_u32_comparison_to_literal() {
  p_v: u32 = 3000000000;
  assert(p_v > 2000000000, "compare > literal");
  assert(p_v == 3000000000, "compare == literal");
  assert(p_v != 3000000001, "compare != literal");
  assert(p_v < 4000000000, "compare < literal");
}

fn test_u32_rgba_pack() {
  p_r: u32 = 0x12;
  p_g: u32 = 0x34;
  p_b: u32 = 0x56;
  p_alpha: u32 = 0x78;
  p_packed: u32 = p_r * 16777216 + p_g * 65536 + p_b * 256 + p_alpha;
  assert(p_packed == 0x12345678, "rgba packed");
}
