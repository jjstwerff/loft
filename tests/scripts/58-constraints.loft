// Constraints (L6): field assert, cross-field, auto-message, vector elements.

struct CScore {
  val: integer assert($.val >= 0, "val must be >= 0"),
  cap: integer assert($.cap >= $.val, "cap must be >= val")
}

struct CItem {
  label: text,
  qty: integer assert($.qty > 0, "qty must be > 0 for '{$.label}'")
}

fn test_constraint_valid_construction() {
  s = CScore { val: 5, cap: 10 };
  assert(s.val == 5, "val: {s.val}");
  assert(s.cap == 10, "cap: {s.cap}");
}

fn test_constraint_valid_assignment() {
  s = CScore { val: 5, cap: 10 };
  s.val = 8;
  assert(s.val == 8, "assigned val: {s.val}");
}

fn test_constraint_valid_vector_of_structs() {
  items = [
    CItem { label: "apple", qty: 3 },
    CItem { label: "banana", qty: 5 }
  ];
  total = 0;
  for ci_it in items {
    total += ci_it.qty;
  }
  assert(total == 8, "total: {total}");
}

fn test_constraint_with_parse() {
  s = CScore.parse(`{{"val": 5, "cap": 10}}`);
  assert(s.val == 5, "parsed val");
  assert(s.cap == 10, "parsed cap");
}
