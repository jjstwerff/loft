// C16: return inside branches of value-producing if-expressions.
// The Never type allows return in either branch of an if-expression.

// --- return in else branch ---
fn safe_div(a: integer, b: integer) -> integer {
  val = if b != 0 { a / b } else { return -1; };
  val
}

// --- return in true branch ---
fn safe_div_true(a: integer, b: integer) -> integer {
  val = if b == 0 { return -1; } else { a / b };
  val
}

// --- return in nested context ---
fn clamp(x: integer, lo: integer, hi: integer) -> integer {
  result = if x < lo { return lo; } else { x };
  if result > hi { return hi; }
  result
}

// --- return in both branches (both diverge) ---
fn either(x: integer) -> integer {
  if x > 0 { return 1; } else { return -1; }
}

fn main() {
  // return in else
  assert(safe_div(10, 2) == 5, "10/2={safe_div(10, 2)}");
  assert(safe_div(10, 0) == -1, "10/0={safe_div(10, 0)}");

  // return in true
  assert(safe_div_true(10, 2) == 5, "true: 10/2={safe_div_true(10, 2)}");
  assert(safe_div_true(10, 0) == -1, "true: 10/0={safe_div_true(10, 0)}");

  // clamp with return in if-expr
  assert(clamp(5, 1, 10) == 5, "clamp middle");
  assert(clamp(-5, 1, 10) == 1, "clamp low");
  assert(clamp(15, 1, 10) == 10, "clamp high");

  // both branches return
  assert(either(5) == 1, "either positive");
  assert(either(-5) == -1, "either negative");
}
