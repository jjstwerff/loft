// Regression tests for documented caveats (CAVEATS.md).
// Each test verifies the current behaviour so releases can be retested quickly.

// C1 — Lambda closure capture: verify lambdas work without capture.
fn test_c1_lambda_no_capture() {
  nums = [1, 2, 3, 4, 5];
  doubled = map(nums, |x| { x * 2 });
  assert(doubled[0] == 2, "C1: lambda works without capture");
  assert(doubled[4] == 10, "C1: lambda map result");
}

// P3 regression — all vector aggregates implemented (sum_of/min_of/max_of/any/all/count_if).
fn test_p3_aggregates() {
  nums = [3, 1, 4, 1, 5];
  assert(sum_of(nums) == 14, "P3: sum_of works");
  assert(min_of(nums) == 1, "P3: min_of works");
  assert(max_of(nums) == 5, "P3: max_of works");
  assert(any(nums, |x| { x > 4 }), "P3: any works");
  assert(!all(nums, |x| { x > 2 }), "P3: all works");
  assert(count_if(nums, |x| { x == 1 }) == 2, "P3: count_if works");
}

// S15 regression: struct-enum variants with same-named fields now read the correct offset.
enum TwoVal { TvInt { v: integer }, TvFloat { v: float } }

fn test_s15_same_named_field_offset() {
  x = TvInt { v: 42 };
  if x is TvInt { v } {
    assert(v == 42, "S15: TvInt v should be 42, got {v}");
  } else {
    assert(false, "S15: wrong match arm");
  }
}

// C11 — while loop now supported (L10 fix).
fn test_c11_while() {
  i = 0;
  found = false;
  while !found { i += 1; found = i * i > 100; }
  assert(found, "C11: while loop works");
}

// C11b — while loop with break value.
fn c11_first_square_above(limit: integer) -> integer {
  i = 0;
  while i < 1000 {
    i += 1;
    if i * i > limit { break i; }
  }
  -1
}

fn test_c11b_while_break_value() {
  assert(c11_first_square_above(100) == 11, "C11b: first square > 100");
  assert(c11_first_square_above(50) == 8, "C11b: first square > 50");
}

// C19 — Tuples work in interpreter (element access and assignment).
fn test_c19_tuple_basics() {
  t = (10, 20);
  assert(t.0 == 10, "C19: tuple .0");
  assert(t.1 == 20, "C19: tuple .1");
  t.0 = 99;
  assert(t.0 == 99, "C19: tuple element assign");
}

// C61 — sequential same-name loops keep working (only *nested*
// same-name loops are rejected).  Each loop runs fully and `i` is
// valid within each scope.
fn test_c61_sequential_same_name() {
  total_a = 0;
  for i in 0..3 { total_a += i; }
  total_b = 0;
  for i in 10..13 { total_b += i; }
  assert(total_a == 3, "C61: first loop sum, got {total_a}");
  assert(total_b == 33, "C61: second loop sum, got {total_b}");
}

// C61.local — renaming a loop variable to avoid an outer-local shadow
// keeps the outer value intact (the documented fix for the rejected
// shadow diagnostic).
fn test_c61_renamed_loop_var_keeps_local() {
  outer_x = 99;
  for loop_x in 0..3 { loop_x; }
  assert(outer_x == 99, "C61.local: outer survives, got {outer_x}");
}

// C61 — nested loops with different names work without collision.
fn test_c61_nested_different_names() {
  total = 0;
  for i in 0..3 {
    for j in 10..13 { total += j; }
    total += i;
  }
  // 3 * (10+11+12) + (0+1+2) = 99 + 3 = 102
  assert(total == 102, "C61: nested different names, got {total}");
}

// C19/C21 — Coroutines tested separately in tests/scripts/51-coroutines.loft.
// The yield from regression (C21) and native-codegen exclusion (C19) are
// tracked in CAVEATS.md; their test coverage lives in 51-coroutines.loft.

fn main() {
  test_c1_lambda_no_capture();
  test_p3_aggregates();
  test_s15_same_named_field_offset();
  test_c11_while();
  test_c11b_while_break_value();
  test_c19_tuple_basics();
  test_c61_sequential_same_name();
  test_c61_renamed_loop_var_keeps_local();
  test_c61_nested_different_names();
  println("caveats: all ok");
}
