// Parallel workers returning struct references.

struct Item {
  name: text,
  value: integer
}

struct Items {
  list: vector<Item>
}

struct Result {
  label: text,
  doubled: integer
}

fn transform(src: const Item) -> Result {
  Result { label: "v{src.value}", doubled: src.value * 2 }
}

struct Pair {
  a: integer,
  b: integer
}

fn make_pair(src: const Item) -> Pair {
  Pair { a: src.value, b: src.value * 3 }
}

fn test_par_struct_simple() {
  data = Items {};
  data.list += [Item { name: "x", value: 10 }, Item { name: "y", value: 20 }];
  total = 0;
  for par_s in data.list par(par_p = make_pair(par_s), 1) {
    total += par_p.a + par_p.b;
  }
  assert(total == 120, "simple struct: {total}");
}

fn test_par_struct_return_single_thread() {
  data = Items {};
  data.list += [Item { name: "a", value: 10 }, Item { name: "b", value: 20 }, Item { name: "c", value: 30 }];
  total = 0;
  labels = "";
  for par_item in data.list par(par_res = transform(par_item), 1) {
    total += par_res.doubled;
    labels += "{par_res.label},";
  }
  assert(total == 120, "single thread total: {total}");
  assert(labels == "v10,v20,v30,", "single thread labels: {labels}");
}

fn test_par_struct_return_multi_thread() {
  data = Items {};
  data.list += [Item { name: "a", value: 5 }, Item { name: "b", value: 15 }, Item { name: "c", value: 25 }, Item { name: "d", value: 35 }];
  total = 0;
  for par_mt in data.list par(par_r2 = transform(par_mt), 4) {
    total += par_r2.doubled;
  }
  assert(total == 160, "multi thread total: {total}");
}

fn test_par_struct_return_empty() {
  data = Items {};
  count = 0;
  for par_empty in data.list par(par_r3 = transform(par_empty), 1) {
    count += par_r3.doubled * 0 + 1;
  }
  assert(count == 0, "empty: {count}");
}
