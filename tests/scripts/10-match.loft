// Match expressions: plain enums, struct enums, scalars, guards, patterns.

// ── Plain enum ──────────────────────────────────────────────────────────────

enum Direction { North, East, South, West }

fn test_plain_all_arms() {
  d = South;
  r = match d { North => "N", East => "E", South => "S", West => "W" };
  assert(r == "S", "all arms");
}

fn test_plain_wildcard() {
  d = West;
  r = match d { North => "north", _ => "other" };
  assert(r == "other", "wildcard");
}

fn test_plain_wildcard_first() {
  d = North;
  r = match d { South => "south", _ => "not south" };
  assert(r == "not south", "wildcard first");
}

// @EXPECT_ERROR: match on Direction is not exhaustive
fn test_plain_missing_arm() {
  d = North;
  match d { North => "N", East => "E", South => "S" };
}

fn label(d: Direction) -> text {
  result = "";
  match d { North => result = "N", East => result = "E", South => result = "S", West => result = "W" };
  result
}

fn test_plain_as_statement() {
  assert(label(East) == "E", "as statement");
}

enum Priority { Low, Medium, High }

fn test_plain_as_integer_value() {
  p = High;
  v = match p { Low => 1, Medium => 5, High => 10 };
  assert(v * 2 == 20, "integer value");
}

fn label2(d: Direction) -> text {
  match d { North => "N", East => "E", South => "S", West => "W" }
}

fn test_plain_in_function() {
  assert(label2(West) == "W", "in function");
}

// ── Struct enum ─────────────────────────────────────────────────────────────

enum Shape {
  Circle { radius: float },
  Rect { width: float, height: float },
  Square { side: float }
}

fn test_struct_no_binding() {
  s = Circle { radius: 3.0 };
  r = match s { Circle => true, _ => false };
  assert(r, "no binding");
}

fn test_struct_single_field() {
  s = Circle { radius: 2.0 };
  r = match s {
    Circle { radius } => radius * radius,
    Rect { width, height } => width * height,
    Square { side } => side * side
  };
  assert(r == 4.0, "single field");
}

fn test_struct_multi_field() {
  s = Rect { width: 4.0, height: 5.0 };
  r = match s {
    Circle { radius } => radius * radius,
    Rect { width, height } => width * height,
    Square { side } => side * side
  };
  assert(r == 20.0, "multi field");
}

fn area(s: Shape) -> float {
  match s {
    Circle { radius } => PI * radius * radius,
    Rect { width, height } => width * height,
    Square { side } => side * side
  }
}

fn test_struct_all_variants() {
  c = area(Circle { radius: 1.0 });
  r = area(Rect { width: 3.0, height: 4.0 });
  s = area(Square { side: 5.0 });
  assert("{c} {r} {s}" == "3.141592653589793 12 25", "all variants");
}

// @EXPECT_ERROR: match on Shape is not exhaustive
fn test_struct_missing_arm() {
  s = Circle { radius: 1.0 };
  match s { Circle { radius } => radius, Rect { width, height } => width * height };
}

// ── Nesting and composition ─────────────────────────────────────────────────

enum NX { NA, NB }
enum NY { NP, NQ }

fn test_match_nested() {
  x = NA;
  y = NQ;
  r = match x { NA => match y { NP => 1, NQ => 2 }, NB => 0 };
  assert(r == 2, "nested");
}

enum Flag { On, Off }

fn test_match_in_call() {
  f = On;
  r = len(match f { On => "enabled", Off => "disabled" });
  assert(r == 7, "in call");
}

// ── Scalar and error cases ──────────────────────────────────────────────────

fn test_match_non_enum() {
  v = [1, 2, 3];
  r = match v { _ => 0 };
  assert(r == 0, "wildcard");
}

// @EXPECT_ERROR: cannot unify: text and integer
fn test_match_type_mismatch() {
  d = North;
  match d { North => "text", _ => 42 };
}

// @EXPECT_WARNING: unreachable arm: North already matched
fn test_match_duplicate_arm() {
  d = North;
  match d { North => "first", North => "second", _ => "other" };
}

struct MPoint { x: float, y: float }

fn test_match_struct_destructure() {
  p = MPoint { x: 3.0, y: 4.0 };
  r = match p { MPoint { x, y } => x + y };
  assert(r == 7.0, "r: {r}");
}

fn test_match_struct_no_fields() {
  p = MPoint { x: 1.0, y: 2.0 };
  r = match p { MPoint => 42 };
  assert(r == 42, "r: {r}");
}

fn test_match_scalar_integer() {
  x = 42;
  r = match x { 1 => "one", 42 => "forty-two", _ => "other" };
  assert(r == "forty-two", "r");
}

fn test_match_scalar_text() {
  cmd = "help";
  r = match cmd { "quit" => 0, "help" => 1, _ => -1 };
  assert(r == 1, "r: {r}");
}

fn test_match_scalar_boolean() {
  flag = true;
  r = match flag { true => "on", false => "off" };
  assert(r == "on", "r");
}

fn test_match_with_commas() {
  d = East;
  r = match d { North => "N", East => "E", South => "S", West => "W", };
  assert(r == "E", "commas");
}

fn test_match_scalar_no_match() {
  x = 99;
  r = match x { 1 => 10, 2 => 20 };
  assert(r == null, "r should be null");
}

fn test_match_scalar_single_arm() {
  x = 5;
  r = match x { 5 => "five" };
  assert(r == "five", "r");
}

fn test_match_scalar_negative() {
  x = -1;
  r = match x { -1 => "neg", 0 => "zero", 1 => "pos", _ => "other" };
  assert(r == "neg", "r");
}

// ── Range patterns ──────────────────────────────────────────────────────────

fn test_match_range_inclusive() {
  x = 5;
  r = match x { 1..=3 => "low", 4..=6 => "mid", 7..=9 => "high", _ => "other" };
  assert(r == "mid", "r");
}

fn test_match_range_exclusive() {
  x = 10;
  r = match x { 0..10 => "single", 10..100 => "double", _ => "large" };
  assert(r == "double", "r");
}

fn test_match_range_boundary() {
  assert(match 0 { 0..=0 => true, _ => false }, "zero");
  assert(match 10 { 0..10 => false, _ => true }, "exclusive end");
  assert(match 9 { 0..10 => true, _ => false }, "just inside");
}

// ── Guard clauses ───────────────────────────────────────────────────────────

fn test_guard_basic() {
  p = High;
  r = match p { High if false => 99, High => 10, _ => 0 };
  assert(r == 10, "basic guard");
}

enum Level { LA, LB, LC }

fn score(l: Level, x: integer) -> text {
  match l {
    LA if x > 90 => "excellent",
    LA if x > 70 => "good",
    LA => "ok",
    LB => "meh",
    LC => "bad"
  }
}

fn test_guard_multiple() {
  assert(score(LA, 95) == "excellent", "multiple guards");
}

enum GShape {
  GCircle { radius: float },
  GRect { width: float, height: float }
}

fn garea(s: GShape) -> float {
  match s {
    GCircle { radius } if radius > 0.0 => PI * radius * radius,
    GCircle { radius } => 0.0,
    GRect { width, height } => width * height
  }
}

fn test_guard_with_binding() {
  assert(garea(GCircle { radius: -1.0 }) == 0.0, "guard with binding");
}

// @EXPECT_ERROR: guard must be boolean, got integer
fn test_guard_non_bool() {
  x = NA;
  match x { NA if 42 => 1, _ => 0 };
}

enum GDir { GNorth, GSouth }

fn glabel(d: GDir) -> text {
  match d { GNorth if false => "never", GNorth => "N", GSouth => "S" }
}

fn test_guard_exhaustive() {
  assert(glabel(GNorth) == "N", "exhaustive guard");
}

fn test_guard_scalar() {
  x = 5;
  r = match x { 5 if x > 10 => "big five", 5 => "five", _ => "other" };
  assert(r == "five", "r: {r}");
}

fn test_guard_scalar_wildcard() {
  x = 42;
  r = match x { _ if x > 100 => "big", _ if x > 10 => "medium", _ => "small" };
  assert(r == "medium", "r: {r}");
}

// ── Block body and special patterns ─────────────────────────────────────────

fn test_match_arm_block_body() {
  x = 2;
  r = match x { 1 => { 10 + 1 }, 2 => { 20 + 2 }, _ => 0 };
  assert(r == 22, "r: {r}");
}

fn classify_null(n: integer) -> text {
  match n { null => "absent", 0 => "zero", _ => "other" }
}

fn test_scalar_null_pattern() {
  assert(classify_null(0) == "zero", "null pattern");
}

fn describe_char(c: character) -> text {
  match c { 'a' => "vowel a", 'e' => "vowel e", _ => "other" }
}

fn test_scalar_char_pattern() {
  assert(describe_char('a') == "vowel a", "char pattern");
}

enum Dir { DNorth, DSouth, DEast, DWest }

fn axis(d: Dir) -> text {
  match d { DNorth | DSouth => "vertical", DEast | DWest => "horizontal" }
}

fn test_or_pattern_plain_enum() {
  assert(axis(DSouth) == "vertical", "or pattern");
}

fn classify_or(n: integer) -> text {
  match n { 1 | 2 | 3 => "low", 10 | 20 => "high", _ => "other" }
}

fn test_or_pattern_scalar() {
  assert(classify_or(2) == "low", "or scalar");
}

// ── Vector patterns ─────────────────────────────────────────────────────────

fn test_vector_match_exact() {
  v = [10, 20, 30];
  r = match v { [a, b] => a + b, [a, b, c] => a + b + c, _ => 0 };
  assert(r == 60, "exact 3-elem match {r}");
}

fn test_vector_match_head_rest() {
  v = [5, 6, 7];
  r = match v { [x, ..] => x, _ => 0 };
  assert(r == 5, "head rest {r}");
}

fn test_vector_match_tail() {
  v = [5, 6, 7];
  r = match v { [.., x] => x, _ => 0 };
  assert(r == 7, "tail {r}");
}

fn test_vector_match_empty() {
  v = [1];
  clear(v);
  r = match v { [] => 1, _ => 0 };
  assert(r == 1, "empty match {r}");
}

// ── Binding patterns ────────────────────────────────────────────────────────

fn classify_bind(x: integer) -> integer {
  match x { 1 => 100, n => n * 10 }
}

fn test_scalar_binding_wildcard() {
  assert(classify_bind(5) == 50, "wildcard bind");
}

fn describe_at(x: integer) -> text {
  match x { v @ 1 => "{v} is one", _ => "other" }
}

fn test_scalar_binding_at() {
  assert(describe_at(1) == "1 is one", "at bind");
}
