// Vector operations: append, format, slicing, sorting, collections.

enum VVal { VA, VB, VC }

fn test_append_vector() {
  v = [VA, VA];
  v += [VB] + [VC] + [VA];
  assert("{v}" == "[VA,VA,VB,VC,VA]", "append enum vector");
}

fn test_format_vector() {
  v = [1, 2, 4, 8];
  v += [16];
  r = "{v} {v.len()} {v[2]} {v[1..3]} {v[rev(1..=3)]} {for x in v if x >= 4 {x/2}}";
  assert(r == "[1,2,4,8,16] 5 4 [2,4] [8,4,2] [2,4,8]", "format vector");
}

fn test_parse_vector() {
  a = "[ 1.2, -10.3, 1.812e4, 1.001e-8 ]" as vector<float>;
  r = a[2] + a[3];
  assert(r > 18119.0, "parse float vector");
}

fn test_loop_variables() {
  r = "{for x in 0..10 if x != 0 && x % 3 == 0 {if x#first { x } else {x * 2}}}";
  assert(r == "[3,12,18]", "loop variables");
}

fn test_slice_assign() {
  v = [1, 2, 4, 8];
  s = v[1..3];
  assert("{s}" == "[2,4]", "slice assign");
}

fn test_slice_append() {
  v = [1, 2, 3];
  v += v[1..3];
  assert("{v}" == "[1,2,3,2,3]", "slice append");
}

fn test_slice_no_mutation() {
  v = [10, 20, 30];
  s = v[0..2];
  s += [-1];
  assert("{v} {s}" == "[10,20,30] [10,20,-1]", "slice no mutation");
}

struct VElm { a: integer, b: integer }

fn test_format_object() {
  v = [VElm{a:1, b:2}, VElm{a:12, b:13}, VElm{a:4, b:5}];
  v[2].b = 6;
  assert("{v} sizeof {sizeof(VElm)}" == `[{{a:1,b:2}},{{a:12,b:13}},{{a:4,b:6}}] sizeof 8`, "format object");
}

fn vsum(v: vector<integer>) -> integer {
  t = 0;
  for i in v { t += i }
  t
}

fn test_sum_vector() {
  assert(vsum([1, 2, 3, 4, 5]) == 15, "sum vector");
}

fn test_growing_vector() {
  a: vector<integer> = [];
  for v in 1..400 { a += [v * 10] }
  sum = 0;
  for elm in a { sum += elm }
  assert("{sum}" == "798000", "growing vector");
}

fn vfill() -> vector<text> {
  result: vector<text> = [];
  result += ["aa"];
  result += ["bb"];
  result
}

fn test_fill_result() {
  t = vfill();
  assert("{t}" == `["aa","bb"]`, "fill result");
}

struct VCount { t: text, v: integer }
struct VCounting { v: vector<VCount>, h: hash<VCount[t]> }

fn cfill(c: VCounting) {
  c.v = [
    {t:"One", v:1}, {t:"Two", v:2}
  ];
  c.v += [
    {t:"Three", v:3}, {t:"Four", v:4}, {t:"Five", v:5},
    {t:"Six", v:6}, {t:"Seven", v:7}, {t:"Eight", v:8},
    {t:"Nine", v:9}, {t:"Ten", v:10}, {t:"Eleven", v:11},
    {t:"Twelve", v:12}, {t:"Thirteen", v:13}
  ];
}

fn test_combination_hash() {
  c = VCounting {};
  cfill(c);
  assert(!c.h["None"], "No element");
  add = 0;
  for v in c.v { add += v.v; }
  assert(add == 91, "Incorrect sum");
  assert(c.h["Five"].v + c.h["Seven"].v == 12, "hash lookup");
}

struct VData { name: character, number: integer }

fn vdata(n: text) -> vector<VData> {
  res: vector<VData> = [];
  nr = 0;
  for ch in n {
    res += [VData {name: ch, number: nr}];
    nr += 1;
  }
  res
}

fn test_fill_fn() {
  d = vdata("test");
  assert("{d}" == `[{{name:'t',number:0}},{{name:'e',number:1}},{{name:'s',number:2}},{{name:'t',number:3}}]`,
    "fill fn");
}

fn test_vector_clear() {
  v = [1, 2, 3, 4, 5];
  clear(v);
  assert(v.len() == 0, "cleared");
  v += [10];
  assert(v.len() == 1, "after re-add");
}

fn test_vector_sort() {
  v = [5, 2, 8, 1, 9, 3];
  sort(v);
  assert("{v}" == "[1,2,3,5,8,9]", "sorted");
}

fn test_vector_reverse() {
  v = [1, 2, 3, 4, 5];
  reverse(v);
  assert("{v}" == "[5,4,3,2,1]", "reversed");
}

fn test_remove_in_loop() {
  v = [1, 2, 3, 4, 5, 6];
  for e in v {
    if e % 2 == 0 { e#remove }
  }
  assert("{v}" == "[1,3,5]", "remove evens");
}

fn test_for_comprehension() {
  v = [for n in 1..7 { n * 2 }];
  assert("{v}" == "[2,4,6,8,10,12]", "comprehension");
}

fn test_for_comprehension_if() {
  v = [for n in 1..10 if n % 2 == 0 { n }];
  assert("{v}" == "[2,4,6,8]", "comprehension if");
}

struct VSortElm { skey: integer, val: integer }
struct VSortDb { s: sorted<VSortElm[skey]> }

fn test_sorted_reverse_iterator() {
  db = VSortDb { s: [VSortElm{skey:1,val:10}, VSortElm{skey:2,val:20}, VSortElm{skey:3,val:30}] };
  fwd = 0;
  for e in db.s { fwd = fwd * 10 + e.skey }
  assert(fwd == 123, "forward got {fwd}");
  rev_sum = 0;
  for e in rev(db.s) { rev_sum = rev_sum * 10 + e.skey }
  assert(rev_sum == 321, "reverse got {rev_sum}");
}

fn test_sorted_reverse_empty() {
  db = VSortDb { s: [] };
  sum = 0;
  for e in rev(db.s) { sum += e.skey }
  assert(sum == 0, "empty rev got {sum}");
}

fn test_sorted_remove() {
  db = VSortDb { s: [VSortElm{skey:1,val:10}, VSortElm{skey:2,val:20}, VSortElm{skey:3,val:30}, VSortElm{skey:4,val:40}] };
  for e in db.s if e.skey % 2 == 0 {
    e#remove;
  }
  total = 0;
  for e in db.s { total += e.skey }
  assert(total == 4, "remaining keys {total}");
}

struct VIdxElm { ikey: integer, val: integer }
struct VIdxDb { map: index<VIdxElm[ikey]> }

fn test_index_loop_remove_small() {
  db = VIdxDb { map: [VIdxElm{ikey:1,val:10}, VIdxElm{ikey:2,val:20}, VIdxElm{ikey:3,val:30}] };
  for e in db.map { e#remove; }
  count = 0;
  for _e in db.map { count += 1; }
  assert(count == 0, "should be empty, count={count}");
}

fn test_sort_int_vector() {
  v = [5, 2, 8, 1, 9, 3];
  sort(v);
  assert("{v}" == "[1,2,3,5,8,9]", "sort int");
}

fn test_sort_empty() {
  v: vector<integer> = [];
  sort(v);
  assert(v.len() == 0, "sort empty");
}

fn test_insert_at_start() {
  v = [2, 3, 4];
  insert(v, 0, 1);
  assert("{v}" == "[1,2,3,4]", "insert start");
}

fn test_insert_at_end() {
  v = [1, 2, 3];
  insert(v, 3, 4);
  assert("{v}" == "[1,2,3,4]", "insert end");
}

fn test_reverse_single() {
  v = [42];
  reverse(v);
  assert("{v}" == "[42]", "reverse single");
}

fn test_reverse_empty() {
  v: vector<integer> = [];
  reverse(v);
  assert(v.len() == 0, "reverse empty");
}

fn test_map_method() {
  v = [1, 2, 3, 4, 5];
  r = v.map(|x| { x * x });
  assert("{r}" == "[1,4,9,16,25]", "map method");
}

fn test_filter_method() {
  v = [1, 2, 3, 4, 5, 6];
  r = v.filter(|x| { x % 2 == 0 });
  assert("{r}" == "[2,4,6]", "filter method");
}

fn test_reduce_method() {
  v = [1, 2, 3, 4, 5];
  r = v.reduce(0, |acc, x| { acc + x });
  assert(r == 15, "reduce method");
}

fn test_vector_self_append_empty() {
  v: vector<integer> = [];
  v += v;
  assert(len(v) == 0, "empty self-append");
}

struct VGContainer { src: vector<integer>, dst: vector<integer> }

fn test_for_loop_mutation_guard_different_field_ok() {
  db = VGContainer { src: [1, 2, 3], dst: [] };
  for e in db.src { db.dst += [e * 2]; }
  assert(len(db.dst) == 3, "len: {len(db.dst)}");
  assert(db.dst[0] == 2, "dst[0]: {db.dst[0]}");
}

fn vsort_merge(lp: vector<integer>, rp: vector<integer>) -> vector<integer> {
  out = [for mg_i in 0..0 { mg_i }];
  li = 0; ri = 0;
  ll = len(lp); rl = len(rp);
  for _mg_step in 0..(ll + rl) {
    if li >= ll && ri >= rl { break; }
    if li >= ll { out += [rp[ri]]; ri += 1; }
    else if ri >= rl { out += [lp[li]]; li += 1; }
    else if lp[li] <= rp[ri] { out += [lp[li]]; li += 1; }
    else { out += [rp[ri]]; ri += 1; }
  }
  out
}

fn vsort(arr: vector<integer>, lo: integer, hi: integer) -> vector<integer> {
  sz = hi - lo;
  if sz <= 1 {
    base = [for ms_i in 0..0 { ms_i }];
    if sz == 1 { base += [arr[lo]]; }
    return base;
  }
  mid = lo + sz / 2;
  vsort_merge(vsort(arr, lo, mid), vsort(arr, mid, hi))
}

fn test_merge_sort() {
  data = [3, 1, 4, 1, 5, 9, 2, 6];
  out = vsort(data, 0, 8);
  assert(out[0] == 1, "first={out[0]}");
  assert(out[7] == 9, "last={out[7]}");
}
