// P103: Pre-existing failures from 06-structs.loft discovered when wrap.rs
// was updated to run all entry points (not just main()).
// test_vector_inline_argument: "Unknown record" or assert panic — passing an
// inline vector literal [1,2,3] + [4,5] as a function argument corrupts state.

fn smb_vec_sum(r: vector<integer>) -> integer {
  total = 0;
  for smb_e in r {
    total += smb_e;
  }
  total
}

// Guard: simple inline vector arguments work.
fn test_vector_simple_argument_ok() {
  assert(smb_vec_sum([1,2,3,4,5]) == 15, "simple vector argument");
}

// Bug: inline vector concatenation as argument corrupts state.
fn test_vector_inline_concat_argument() {
  assert(smb_vec_sum([1,2,3] + [4,5]) == 15, "concat vector argument");
}

// @EXPECT_FAIL: combined vector expression
fn test_vector_combined_expression() {
  assert(smb_vec_sum([1,2,3,4,5]) + 100 * smb_vec_sum([1,2,3] + [4,5]) == 1515, "combined vector expression");
}
