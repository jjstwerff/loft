// Index range queries and sorted integer-key lookups: coverage for
// database/search.rs find_index, range iteration, and sorted_find paths.

struct RngItem {
  nr: integer,
  label: text,
  val: integer
}

struct RngStore {
  items: index < RngItem[nr, -label] >
}

struct RngScore {
  pts: integer,
  name: text
}

struct RngBoard {
  scores: sorted < RngScore[pts] >
}

fn rng_build_index() -> RngStore {
  RngStore { items: [
    RngItem { nr: 10, label: "alpha", val: 1 },
    RngItem { nr: 20, label: "beta", val: 2 },
    RngItem { nr: 20, label: "gamma", val: 3 },
    RngItem { nr: 30, label: "delta", val: 4 },
    RngItem { nr: 30, label: "epsilon", val: 5 },
    RngItem { nr: 30, label: "alpha", val: 6 },
    RngItem { nr: 40, label: "zeta", val: 7 },
    RngItem { nr: 50, label: "eta", val: 8 }
  ] }
}

fn test_index_range_basic() {
  irb_db = rng_build_index();
  irb_sum = 0;
  irb_cnt = 0;
  for irb_e in irb_db.items[20..40] {
    irb_sum += irb_e.val;
    irb_cnt += 1;
  }
  assert(irb_cnt == 5, "range [20..40) count: {irb_cnt}");
  assert(irb_sum == 20, "range [20..40) sum: {irb_sum}");
}

fn test_index_range_empty() {
  ire_db = rng_build_index();
  // Range with no matching primary keys.
  ire_hi = 0;
  for ire_h in ire_db.items[100..200] {
    ire_hi += 1;
  }
  assert(ire_hi == 0, "range [100..200) returns 0 elements");
}

fn test_index_range_with_secondary() {
  irs_db = rng_build_index();
  irs_sum = 0;
  irs_cnt = 0;
  for irs_e in irs_db.items[20..40, "gamma"] {
    irs_sum += irs_e.val;
    irs_cnt += 1;
  }
  // Range nr in [20..40), secondary label from "gamma" (descending).
  // Actual results depend on how the range+secondary filter works.
  assert(irs_cnt > 0, "range+secondary found elements: {irs_cnt}");
  assert(irs_sum == 35, "range+secondary sum: {irs_sum}");
}

fn test_index_range_single_element() {
  ise_db = rng_build_index();
  ise_cnt = 0;
  for ise_e in ise_db.items[10..11] {
    ise_cnt += 1;
  }
  assert(ise_cnt == 1, "single element range: {ise_cnt}");
}

fn test_index_full_iteration() {
  ifi_db = rng_build_index();
  ifi_sum = 0;
  for ifi_e in ifi_db.items {
    ifi_sum += ifi_e.val;
  }
  assert(ifi_sum == 36, "full iteration sum: {ifi_sum}");
}

fn test_index_exact_lookup() {
  iel_db = rng_build_index();
  assert(iel_db.items[30, "delta"].val == 4, "exact multi-key lookup");
  assert(!iel_db.items[30, "missing"], "missing secondary key is null");
  assert(!iel_db.items[99, "any"], "missing primary key is null");
}

fn test_index_range_after_removal() {
  iar_db = rng_build_index();
  iar_db.items[20, "beta"] = null;
  iar_cnt = 0;
  for iar_e in iar_db.items[20..40] {
    iar_cnt += 1;
  }
  assert(iar_cnt == 4, "range after removal: {iar_cnt}");
}

fn test_sorted_integer_key() {
  sik_board = RngBoard { scores: [
    RngScore { pts: 100, name: "Alice" },
    RngScore { pts: 50, name: "Bob" },
    RngScore { pts: 200, name: "Carol" },
    RngScore { pts: 150, name: "Dave" },
    RngScore { pts: 75, name: "Eve" }
  ] };
  sik_prev = 0;
  sik_ok = true;
  for sik_e in sik_board.scores {
    if sik_e.pts < sik_prev {
      sik_ok = false;
    }
    sik_prev = sik_e.pts;
  }
  assert(sik_ok, "sorted integer key ascending");
  assert(sik_board.scores[100].name == "Alice", "sorted int lookup 100");
  assert(sik_board.scores[200].name == "Carol", "sorted int lookup 200");
  assert(!sik_board.scores[999], "sorted missing int key is null");
}

fn test_sorted_reverse_iteration() {
  sri_board = RngBoard { scores: [
    RngScore { pts: 100, name: "Alice" },
    RngScore { pts: 50, name: "Bob" },
    RngScore { pts: 200, name: "Carol" }
  ] };
  sri_prev = 999;
  sri_ok = true;
  for sri_e in rev(sri_board.scores) {
    if sri_e.pts > sri_prev {
      sri_ok = false;
    }
    sri_prev = sri_e.pts;
  }
  assert(sri_ok, "sorted reverse descending");
}

fn test_sorted_remove_and_verify() {
  srv_board = RngBoard { scores: [
    RngScore { pts: 10, name: "X" },
    RngScore { pts: 20, name: "Y" },
    RngScore { pts: 30, name: "Z" }
  ] };
  srv_board.scores[20] = null;
  assert(!srv_board.scores[20], "removed score is null");
  srv_cnt = 0;
  for srv_e in srv_board.scores {
    srv_cnt += 1;
  }
  assert(srv_cnt == 2, "sorted count after removal: {srv_cnt}");
}
