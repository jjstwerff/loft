// Error tests moved to 102-expected-errors.loft
// Compile-time warning detection tests.

// @EXPECT_WARNING: Not all code paths return
fn pe_classify(n: integer) -> text not null {
  if n > 0 { return "pos"; }
}

// --- Unused loop variable warnings ---

// @EXPECT_WARNING: Variable i is never read
fn test_unused_loop_var_range() {
  total = 0;
  for i in 0..3 { total += 1; }
  assert(total == 3, "t");
}

// @EXPECT_WARNING: Variable item is never read
fn test_unused_loop_var_vector() {
  items = [1, 2, 3];
  total = 0;
  for item in items { total += 1; }
  assert(total == 3, "t");
}

// --- Unreachable code warnings ---

// @EXPECT_WARNING: Unreachable code after return
fn pe_unreachable_return() -> integer {
  return 1;
  x = 2;
  x
}

// @EXPECT_WARNING: Unreachable code after break
fn test_unreachable_after_break() {
  for _i in 1..5 {
    break;
    assert(false, "unreachable");
  }
}

// @EXPECT_WARNING: Unreachable code after continue
fn test_unreachable_after_continue() {
  for _i in 1..5 {
    continue;
    assert(false, "unreachable");
  }
}

// --- Dead assignment: assert counts as a read ---

// @EXPECT_WARNING: Dead assignment
// The first assignment to 'found' is overwritten before being read.
// assert(found, ...) counts as a read, so the warning targets the first write.
fn test_dead_assign_assert_reads() {
  found = false;
  found = true;
  assert(found, "assert counts as a read");
}

// --- Enum dispatch: missing-variant warning ---

enum Priority { High {pts: integer}, Low {dummy: integer} }

fn mv_score(self: High) -> integer { self.pts }
// (no mv_score for Low — synthesizer warns at end of first pass)

// @EXPECT_WARNING: no implementation of 'mv_score' for variant 'Low'
fn test_missing_variant_warning() {
  h = High {pts: 99};
  assert(mv_score(h) == 99, "dispatch to High variant works");
}

