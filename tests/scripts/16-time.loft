// Time functions: now() and ticks().

fn test_now_is_positive() {
  t = now();
  assert(t > 946684800000, "now() too small: {t}");
}

fn test_now_is_not_null() {
  t = now();
  assert(t != null, "now() returned null");
}

fn test_ticks_is_non_negative() {
  t = ticks();
  assert(t >= 0, "ticks() negative: {t}");
}

fn test_ticks_is_monotonic() {
  t1 = ticks();
  t2 = ticks();
  assert(t2 >= t1, "ticks() went backwards: {t1} then {t2}");
}
