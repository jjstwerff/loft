// P101/C57: Float format precision :.0 — fixed.

fn test_float_zero_precision() {
  assert("{3.14159:.0}" == "3", "zero precision: [{3.14159:.0}]");
}

fn test_float_zero_precision_negative() {
  assert("{-2.7:.0}" == "-3", "zero precision negative: [{-2.7:.0}]");
}

fn test_float_zero_precision_exact() {
  assert("{5.0:.0}" == "5", "zero precision exact");
}
