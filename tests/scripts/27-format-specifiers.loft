// Format string specifiers: passing tests for radix, width, precision.

fn test_bare_specifier_d_accepted() {
  n = 42;
  s = "{n:d}";
  assert(s == "42", s);
}

fn test_f_for_float_accepted() {
  n = 42;
  s = "{n:5f}";
  assert(s == "   42", s);
}

fn test_d_with_width_accepted() {
  n = 42;
  s = "{n:5d}";
  assert(s == "   42", s);
}

fn test_bare_precision_float() {
  f = 3.14159;
  s = "{f:.2}";
  assert(s == "3.14", s);
}

fn test_string_literal_no_specifier() {
  s = "{"hello"}";
  assert(s == "hello", s);
}

fn test_string_literal_with_width() {
  s = "{"hello":3}";
  assert(s == "hello", s);
}

fn test_format_use_after_assign() {
  cd = 5;
  s = "{cd}";
  assert(s == "5", s);
}

fn test_format_loop_count() {
  v = [10, 20, 30];
  r = "";
  for e in v {
    if !e#first { r += "," }
    r += "{e#count}:{e}";
  }
  assert(r == "0:10,1:20,2:30", r);
}
