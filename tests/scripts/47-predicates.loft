// P3: Vector predicate aggregates — any, all, count_if

fn is_positive(x: integer) -> boolean { x > 0 }
fn is_even(x: integer) -> boolean { x % 2 == 0 }
fn is_big(x: integer) -> boolean { x > 100 }

fn main() {
  nums = [1, 2, 3, 4, 5];
  neg = [-1, -2, -3];
  mixed = [-1, 0, 3, -5, 7];

  // --- any ---
  assert(any(nums, is_positive), "any: all positive");
  assert(!any(neg, is_positive), "any: none positive");
  assert(any(mixed, is_positive), "any: some positive");

  // --- all ---
  assert(all(nums, is_positive), "all: all positive");
  assert(!all(mixed, is_positive), "all: not all positive");

  // --- count_if ---
  assert(count_if(nums, is_even) == 2, "count_if: 2 even in 1..5");
  assert(count_if(nums, is_big) == 0, "count_if: none big");
  assert(count_if(mixed, is_positive) == 2, "count_if: 2 positive in mixed");

  // --- lambda forms ---
  assert(any(nums, |x| { x == 3 }), "any lambda");
  assert(all(nums, |x| { x < 10 }), "all lambda");
  assert(count_if(nums, |x| { x > 3 }) == 2, "count_if lambda");
}
