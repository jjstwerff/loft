// T2: size(t) — Unicode character count

fn test_size_ascii() {
  assert(size("hello") == 5, "ASCII size");
}

fn test_size_multibyte() {
  assert(size("héllo") == 5, "Multi-byte accent");
  assert(size("日本語") == 3, "CJK characters");
}

fn test_size_empty() {
  assert(size("") == 0, "Empty text");
}

fn test_size_emoji() {
  assert(size("🎉") == 1, "4-byte emoji");
  assert(size("♥") == 1, "3-byte heart");
  assert(size("a😃b") == 3, "Mixed ASCII and emoji");
}
