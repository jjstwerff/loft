// P100/C56: Left-align and center-align format specifiers — fixed.

fn test_left_align_integer() {
  assert("{42:<6}" == "42    ", "left-align integer: [{42:<6}]");
}

fn test_center_align_integer() {
  assert("{42:^6}" == "  42  ", "center-align integer: [{42:^6}]");
}

fn test_left_align_float() {
  assert("{3.14:<8}" == "3.14    ", "left-align float: [{3.14:<8}]");
}

fn test_center_align_float() {
  assert("{3.14:^8}" == "  3.14  ", "center-align float: [{3.14:^8}]");
}

fn test_left_align_text() {
  s = "hi";
  assert("{s:<6}" == "hi    ", "left-align text");
}

fn test_center_align_text() {
  s = "hi";
  assert("{s:^6}" == "  hi  ", "center-align text");
}

fn test_right_align_integer() {
  assert("{42:>6}" == "    42", "right-align integer");
}

fn test_default_align_integer() {
  assert("{42:6}" == "    42", "default align integer is right");
}
