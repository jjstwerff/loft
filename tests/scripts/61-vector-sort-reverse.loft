// Vector sort, reverse, and insert: coverage for vector.rs sort_vector,
// reverse_vector, and insert_vector paths.

fn test_sort_integers() {
  si_v = [5, 3, 1, 4, 2];
  sort(si_v);
  assert("{si_v}" == "[1,2,3,4,5]", "sort integers: {si_v}");
  sort(si_v);
  assert("{si_v}" == "[1,2,3,4,5]", "sort already sorted: {si_v}");
}

fn test_sort_single_and_empty() {
  sse_one = [42];
  sort(sse_one);
  assert(sse_one[0] == 42, "sort single element");
  sse_empty = [for sse_d in 0..0 { sse_d }];
  sort(sse_empty);
  assert(sse_empty.len() == 0, "sort empty vector");
}

fn test_sort_floats() {
  sf_v = [3.14, -1.0, 2.71, 0.0, -0.5];
  sort(sf_v);
  assert(sf_v[0] == -1.0, "sort float first");
  assert(sf_v[1] == -0.5, "sort float second");
  assert(sf_v[2] == 0.0, "sort float third");
  assert(sf_v[3] == 2.71, "sort float fourth");
  assert(sf_v[4] == 3.14, "sort float fifth");
}

fn test_sort_longs() {
  sl_v = [300l, 100l, 200l, 500l, 400l];
  sort(sl_v);
  assert("{sl_v}" == "[100,200,300,400,500]", "sort longs: {sl_v}");
}

fn test_sort_singles() {
  ss_v = [2.0f, 1.0f, 3.0f];
  sort(ss_v);
  assert(ss_v[0] == 1.0f, "sort single first");
  assert(ss_v[1] == 2.0f, "sort single second");
  assert(ss_v[2] == 3.0f, "sort single third");
}

fn test_reverse_integers() {
  ri_v = [1, 2, 3, 4, 5];
  reverse(ri_v);
  assert("{ri_v}" == "[5,4,3,2,1]", "reverse integers: {ri_v}");
}

fn test_reverse_single_and_empty() {
  rse_one = [99];
  reverse(rse_one);
  assert(rse_one[0] == 99, "reverse single element");
  rse_empty = [for rse_d in 0..0 { rse_d }];
  reverse(rse_empty);
  assert(rse_empty.len() == 0, "reverse empty vector");
}

fn test_reverse_two_elements() {
  rt_v = [10, 20];
  reverse(rt_v);
  assert("{rt_v}" == "[20,10]", "reverse two: {rt_v}");
}

fn test_reverse_twice_restores() {
  rtr_v = [1, 2, 3, 4];
  reverse(rtr_v);
  reverse(rtr_v);
  assert("{rtr_v}" == "[1,2,3,4]", "double reverse: {rtr_v}");
}

fn test_reverse_floats() {
  rf_v = [1.1, 2.2, 3.3];
  reverse(rf_v);
  assert(rf_v[0] == 3.3, "reverse float first");
  assert(rf_v[2] == 1.1, "reverse float last");
}

fn test_sort_then_reverse() {
  sr_v = [3, 1, 4, 1, 5, 9, 2, 6];
  sort(sr_v);
  reverse(sr_v);
  assert("{sr_v}" == "[9,6,5,4,3,2,1,1]", "sort+reverse descending: {sr_v}");
}

fn test_insert() {
  ins_v = [10, 20, 30];
  insert(ins_v, 1, 15);
  assert("{ins_v}" == "[10,15,20,30]", "insert at 1: {ins_v}");
  insert(ins_v, 0, 5);
  assert("{ins_v}" == "[5,10,15,20,30]", "insert at 0: {ins_v}");
  insert(ins_v, 5, 35);
  assert("{ins_v}" == "[5,10,15,20,30,35]", "insert at end: {ins_v}");
}

fn test_sort_large() {
  slg_v = [for slg_i in 0..100 { 100 - slg_i }];
  sort(slg_v);
  assert(slg_v[0] == 1, "large sort first: {slg_v[0]}");
  assert(slg_v[99] == 100, "large sort last: {slg_v[99]}");
  slg_ok = true;
  for slg_e in slg_v {
    if slg_e#index > 0 {
      if slg_v[slg_e#index] < slg_v[slg_e#index - 1] {
        slg_ok = false;
      }
    }
  }
  assert(slg_ok, "large sort is monotonic");
}
