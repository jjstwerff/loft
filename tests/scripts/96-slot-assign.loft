// Slot assignment: patterns that were historically prone to overlapping stack slots.

struct SANode { val: integer }

fn find_max(nodes: vector<SANode>) -> integer {
  best = nodes[0].val;
  for n in nodes {
    if n.val > best { best = n.val }
  }
  best
}

fn test_int_accumulator_and_struct_loop_element() {
  nodes = [SANode{val:3}, SANode{val:10}, SANode{val:7}];
  assert(find_max(nodes) == 10, "Expected 10");
}

struct SAElm { a: integer, b: integer }

fn sum_with_first(v: vector<SAElm>) -> integer {
  e = v[0];
  t = 0;
  for el in v { t += el.a + el.b }
  t + e.a
}

fn test_ref_before_loop_and_loop_element() {
  v = [SAElm{a:1, b:2}, SAElm{a:12, b:13}, SAElm{a:4, b:5}];
  assert(sum_with_first(v) == 38, "Expected 38");
}

struct SAItem { val: integer }
struct SABag { items: vector<SAItem>, extra: SAItem }

fn sa_process(b: SABag) -> integer {
  result = 0;
  if b.items[0].val > 0 {
    result = b.items[0].val;
  } else {
    b.items += [b.extra];
    last = b.items[b.items.len() - 1];
    result = last.val;
  }
  result
}

fn test_long_lived_int_and_copy_record_followed_by_ref() {
  extra = SAItem { val: 42 };
  b = SABag { items: [], extra: extra };
  assert(sa_process(b) == 42, "Expected 42");
}

struct SAPair { x: integer, y: integer }

fn sum_matching(pairs: vector<SAPair>, xs: vector<SAPair>) -> integer {
  total = 0;
  for p in pairs {
    for q in xs {
      if p.x == q.x { total = total + p.y }
    }
  }
  total
}

fn test_nested_loop_struct_elements() {
  pairs = [SAPair{x:1, y:10}, SAPair{x:2, y:20}];
  xs = [SAPair{x:1, y:0}];
  assert(sum_matching(pairs, xs) == 10, "Expected 10");
}

struct SAPoint { x: integer, y: integer }

fn sum_points(pts: vector<SAPoint>) -> integer {
  acc = 0;
  for p in pts { acc += p.x + p.y }
  acc
}

fn test_post_loop_variable_reuses_dead_loop_slot() {
  pts = [SAPoint{x:1, y:2}, SAPoint{x:3, y:4}];
  total = sum_points(pts);
  assert(total == 10, "Expected 10");
}

fn add_chain() -> integer {
  x = 3;
  y = x + 1;
  z = y * 2;
  z
}

fn test_shadow_comparison_sequential_dead_primitives() {
  assert(add_chain() == 8, "Expected 8");
}

fn greet(name: text) -> text {
  msg = "Hello ";
  msg += name;
  msg
}

fn test_shadow_comparison_text_and_integer_mixed() {
  result = greet("world");
  assert(result == "Hello world", "Expected 'Hello world'");
}

fn compute() -> integer {
  a = 10;
  b = a * 2;
  c = b - 5;
  c
}

fn test_claim_free_sequential_primitives() {
  assert(compute() == 15, "Expected 15");
}

fn sa_build(prefix: text, n: integer) -> text {
  result = prefix;
  result += " ";
  result += "{n}";
  result
}

fn test_claim_free_text_variable_first_alloc() {
  assert(sa_build("count", 42) == "count 42", "Expected 'count 42'");
}
