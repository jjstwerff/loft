// C15: Function references should work regardless of definition order.

fn apply(f: fn(integer) -> integer, x: integer) -> integer {
  f(x)
}

fn main() {
  // Forward reference: triple is defined AFTER main
  assert(apply(triple, 3) == 9, "forward fn-ref: triple(3)={apply(triple, 3)}");
  assert(apply(double, 5) == 10, "forward fn-ref: double(5)={apply(double, 5)}");

  // Backward reference: should still work
  assert(apply(square, 4) == 16, "backward fn-ref: square(4)={apply(square, 4)}");
}

fn square(x: integer) -> integer {
  x * x
}

fn triple(x: integer) -> integer {
  x * 3
}

fn double(x: integer) -> integer {
  x * 2
}
