// Closures: lambda variable capture, timing, text deep-copy, factory functions.

fn make_adder(cl_base: integer) -> fn(integer) -> integer {
  fn(cl_n: integer) -> integer { cl_base + cl_n }
}

fn apply_fn(cl_f: fn(integer) -> integer, cl_val: integer) -> integer {
  cl_f(cl_val)
}

fn test_integer_capture() {
  offset = 100;
  shift = fn(cl_x: integer) -> integer { cl_x + offset };
  assert(shift(5) == 105, "integer capture: {shift(5)}");
}

fn test_multiple_integer_captures() {
  lo = 10;
  hi = 20;
  clamp_val = fn(cl_x: integer) -> integer {
    if cl_x < lo { lo } else if cl_x > hi { hi } else { cl_x }
  };
  assert(clamp_val(5) == 10, "clamped low: {clamp_val(5)}");
  assert(clamp_val(15) == 15, "clamped mid: {clamp_val(15)}");
  assert(clamp_val(25) == 20, "clamped high: {clamp_val(25)}");
}

fn test_text_capture_deep_copy() {
  greeting = "Hello";
  make_msg = fn(cl_name: text) -> text { "{greeting}, {cl_name}!" };
  assert(make_msg("Alice") == "Hello, Alice!", "text capture");
  // Mutating greeting after capture should NOT affect the closure.
  greeting = "Bye";
  assert(make_msg("Bob") == "Hello, Bob!", "deep copy: {make_msg("Bob")}");
}

// @EXPECT_WARNING: Dead assignment
fn test_capture_timing() {
  base = 10;
  add_base = fn(cl_n: integer) -> integer { base + cl_n };
  // Capture happened at definition time.
  base = 999;
  assert(add_base(5) == 15, "capture timing: {add_base(5)}");
}

fn test_factory_function() {
  add5 = make_adder(5);
  add10 = make_adder(10);
  assert(add5(3) == 8, "factory add5: {add5(3)}");
  assert(add10(3) == 13, "factory add10: {add10(3)}");
}

fn test_closure_in_higher_order() {
  factor = 3;
  scale = fn(cl_x: integer) -> integer { cl_x * factor };
  assert(apply_fn(scale, 7) == 21, "closure in HOF: {apply_fn(scale, 7)}");
}

fn test_closure_called_multiple_times() {
  counter = 0;
  inc = fn(cl_n: integer) -> integer { counter + cl_n };
  assert(inc(1) == 1, "first call");
  assert(inc(10) == 10, "second call");
}

fn test_non_capturing_lambda() {
  nums = [1, 2, 3, 4, 5];
  doubled = map(nums, |cl_x| { cl_x * 2 });
  assert(doubled[0] == 2, "doubled[0]");
  assert(doubled[4] == 10, "doubled[4]");
  evens = filter(nums, |cl_y| { cl_y % 2 == 0 });
  assert(len(evens) == 2, "evens count");
}
