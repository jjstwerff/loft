struct Point {
  x: float not null,
  y: float not null
}

struct Line {
  name: text,
  start: Point,
  end_p: Point
}

fn main() {
  l = Line {
    name: "diagonal",
    start: Point { x: 1.5, y: 2.5 },
    end_p: Point { x: 10.0, y: 20.0 }
  };
  assert(l.start.x == 1.5, "start x");
  assert(l.end_p.y == 20.0, "end y");
}
