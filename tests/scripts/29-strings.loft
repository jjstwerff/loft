// String/text operations: indexing, references, slicing, parsing, loops.

// utf8_index test stays in tests/strings.rs (codegen issue with a[0] indexing)

fn to_text() -> text {
  res = "aa ";
  for _i in 0..2 {
    res += "b";
  }
  res + " cc"
}

fn test_string_fn() {
  assert("1{to_text()}2" == "1aa bb cc2", "string fn");
}

fn text_ref() -> text {
  a = "12345";
  a[0..4]
}

fn test_var_ref() {
  assert(text_ref() == "1234", "var ref");
}

fn return_ref() -> text {
  a = "12345";
  return a[0..4];
}

fn test_return_ref() {
  assert(return_ref() == "1234", "return ref");
}

fn add_ref(a: &text, b: text = " world!") {
  a += b;
}

fn test_reference() {
  v = "Hello";
  add_ref(v);
  assert(v == "Hello world!", "reference");
}

fn add_default(a: text, b: &text = "var") -> text {
  b += "_" + a;
  b
}

fn test_default_ref() {
  assert(add_default("1234") == "var_1234", "default ref");
}

fn choice(a: text, b: text) -> text {
  if len(a) > len(b) { a } else { b }
}

fn test_call() {
  assert(choice("{1:03}", "{2}1") + choice("2", "") == "0012", "call");
}

fn test_work_loop() {
  a = 0;
  for t in 1..4 { a += "0{t}0" as integer }
  assert(a == 60, "work loop");
}

fn test_loop_variable() {
  a = 0;
  for _t in 1..5 { b = "123"; a += b as integer; if a > 200 { break; } }
  assert(a == 246, "loop variable");
}

fn res() -> integer {
  a = 0;
  for _t in 1..5 { b = "123"; a += b as integer; if a > 200 { return a; } }
  0
}

fn test_return_clear() {
  assert(res() == 246, "return clear");
}

fn last(filename: text) -> text {
  v = filename.rfind("/");
  if v { filename[v + 1..] } else { filename }
}

fn test_optional_remove() {
  assert(last("a/b/c") + last("d") == "cd", "optional remove");
}

fn build() -> text {
  t = "abcde";
  if t.len() > 3 { t } else { "" }
}

fn test_strange_if() {
  assert(build() == "abcde", "strange if");
}

fn parse_ident(s: text) -> integer {
  for t in 0..300 {
    l = s[t];
    if !l.is_alphanumeric() and l != '_' {
      return t;
    }
  }
  return 0;
}

fn test_string_parse() {
  assert(parse_ident("if_cond ") == 7, "string parse");
}

fn test_string_scope() {
  a = 1l;
  b = "";
  for n in 1..4 {
    t = "1";
    b += "n" + ":{n}" + "=";
    for _m in 1..n {
      t += "2";
    }
    b += t + " ";
    a += t as long;
  }
  assert("{a} via {b}" == "136 via n:1=1 n:2=12 n:3=122 ", "string scope");
}

