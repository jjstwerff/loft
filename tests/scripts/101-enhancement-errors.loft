// Expected-error tests for language enhancements.
// Separated from 100-enhancements.loft because parse errors prevent
// other test functions in the same file from running.

// @EXPECT_ERROR: requires a non-void function
fn test_break_value_in_void_fn() {
  for i in 0..10 {
    if i == 5 { break i; }
  }
}
