// Error tests moved to 102-expected-errors.loft
// Structs: field types, constructors, methods, virtual fields, null defaults.
struct Pos {
  x: integer,
  y: integer
}

struct Segment {
  label: text,
  start: Pos,
  end: Pos
}

struct Area {
  height: u16,
  terrain: u8,
  water: u8,
  direction: u8
}

struct Point {
  r: integer limit(0, 255) not null,
  g: integer limit(0, 255) not null,
  b: integer limit(0, 255) not null
}

fn value(self: Point) -> integer {
  self.r * 0x10000 + self.g * 0x100 + self.b
}

fn dimmed(self: Point) -> Point {
  Point {r: self.r / 2, g: self.g / 2, b: self.b / 2 }
}

struct Object {
  name_length: integer = len($.name),
  name: text
}

struct Circle {
  radius: float,
  area: float
    computed(3.14159265 * $.radius * $.radius)
}

struct Counter {
  count: integer not null
}

fn inc(self: Counter) {
  self.count += 1;
}

fn main() {
  // --- Basic constructor and field access ---
  p = Point {r: 128, b: 64 };
  assert(p.r == 128, "field r");
  assert(p.g == 0, "omitted field g defaults to 0 (not null)");
  assert(p.b == 64, "field b");
  // --- Method call ---
  assert(p.value() == 0x800040, "method value");
  // --- Method returning a new struct record ---
  dark = p.dimmed();
  assert(dark.r == 64, "dimmed r: {dark.r}");
  assert(dark.g == 0, "dimmed g: {dark.g}");
  assert(dark.b == 32, "dimmed b: {dark.b}");
  // --- Stored default field (= expr, computed at construction) ---
  o = Object {name: "hello" };
  assert(o.name_length == 5, "stored default name_length");
  o2 = Object {name: "hi" };
  assert(o2.name_length == 2, "stored default shorter name");
  // --- Computed field (not stored, recomputed on access) ---
  ci = Circle { radius: 5.0 };
  assert(ci.area > 78.0, "computed area: {ci.area}");
  assert(ci.area < 79.0, "computed area upper: {ci.area}");
  ci.radius = 10.0;
  assert(ci.area > 314.0, "recomputed area: {ci.area}");
  assert(ci.area < 315.0, "recomputed area upper: {ci.area}");
  // --- not null field with zero ---
  c = Counter { };
  assert(c.count == 0, "not null int defaults to 0");
  c.inc();
  assert(c.count == 1, "after inc count == 1");
  c.inc();
  assert(c.count == 2, "after two incs count == 2");
  // --- Compact format ---
  // Use escaped braces so the RHS is a literal string, not a format expression.
  assert("{p}" == "{{r:128,g:0,b:64}}", "compact struct format");
  // --- JSON format ---
  // Use escaped braces on the RHS; \" is a literal quote inside the string.
  assert("{o:j}" == "{{\"name_length\":5,\"name\":\"hello\"}}", "json format");
  // --- Vector of structs with repetition ---
  map =[Area {height: 0, terrain: 1, water: 1, direction: 1 };
  4];
  assert("{map[0]}" == "{{height:0,terrain:1,water:1,direction:1}}", "vector of structs [0]");
  assert("{map[3]}" == "{{height:0,terrain:1,water:1,direction:1}}", "vector of structs [3]");
  assert(!map[10], "out-of-bounds is null");
  // --- Field mutation ---
  pt = Point {r: 10, g: 20, b: 30 };
  pt.r = 99;
  assert(pt.r == 99, "field mutation");
  // --- Nested struct: field access and mutation ---
  seg = Segment {
  label: "AB",
  start: Pos {x: 1, y: 2 },
  end: Pos {x: 5, y: 6 }
 };
  assert(seg.start.x == 1, "nested field start.x");
  assert(seg.end.y == 6, "nested field end.y");
  assert(seg.label == "AB", "outer field label");
  // --- Nested struct field mutation ---
  seg.start.x = 99;
  seg.end.y = 77;
  assert(seg.start.x == 99, "nested field mutation start.x");
  assert(seg.end.y == 77, "nested field mutation end.y");
  assert(seg.start.y == 2, "unchanged field start.y stays 2");
  // --- Struct with all-default constructor ---
  p_def = Pos { };
  assert(p_def.x == 0, "default integer field is 0");
  assert(p_def.y == 0, "default integer field y is 0");
  // --- sizeof ---
  // Primitive types
  assert(sizeof(integer) == 8, "sizeof integer is 8");
  assert(sizeof(long) == 8, "sizeof long is 8");
  assert(sizeof(float) == 8, "sizeof float is 8");
  assert(sizeof(boolean) == 1, "sizeof boolean is 1");
  // Range-constrained integer types return their packed size
  assert(sizeof(u8) == 1, "sizeof u8 is 1");
  assert(sizeof(u16) == 2, "sizeof u16 is 2");
  assert(sizeof(i8) == 1, "sizeof i8 is 1");
  assert(sizeof(i16) == 2, "sizeof i16 is 2");
  assert(sizeof(i32) == 4, "sizeof i32 is 4");
  // Struct sizes — Pos uses `integer` (8B post-2c), so 2 × 8 = 16.
  assert(sizeof(Pos) == 16, "sizeof Pos (2x integer) is 16");
  // Point has 3 fields of integer limit(0,255) — packed to 1 byte each in DB storage
  assert(sizeof(Point) == 3, "sizeof Point (3x limited-integer) is 3");
  // --- Pretty-print format (:#) ---
  // Compact {o} vs pretty {o:#} with spaces and newline-indented nested structs.
  pp = Point {r: 10, g: 20, b: 30 };
  assert("{pp}" == "{{r:10,g:20,b:30}}", "compact struct format");
  assert("{pp:#}" == "{{ r: 10, g: 20, b: 30 }}", "pretty struct format");
  // --- Method called directly on a constructor expression ---
  assert(Point {r: 10, g: 20, b: 30 }.value() == 0x0a141e, "method on constructor");
  // --- Struct copy semantics: text fields are independent ---
  // Assigning a struct copies it; mutating the copy must not affect the original.
  sc_orig = Segment {label: "hello", start: Pos {x: 1, y: 2 }, end: Pos {x: 3, y: 4 } };
  sc_copy = sc_orig;
  sc_copy.label += " world";
  assert(sc_orig.label == "hello", "struct copy: original text field unchanged");
  assert(sc_copy.label == "hello world", "struct copy: copy has modified text");
  // --- Direct access on not-null struct fields ---
  pq = Point {r: 7, g: 0, b: 3 };
  assert(pq.r == 7, "not-null field returns assigned value");
  // A zero-valued not-null field is still non-null (0 != null sentinel).
  assert(pq.g == 0, "zero not-null field is 0 not null");
  // --- const local variable with struct ---
  const fixed = Counter { };
  assert(fixed.count == 0, "const local struct: field readable");
}

struct PObj { a: integer, bb: text, ccc: boolean }

fn obj() -> PObj { PObj { a: 12, bb: "hi", ccc: false } }

fn test_print_object() {
  o = obj();
  o.bb += '!';
  compact = "{o}";
  assert(compact == `{{a:12,bb:"hi!",ccc:false}}`, "compact format");
  pretty = "{o:#}";
  assert(pretty.contains("a: 12"), "pretty has a");
  assert(pretty.contains(`"hi!"`), "pretty has quoted bb");
}

enum SGender { Male, Female, Fluid }
struct SObj { a: vector<integer>, b: SGender }

fn sum_sobj(o: SObj) -> integer {
  r = 0;
  for v in o.a { r += v; }
  r
}

fn test_special_fields() {
  o = SObj { a: [1,4,3], b: Fluid };
  o.a += [sum_sobj(o)];
  assert("{o}" == `{{a:[1,4,3,8],b:Fluid}}`, "special fields");
}

struct CPoint {
  r: integer limit(0, 255) not null,
  g: integer limit(0, 255) not null,
  b: integer limit(0, 255) not null
}

fn value(self: CPoint) -> integer {
  self.r * 0x10000 + self.g * 0x100 + self.b
}

fn test_colours() {
  points = [ CPoint { r: 128, b: 128 }, CPoint { b: 255 } ];
  result = "size:{sizeof(CPoint)} purple:{points[0]} value:{points[0].value():x} blue:{points[1]}";
  assert(result == `size:3 purple:{{r:128,g:0,b:128}} value:800080 blue:{{r:0,g:0,b:255}}`, "colours");
}

struct MData {
  num: integer,
  values: vector<integer>
}

fn m_add(r: &MData = null, val: integer) {
  if !r {
    r = MData { num: 0 };
  }
  r.num += val;
  r.values += [val];
}

fn test_mutable_reference() {
  v = MData { num: 1 };
  m_add(v, 2);
  m_add(v, 3);
  assert("{v}" == `{{num:6,values:[2,3]}}`, "mutable reference");
}

fn vec_add(r: &vector<integer> = [], val: integer) {
  r += [val];
}

fn test_mutable_vector() {
  v = [1];
  vec_add(v, 2);
  vec_add(v, 3);
  assert("{v}" == "[1,2,3]", "mutable vector");
}

fn vec_sum(r: vector<integer>) -> integer {
  res = 0;
  for v in r {
    res += v;
  }
  res
}

struct RTData {
  name: text,
  number: integer
}

fn rt_data(n: text) -> text {
  res = RTData { name: n };
  res.name
}

fn test_return_text() {
  assert(rt_data("test") == "test", "return text");
}

struct ATObj { a: text }

fn test_assign_text() {
  o = ATObj { a: "a" };
  o.a = "b";
  o.a += "c";
  o.a += "d" + "e";
  o.a = "{o.a}f";
  assert("{o}" == `{{a:"bcdef"}}`, "assign text");
}

struct IST { name: text }

fn test_independent_strings() {
  a = IST { name: "hello" };
  b = a;
  b.name += " world";
  assert(a.name == "hello", "independent strings");
}

struct MCPt { x: integer, y: integer }

fn dist2(self: MCPt) -> integer { self.x * self.x + self.y * self.y }

fn test_method_on_constructor() {
  assert(MCPt { x: 3, y: 4 }.dist2() == 25, "method on constructor");
}

// Regression: borrowed loop variable whose dependency is allocated above
// current TOS caused a subtract overflow in gen_set_first_ref_null.
// The codegen now emits OpNullRefSentinel instead of OpCreateStack when
// the dependency slot is above the stack position.
struct DepItem { name: text, value: integer }
struct DepContainer { items: vector<DepItem>, extra: vector<integer> }

fn test_loop_dep_above_tos() {
  c = DepContainer {};
  c.items += [DepItem { name: "a", value: 10 }];
  c.items += [DepItem { name: "b", value: 20 }];
  c.items += [DepItem { name: "c", value: 30 }];
  c.extra += [1, 2, 3];
  total = 0;
  names = "";
  for it in c.items {
    total += it.value;
    names += it.name;
  }
  assert(total == 60, "total={total}");
  assert(names == "abc", "names={names}");
}
