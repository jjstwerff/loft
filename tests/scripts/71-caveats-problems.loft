// Runtime reproducers for known CAVEATS and PROBLEMS entries.
// Failing tests are annotated so they pass once the underlying bug is fixed.
// Parse-error tests are in 72-parse-error-caveats.loft (separate file).

// --- C54: file.lines() drops content without trailing newline ---

fn test_c54_file_lines_no_trailing_newline() {
  {c54_f = file("test_c54.txt"); c54_f += "no trailing newline";}
  c54_lines = file("test_c54.txt").lines();
  delete("test_c54.txt");
  assert(c54_lines.len() >= 1, "C54 file.lines no trailing newline: got {c54_lines.len()} lines");
}

fn test_c54_file_lines_with_trailing_newline_ok() {
  {c54w_f = file("test_c54w.txt"); c54w_f += "has trailing newline\n";}
  c54w_lines = file("test_c54w.txt").lines();
  delete("test_c54w.txt");
  assert(c54w_lines.len() >= 1, "C54 guard: with newline got {c54w_lines.len()} lines");
}

// --- P85: Struct-enum local variable — guard (was debug assertion, may be fixed) ---

enum P85Val { P85Int { n: integer }, P85Text { t: text } }

fn p85_extract() -> integer {
  p85_v = P85Int { n: 42 };
  if p85_v is P85Int { n } {
    return n;
  }
  0
}

fn test_p85_struct_enum_local() {
  p85_result = p85_extract();
  assert(p85_result == 42, "P85 struct-enum local: {p85_result}");
}

// --- P91: moved to 72-parse-error-caveats.loft (now a compile error) ---

// --- P98: Index range query with descending key returns wrong results ---

struct P98Item { cat: text, score: integer }
struct P98Db { idx: index<P98Item[-cat]> }

fn test_p98_index_range_descending_key() {
  p98_db = P98Db { idx: [
    P98Item { cat: "a", score: 1 },
    P98Item { cat: "b", score: 2 },
    P98Item { cat: "c", score: 3 }
  ] };
  p98_sum = 0;
  for p98_e in p98_db.idx["a".."c"] {
    p98_sum += p98_e.score;
  }
  assert(p98_sum == 3, "P98 descending key range: expected 3 got {p98_sum}");
}

fn test_p98_full_iteration_ok() {
  p98a_db = P98Db { idx: [
    P98Item { cat: "a", score: 1 },
    P98Item { cat: "b", score: 2 },
    P98Item { cat: "c", score: 3 }
  ] };
  p98a_total = 0;
  for p98a_e in p98a_db.idx {
    p98a_total += p98a_e.score;
  }
  assert(p98a_total == 6, "P98 guard: full iteration sum {p98a_total}");
}
