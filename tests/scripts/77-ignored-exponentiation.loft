// C54 FIXED: Exponentiation ** operator now works (mapped to pow())

fn test_exponentiation_sqrt() {
  sv_val = 9.0;
  sv_root = sv_val ** 0.5;
  assert(sv_root == 3.0, "sqrt of 9 via **");
}

fn test_exponentiation_square() {
  es_val = 3.0;
  es_sq = es_val ** 2.0;
  assert(es_sq == 9.0, "3 ** 2 = 9");
}

fn test_exponentiation_cube() {
  ec_val = 2.0;
  ec_cb = ec_val ** 3.0;
  assert(ec_cb == 8.0, "2 ** 3 = 8");
}

fn test_exponentiation_one() {
  eo_val = 42.0;
  eo_r = eo_val ** 1.0;
  assert(eo_r == 42.0, "x ** 1 = x");
}

fn test_exponentiation_zero() {
  ez_val = 42.0;
  ez_r = ez_val ** 0.0;
  assert(ez_r == 1.0, "x ** 0 = 1");
}
