// Hash edge cases: removal, missing-key removal, integer keys, growth —
// coverage for database/search.rs hash paths and keys.rs hash/compare.

struct HecEntry {
  word: text,
  freq: integer
}

struct HecMap {
  entries: vector < HecEntry >,
  lookup: hash < HecEntry[word] >
}

struct HecNum {
  id: integer not null,
  label: text
}

struct HecNumMap {
  data: vector < HecNum >,
  lookup: hash < HecNum[id] >
}

fn test_hash_text_lookup() {
  htl_m = HecMap { };
  htl_m.entries = [
    HecEntry { word: "hello", freq: 5 },
    HecEntry { word: "world", freq: 3 },
    HecEntry { word: "test", freq: 7 },
    HecEntry { word: "loft", freq: 2 }
  ];
  assert(htl_m.lookup["hello"].freq == 5, "text hash lookup hello");
  assert(htl_m.lookup["loft"].freq == 2, "text hash lookup loft");
  assert(!htl_m.lookup["missing"], "text hash missing key");
}

fn test_hash_removal() {
  hrm_m = HecMap { };
  hrm_m.entries = [
    HecEntry { word: "a", freq: 1 },
    HecEntry { word: "b", freq: 2 },
    HecEntry { word: "c", freq: 3 }
  ];
  hrm_m.lookup["b"] = null;
  assert(!hrm_m.lookup["b"], "removed key is null");
  assert(hrm_m.lookup["a"].freq == 1, "a still present after remove");
  hrm_m.lookup["b"] = null;
  assert(!hrm_m.lookup["b"], "double remove is safe");
  hrm_m.lookup["nonexistent"] = null;
  assert(!hrm_m.lookup["nonexistent"], "remove absent key is safe");
}

fn test_hash_integer_key() {
  hik_m = HecNumMap { };
  hik_m.data = [
    HecNum { id: 1, label: "one" },
    HecNum { id: 2, label: "two" },
    HecNum { id: 3, label: "three" },
    HecNum { id: 100, label: "hundred" }
  ];
  assert(hik_m.lookup[1].label == "one", "int hash lookup 1");
  assert(hik_m.lookup[100].label == "hundred", "int hash lookup 100");
  assert(!hik_m.lookup[999], "int hash missing key");
  hik_m.lookup[2] = null;
  assert(!hik_m.lookup[2], "int hash removed key");
  assert(hik_m.lookup[3].label == "three", "int hash 3 still present");
}

fn test_hash_growth() {
  hgr_m = HecMap { };
  hgr_m.entries = [];
  for hgr_n in 0..100 {
    hgr_m.entries += [HecEntry { word: "item_{hgr_n}", freq: hgr_n }];
  }
  assert(hgr_m.lookup["item_0"].freq == 0, "big hash item_0");
  assert(hgr_m.lookup["item_50"].freq == 50, "big hash item_50");
  assert(hgr_m.lookup["item_99"].freq == 99, "big hash item_99");
  assert(!hgr_m.lookup["item_100"], "big hash out of range");
}

fn test_hash_update_via_vector() {
  huv_m = HecMap { };
  huv_m.entries = [
    HecEntry { word: "x", freq: 1 },
    HecEntry { word: "y", freq: 2 }
  ];
  assert(huv_m.lookup["x"].freq == 1, "before update");
  for huv_e in huv_m.entries {
    if huv_e.word == "x" {
      huv_e.freq = 99;
    }
  }
  assert(huv_m.lookup["x"].freq == 99, "after update via vector");
}

fn test_hash_empty() {
  hem_m = HecMap { };
  hem_m.entries = [];
  assert(!hem_m.lookup["anything"], "empty hash lookup is null");
  hem_m.lookup["ghost"] = null;
}
