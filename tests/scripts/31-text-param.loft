// Test for text parameter handling.
// P115: text argument mutation auto-promotes to local String.

fn tp_reassign(tp_br: text) -> text {
  tp_br = "modified";
  tp_br
}

fn tp_append(tp_ba: text) -> text {
  tp_ba += " world";
  tp_ba
}

fn test_text_param_auto_promote() {
  assert(tp_reassign("hello") == "modified", "reassign");
  assert(tp_append("hello") == "hello world", "append");
}

// Workaround still works too.
fn test_text_param_workaround() {
  tp_result = tp_copy_and_modify("hello");
  assert(tp_result == "hello world", "workaround: {tp_result}");
}

fn tp_copy_and_modify(tp_orig: text) -> text {
  tp_local = tp_orig;
  tp_local += " world";
  tp_local
}

// Read-only text parameter works fine (no promotion needed).
fn test_text_param_read() {
  assert(tp_len("hello") == 5, "len");
  assert(tp_first("hello") == "h", "first");
  assert(tp_concat("hello", " world") == "hello world", "concat");
}

fn tp_len(tp_s: text) -> integer { len(tp_s) }
fn tp_first(tp_s: text) -> text { tp_s[0..1] }
fn tp_concat(tp_a: text, tp_b: text) -> text { tp_a + tp_b }
