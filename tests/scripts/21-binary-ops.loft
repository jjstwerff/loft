// Binary file operations: seek+overwrite, set_size (truncate/extend), incomplete read, size field.
fn cleanup() {
  delete("test_loft_13_a.bin");
  delete("test_loft_13_b.bin");
}

fn main() {
  cleanup();
  // === Seek then overwrite ===
 {f = file("test_loft_13_a.bin");
  f#format = LittleEndian;
  f += 0x11223344;
  f += 0x55667788;
  // Seek back to start and overwrite first int.
  // Use a value that fits in i32 (0xaabbccdd overflows i32).
  f#next = 0;
  f += 0x11111111;
 }
 {f = file("test_loft_13_a.bin");
  f#format = LittleEndian;
  assert(f#read(4) as i32 == 0x11111111, "seek+overwrite first int");
  assert(f#read(4) as i32 == 0x55667788, "second int unchanged");
 }
  assert(delete("test_loft_13_a.bin").ok(), "delete after seek overwrite test");
  // === #size set (truncate / extend) ===
  // Truncate text file to fewer bytes discards tail
 {f = file("test_loft_13_a.bin");
  f += "Hello World";
  f#size = 5;
 }
 {f = file("test_loft_13_a.bin");
  assert(f#read(100) as text == "Hello", "set_size truncates text");
 }
  assert(delete("test_loft_13_a.bin").ok(), "delete after truncate text test");
  // Truncate binary file: write two ints, resize to 4 — only first remains
 {f = file("test_loft_13_a.bin");
  f#format = LittleEndian;
  f += 0x11223344;
  f += 0x55667788;
  f#size = 4;
 }
 {f = file("test_loft_13_a.bin");
  f#format = LittleEndian;
  assert(f#read(4) as i32 == 0x11223344, "set_size truncates binary: first int survives");
 }
  assert(delete("test_loft_13_a.bin").ok(), "delete after truncate binary test");
  // After truncation reported size matches new length
 {f = file("test_loft_13_a.bin");
  f += "Hello World";
  f#size = 5;
 }
 {f = file("test_loft_13_a.bin");
  assert(f#size == 5, "set_size: reported size matches truncated length");
 }
  assert(delete("test_loft_13_a.bin").ok(), "delete after size report test");
  // Extend file: pads with null bytes, size grows
 {f = file("test_loft_13_a.bin");
  f += "Hi";
  f#size = 10;
 }
 {f = file("test_loft_13_a.bin");
  assert(f#size == 10, "set_size extends: size grows to requested length");
 }
  assert(delete("test_loft_13_a.bin").ok(), "delete after extend test");
  // Set size to zero empties the file
 {f = file("test_loft_13_a.bin");
  f += "Hello";
  f#size = 0;
 }
 {f = file("test_loft_13_a.bin");
  assert(f#size == 0, "set_size zero: file is empty");
 }
  assert(delete("test_loft_13_a.bin").ok(), "delete after zero-size test");
  // Negative size is rejected; set_file_size returns Other and file unchanged
 {f = file("test_loft_13_a.bin");
  f += "Hello";
  ok = f.set_file_size(-1);
  assert(!ok.ok(), "set_file_size negative not ok");
 }
 {f = file("test_loft_13_a.bin");
  assert(f#size == 5, "set_file_size negative: file unchanged");
 }
  assert(delete("test_loft_13_a.bin").ok(), "delete after negative-size test");
  // set_file_size on a directory returns IsDirectory
  assert(!file("example").set_file_size(0).ok(), "set_file_size on directory not ok");
  // set_file_size on a nonexistent file returns NotFound
  assert(!file("nonexistent_xyz_set_size.txt").set_file_size(0).ok(), "set_file_size nonexistent not ok");
  // After truncation via #size = 0, a new write reopens and starts from start
 {f = file("test_loft_13_a.bin");
  f += "Hello World";
  f#size = 0;
 }
 {f = file("test_loft_13_a.bin");
  f += "Hi";
 }
 {f = file("test_loft_13_a.bin");
  assert(f#read(100) as text == "Hi", "set_size zero then write: file contains new data");
 }
  assert(delete("test_loft_13_a.bin").ok(), "delete after zero-then-write test");
  // === Incomplete read (fewer bytes than type requires) → #next unchanged ===
 {f = file("test_loft_13_a.bin");
  f#format = LittleEndian;
  f += 42;
 }
 {f = file("test_loft_13_a.bin");
  f#format = LittleEndian;
  f#read(4) as i32;
  // Consume the 4 bytes, then try to read 8 bytes as integer (0 remain)
  f#next = 0;
  f#read(8) as integer;
  assert(f#next == 0, "incomplete typed read: #next unchanged");
 }
  assert(delete("test_loft_13_a.bin").ok(), "delete after incomplete read test");
  // === file().size field reflects written size (via new file() call) ===
 {f = file("test_loft_13_b.bin");
  f#format = LittleEndian;
  f += 42;
 }
  assert(file("test_loft_13_b.bin").size == 4, "file().size reflects 4-byte write");
  assert(delete("test_loft_13_b.bin").ok(), "delete after size-field test");
}
