// File system: format detection, path safety, exists, delete, move, text I/O, files(), lines().

fn cleanup() {
    delete("test_loft_t.txt");
    delete("test_loft_src.txt");
    delete("test_loft_dst.txt");
}

fn main() {
    cleanup();

    // --- file() format detection ---
    assert(file("tests/example").format == Directory, "directory format");
    assert(file("tests/example/show.loft").format == TextFile, "text file format");
    assert(file("nonexistent_xyz.txt").format == NotExists, "nonexistent format");

    // --- Path safety: traversal outside project is rejected ---
    assert(file("../Cargo.toml").format == NotExists, ".. at start rejected");
    assert(file("tests/example/../../../etc").format == NotExists, "net upward rejected");
    assert(file("tests/example/config/../show.loft").format == TextFile, "net-zero traversal ok");

    // --- exists() ---
    assert(exists("tests/example"), "exists: directory");
    assert(exists("tests/example/show.loft"), "exists: file");
    assert(!exists("nonexistent_xyz.txt"), "exists: missing");
    assert(!exists("../Cargo.toml"), "exists: outside project");

    // --- delete() returns false for non-existent ---
    assert(!delete("nonexistent_xyz.txt"), "delete non-existent returns false");
    assert(!delete("../Cargo.toml"), "delete outside project returns false");

    // --- move() edge cases ---
    assert(!move("nonexistent_src_xyz.txt", "dst_xyz.txt"), "move: missing source");
    assert(!move("tests/example/show.loft", "tests/example/map.png"), "move: dst already exists");
    assert(!move("tests/example/show.loft", "../outside.txt"), "move: dst outside project");
    assert(!move("../Cargo.toml", "stolen.toml"), "move: src outside project");

    // === Text file write and read ===

    { f = file("test_loft_t.txt");
      f += "Hello World";
      assert(f#size == 11l, "text write size 11");
      assert(f#index == 0l, "text write #index is start of write");
      assert(f#next == 11l, "text write #next at end");
    }
    assert(exists("test_loft_t.txt"), "text file created");

    { f = file("test_loft_t.txt");
      s = f#read(5) as text;
      assert(s == "Hello", "text read first 5");
      assert(f#index == 0l, "text read #index after first");
      assert(f#next == 5l, "text read #next after first");
      s2 = f#read(6) as text;
      assert(s2 == " World", "text read next 6");
      assert(f#index == 5l, "text read #index after second");
      assert(f#next == 11l, "text read #next after second");
      // Read past EOF returns partial
      f#next = 8l;
      tail = f#read(100) as text;
      assert(tail == "rld", "text read past eof returns partial");
      // Seek back to start
      f#next = 0l;
      again = f#read(5) as text;
      assert(again == "Hello", "text seek and reread");
    }
    assert(delete("test_loft_t.txt"), "delete text file");

    // === move() write-and-move cycle ===

    { f = file("test_loft_src.txt");
      f += "data";
    }
    assert(move("test_loft_src.txt", "test_loft_dst.txt"), "move succeeds");
    assert(!exists("test_loft_src.txt"), "source gone after move");
    assert(exists("test_loft_dst.txt"), "destination exists after move");
    assert(delete("test_loft_dst.txt"), "delete destination");

    // === Seek then overwrite: text file ===

    { f = file("test_loft_t.txt");
      f += "Hello";
      f#next = 0l;
      f += "World";
    }
    { f = file("test_loft_t.txt");
      assert(f#read(5) as text == "World", "text seek overwrite: reads overwritten data");
    }
    assert(delete("test_loft_t.txt"), "delete after text seek overwrite test");

    // === file().files() directory listing ===

    dir_list = file("tests/example").files();
    assert(dir_list[0].path == "tests/example/config", "files() first entry is config dir");
    assert(dir_list[0].format == Directory, "files() first entry format is Directory");
    assert(dir_list[1].format == TextFile, "files() second entry is a text file");

    // === lines() reads text file into vector ===

    c = file("tests/example/config/terrain.txt").lines();
    assert(c[1] == "    terrain = [", "lines()[1] content");
}
