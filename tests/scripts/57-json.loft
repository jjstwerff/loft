// JSON: serialization (:j), parsing (.parse), cast (as), errors, nested structs.

struct JUser { id: integer, name: text, email: text }
struct JScore { val: integer }
struct JInner { x_coord: integer }
struct JOuter { label: text, data: JInner }
struct JItem { tag: text, amount: integer }

fn test_json_serialize() {
  u = JUser { id: 42, name: "Alice", email: "alice@example.com" };
  json = "{u:j}";
  assert(json == `{{"id":42,"name":"Alice","email":"alice@example.com"}}`, "serialize: {json}");
}

fn test_json_parse_object() {
  bob = JUser.parse(`{{"id":7,"name":"Bob","email":"bob@test.org"}}`);
  assert(bob.id == 7, "id: {bob.id}");
  assert(bob.name == "Bob", "name: {bob.name}");
  assert(bob.email == "bob@test.org", "email: {bob.email}");
}

fn test_json_round_trip() {
  u = JUser { id: 1, name: "Carol", email: "c@d.com" };
  u2 = JUser.parse("{u:j}");
  assert(u2.id == 1, "round-trip id");
  assert(u2.name == "Carol", "round-trip name");
}

fn test_json_parse_loft_native() {
  s = JScore.parse(`{{val: 7}}`);
  assert(s.val == 7, "loft-native parse: {s.val}");
}

fn test_json_parse_from_variable() {
  input = `{{"x_coord": 10}}`;
  p = JInner.parse(input);
  assert(p.x_coord == 10, "from var: {p.x_coord}");
}

fn test_json_parse_nested_struct() {
  c = JOuter.parse(`{{"label":"ok","data":{{"x_coord":99}}}}`);
  assert(c.label == "ok", "label: {c.label}");
  assert(c.data.x_coord == 99, "nested: {c.data.x_coord}");
}

fn test_json_parse_missing_field() {
  partial = JUser.parse(`{{"id":1}}`);
  assert(partial.id == 1, "id present");
  assert(!partial.name, "missing name is null");
  assert(!partial.email, "missing email is null");
}

fn test_json_parse_vector() {
  scores = vector<JScore>.parse(`[{{"val":10}},{{"val":20}},{{"val":30}}]`);
  assert(len(scores) == 3, "vector len: {len(scores)}");
  assert(scores[0].val == 10, "scores[0]");
  assert(scores[2].val == 30, "scores[2]");
}

fn test_json_cast_object() {
  jt = `{{"tag": "hello", "amount": 42}}` as JItem;
  assert(jt.tag == "hello", "cast tag: {jt.tag}");
  assert(jt.amount == 42, "cast amount: {jt.amount}");
}

fn test_json_cast_vector() {
  items = `[{{"tag":"a","amount":1}},{{"tag":"b","amount":2}}]` as vector<JItem>;
  assert(len(items) == 2, "cast len: {len(items)}");
  assert(items[0].tag == "a", "cast[0].tag");
  assert(items[1].amount == 2, "cast[1].amount");
}

fn test_json_quoted_field_names() {
  jt = JItem { "tag": "quoted", "amount": 7 };
  assert(jt.tag == "quoted", "quoted: {jt.tag}");
  assert(jt.amount == 7, "quoted amount");
}

fn test_errors_empty_on_success() {
  s = JScore.parse(`{{"val": 42}}`);
  err = s#errors;
  assert(len(err) == 0, "no error expected, got: '{err}'");
  assert(s.val == 42, "val: {s.val}");
}

fn test_errors_on_bad_input() {
  bad = JScore.parse(`not_json`);
  err = bad#errors;
  assert(len(err) > 0, "expected error for bad input");
  assert(bad.val == null, "val should be null");
}

fn test_errors_nested_path() {
  bad = JOuter.parse(`{{"label":"ok","data":"not_an_object"}}`);
  err = bad#errors;
  assert(len(err) > 0, "expected error for nested: {err}");
}
