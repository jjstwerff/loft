// Test for P110: vector push inside for loops.
// Bug: multiple struct field vector pushes in the same loop corrupt data.
// Root cause: growing one vector field reallocates the struct's store,
// invalidating the cached reference to the other vector field.

struct Collector { vals: vector<integer> }
struct Pair { a: vector<integer>, b: vector<integer> }

// Single field push works fine.
fn test_single_field_push() {
  c = Collector { vals: [] };
  for sp in 0..5 {
    c.vals += [sp * 10];
  }
  assert("{c.vals}" == "[0,10,20,30,40]", "single push: {c.vals}");
}

fn test_local_vector_push() {
  lv: vector<integer> = [];
  for vl in 0..5 {
    lv += [vl * 10];
  }
  assert("{lv}" == "[0,10,20,30,40]", "local push: {lv}");
}

// Two field pushes in one loop — THE BUG.
// @EXPECT_FAIL: two struct field vector pushes in one loop
fn test_two_field_push() {
  p = Pair { a: [], b: [] };
  for tp in 0..3 {
    p.a += [tp];
    p.b += [tp * 10];
  }
  assert("{p.a}" == "[0,1,2]", "a: {p.a}");
  assert("{p.b}" == "[0,10,20]", "b: {p.b}");
}

// Workaround: pre-allocate with comprehension, assign by index.
fn test_workaround() {
  p = Pair { a: [for _ in 0..3 { 0 }], b: [for _ in 0..3 { 0 }] };
  for tw in 0..3 {
    p.a[tw] = tw;
    p.b[tw] = tw * 10;
  }
  assert("{p.a}" == "[0,1,2]", "workaround a: {p.a}");
  assert("{p.b}" == "[0,10,20]", "workaround b: {p.b}");
}
