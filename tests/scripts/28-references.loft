// Reference parameters, borrowed refs, field mutation, empty vector args.

// ── Polymorphic methods on enum variants ────────────────────────────────────

enum RShape {
  RCircle { radius: float },
  RRect { width: float, height: float }
}

fn describe(self: RCircle) -> text { "circle r={self.radius}" }
fn describe(self: RRect) -> text { "rect {self.width}x{self.height}" }

fn test_polymorphic_text_method() {
  c = RCircle { radius: 3.0 };
  assert(c.describe() == "circle r=3", "got: {c.describe()}");
}

// ── Vector field append (Issue 5) ───────────────────────────────────────────

struct RBox { items: vector<integer> }

fn test_vec_field_append_bracket_scalar() {
  b = RBox {};
  b.items += [1];
  assert(len(b.items) == 1, "len: {len(b.items)}");
  assert(b.items[0] == 1, "val: {b.items[0]}");
}

fn test_vec_field_append_bracket_multi() {
  b = RBox {};
  b.items += [3, 5];
  assert(len(b.items) == 2, "len: {len(b.items)}");
  assert(b.items[0] == 3, "[0]: {b.items[0]}");
  assert(b.items[1] == 5, "[1]: {b.items[1]}");
}

fn test_vec_field_append_scalar() {
  b = RBox {};
  b.items += 1;
  assert(len(b.items) == 1, "len: {len(b.items)}");
  assert(b.items[0] == 1, "val: {b.items[0]}");
}

// ── Method returns new struct record (Issue 1) ──────────────────────────────

struct RColor { r: integer not null }

fn rdouble(self: RColor) -> RColor { RColor { r: self.r * 2 } }

fn test_method_returns_new_struct() {
  c = RColor { r: 3 };
  d = c.rdouble();
  assert(d.r == 6, "d.r: {d.r}");
}

// ── Borrowed ref inside branch (Issue 2) ────────────────────────────────────

struct RItem { val: integer }

fn test_ref_inside_branch() {
  items = [RItem { val: 10 }, RItem { val: 20 }];
  result = 0;
  if items[0].val > 0 {
    r = items[0];
    result = r.val;
  }
  assert(result == 10, "result: {result}");
}

// ── Ref param field mutation (Issue 4) ──────────────────────────────────────

fn set_first(v: &vector<RItem>, x: integer) { v[0].val = x; }

fn test_ref_param_field_mutation() {
  buf = [RItem { val: 1 }];
  set_first(buf, 42);
  assert(buf[0].val == 42, "buf[0]: {buf[0].val}");
}

// ── Empty vector as mutable arg (Issue 44/L4) ──────────────────────────────

fn sum_vec_r(v: vector<integer>) -> integer {
  r = 0;
  for x in v { r += x; }
  r
}

fn test_empty_vector_arg() {
  result = join([], "-");
  assert(result == "", "join empty");
}

fn test_empty_int_vector_arg() {
  assert(sum_vec_r([]) == 0, "sum empty");
  assert(sum_vec_r([3, 4]) == 7, "sum 3+4");
}

fn pick(prefix: text, parts: vector<text>) -> text {
  result = prefix;
  for p in parts { result += p; }
  result
}

fn test_empty_vector_second_arg() {
  assert(pick("x", []) == "x", "pick empty");
  assert(pick("a", ["b", "c"]) == "abc", "pick abc");
}

// ── Ref param append (Issue 56/L5) ──────────────────────────────────────────

struct RFillItem { name: text, value: integer }

fn rfill(v: &vector<RFillItem>, extra: vector<RFillItem>) { v += extra; }

fn test_ref_param_append() {
  buf = [RFillItem { name: "a", value: 1 }];
  rfill(buf, [RFillItem { name: "b", value: 2 }]);
  assert(len(buf) == 2, "len: {len(buf)}");
  assert(buf[1].value == 2, "buf[1]: {buf[1].value}");
}

fn append_ints(v: &vector<integer>, extra: vector<integer>) { v += extra; }

fn test_ref_param_append_int_vec() {
  nums = [1, 2, 3];
  append_ints(nums, [4, 5]);
  assert(len(nums) == 5, "len: {len(nums)}");
  assert(nums[3] == 4, "nums[3]: {nums[3]}");
}

fn push_one(v: &vector<integer>, x: integer) { v += [x]; }

fn test_ref_param_multiple_appends() {
  nums = [0];
  push_one(nums, 10);
  push_one(nums, 20);
  push_one(nums, 30);
  assert(len(nums) == 4, "len: {len(nums)}");
  assert(nums[1] == 10, "nums[1]: {nums[1]}");
  assert(nums[3] == 30, "nums[3]: {nums[3]}");
}

// L4: passing a named empty vector to `&vector<T>` works correctly.
fn l4_fill_ref(l4v: &vector<integer>) { l4v += [1]; l4v += [2]; l4v += [3]; }

fn test_l4_empty_vec_annotated_as_ref_param() {
  l4_buf: vector<integer> = [];
  l4_fill_ref(l4_buf);
  assert(len(l4_buf) == 3, "L4 annotated: len={len(l4_buf)}");
}

