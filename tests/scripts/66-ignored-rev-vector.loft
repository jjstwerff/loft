// P102/C55: rev() on plain vectors — fixed.

fn test_rev_vector_direct() {
  v = [10, 20, 30, 40, 50];
  result = "";
  for rvd_e in rev(v) {
    if !rvd_e#first {
      result += ",";
    }
    result += "{rvd_e}";
  }
  assert(result == "50,40,30,20,10", "rev(vector): {result}");
}

fn test_rev_vector_empty() {
  v = [for rvd_d in 0..0 { rvd_d }];
  cnt = 0;
  for _ in rev(v) {
    cnt += 1;
  }
  assert(cnt == 0, "rev empty vector");
}

fn test_rev_vector_single() {
  v = [42];
  val = 0;
  for rvd_e in rev(v) {
    val = rvd_e;
  }
  assert(val == 42, "rev single: {val}");
}
