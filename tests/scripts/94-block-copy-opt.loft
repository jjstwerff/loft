// Regression tests for block copy optimizations O-B1 and O-B2.

struct BcPoint {
  x: float not null,
  y: float not null
}

struct BcRect {
  pos: BcPoint,
  size: BcPoint
}

// --- O-B2: Return store adoption (function returns fresh struct) ---

fn bc_make_point(bc_x: float, bc_y: float) -> BcPoint {
  BcPoint { x: bc_x, y: bc_y }
}

fn bc_make_rect(bc_x: float, bc_y: float, bc_w: float, bc_h: float) -> BcRect {
  BcRect { pos: bc_make_point(bc_x, bc_y), size: bc_make_point(bc_w, bc_h) }
}

// O-B2: basic — return from function with no ref params.
fn test_ob2_basic() {
  bc_p = bc_make_point(3.0, 4.0);
  assert(bc_p.x == 3.0, "ob2 basic x: {bc_p.x}");
  assert(bc_p.y == 4.0, "ob2 basic y: {bc_p.y}");
}

// O-B2: nested struct return.
fn test_ob2_nested_return() {
  bc_r = bc_make_rect(1.0, 2.0, 10.0, 20.0);
  assert(bc_r.pos.x == 1.0, "ob2 rect pos.x: {bc_r.pos.x}");
  assert(bc_r.pos.y == 2.0, "ob2 rect pos.y: {bc_r.pos.y}");
  assert(bc_r.size.x == 10.0, "ob2 rect size.x: {bc_r.size.x}");
  assert(bc_r.size.y == 20.0, "ob2 rect size.y: {bc_r.size.y}");
}

// O-B2: mutation after adoption — adopted store must be writable.
fn test_ob2_mutation_after_adopt() {
  bc_p = bc_make_point(1.0, 2.0);
  bc_p.x = 99.0;
  bc_p.y = 88.0;
  assert(bc_p.x == 99.0, "ob2 mutate x: {bc_p.x}");
  assert(bc_p.y == 88.0, "ob2 mutate y: {bc_p.y}");
}

// O-B2 safety: aliased return test is in 34-alias-copy.loft (separate
// file because native codegen doesn't have the deep-copy fix yet).

// --- O-B1: Last-use move (x = y where y dies) ---

fn test_ob1_last_use_move() {
  bc_temp = bc_make_point(5.0, 6.0);
  bc_result = bc_temp;
  // bc_temp is never used again — move should fire.
  assert(bc_result.x == 5.0, "ob1 move x: {bc_result.x}");
  assert(bc_result.y == 6.0, "ob1 move y: {bc_result.y}");
}

fn test_ob1_multi_use_copies() {
  bc_src = bc_make_point(1.0, 2.0);
  bc_a = bc_src;
  bc_b = bc_src;
  // bc_src is used twice — copy must happen, not move.
  bc_a.x = 10.0;
  bc_b.x = 20.0;
  assert(bc_src.x == 1.0, "ob1 multi src.x: {bc_src.x}");
  assert(bc_a.x == 10.0, "ob1 multi a.x: {bc_a.x}");
  assert(bc_b.x == 20.0, "ob1 multi b.x: {bc_b.x}");
}

// Combined: function return + last-use move chain.
fn test_ob1_ob2_chain() {
  bc_temp = bc_make_rect(0.0, 0.0, 100.0, 200.0);
  bc_final = bc_temp;
  assert(bc_final.size.x == 100.0, "chain size.x: {bc_final.size.x}");
  assert(bc_final.size.y == 200.0, "chain size.y: {bc_final.size.y}");
}
