// Dead assignment detection and suppression.

// @EXPECT_WARNING: Dead assignment
fn test_basic() {
  x = 1;
  x = 2;
  assert(x == 2, "x");
}

fn test_read_between() {
  x = 1;
  assert(x == 1, "x");
  x = 2;
  assert(x == 2, "x");
}

fn test_underscore_exempt() {
  _x = 1;
  _x = 2;
  assert(_x == 2, "x");
}

fn test_augmented_not_dead() {
  x = 1;
  x += 2;
  assert(x == 3, "x");
}

fn test_branch_not_dead() {
  result = 0;
  if true { result = 42; }
  assert(result == 42, "result");
}

fn test_sibling_branches() {
  x = 0;
  if true { x = 1; } else { x = 2; }
  assert(x > 0, "x");
}

enum DAState { DAStart, DAOngoing, DAHalt }

fn da_step(s: DAState) -> DAState {
  if s == DAStart { s = DAOngoing; } else { s = DAHalt; }
  s
}

fn test_param_branch() {
  assert(da_step(DAStart) == DAOngoing, "step");
}

fn test_loop_init() {
  sum = 0;
  for i in 1..4 { sum = sum + i; }
  assert(sum == 6, "sum");
}

enum DAColor { DARed, DAGreen, DABlue }

fn da_label(c: DAColor) -> integer {
  result = 0;
  match c {
    DARed => result = 1,
    DAGreen => result = 2,
    DABlue => result = 3
  }
  result
}

fn test_match_arms() {
  assert(da_label(DARed) == 1, "red");
}
