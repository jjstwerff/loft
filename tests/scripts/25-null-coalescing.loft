// Null coalescing operator ?? and null handling.

fn test_integer_non_null() {
  x = 42;
  r = x ?? 0;
  assert(r == 42, "r: {r}");
}

fn test_integer_null() {
  x = null;
  r = x ?? 99;
  assert(r == 99, "r: {r}");
}

struct NRow { val: integer }

fn test_field_non_null() {
  r = NRow { val: 7 };
  result = r.val ?? 0;
  assert(result == 7, "result: {result}");
}

fn test_chain_first_non_null() {
  a = 1;
  b = 2;
  c = 3;
  r = a ?? b ?? c;
  assert(r == 1, "r: {r}");
}

fn test_chain_last_non_null() {
  a = null;
  b = null;
  c = 3;
  r = a ?? b ?? c;
  assert(r == 3, "r: {r}");
}

fn test_null_add() {
  r = 1 + null;
  assert(!r, "1+null is null");
}

fn test_zero_divide() {
  r = 2 / (3 - 2 - 1);
  assert(!r, "div by zero is null");
}

fn add_null(a: integer, b: integer) -> integer { a + b }

fn test_call_with_null() {
  r = add_null(1, null);
  assert(!r, "call with null is null");
}

fn text_or_null(a: integer) -> text {
  if a > 2 { return null }
  "#{a}#"
}

fn test_call_text_null() {
  r = text_or_null(5);
  assert(!r, "text null");
}

fn int_or_null(a: integer) -> integer {
  if a > 2 { return null }
  a + 1
}

fn test_call_int_null() {
  r = int_or_null(5);
  assert(!r, "int null");
}

fn test_if_typing() {
  a = "12";
  r = if a.len() > 2 { null } else { "error" };
  assert(r == "error", "if typing non-null");
  r2 = if a.len() == 2 { null } else { "error" };
  assert(!r2, "if typing null");
}

struct NNCounter { count: integer not null }

// @EXPECT_WARNING: Redundant null check
fn test_redundant_null_eq() {
  c = NNCounter { count: 0 };
  if c.count == null { assert(false, "unreachable"); }
}

// @EXPECT_WARNING: Redundant null check
fn test_redundant_null_ne() {
  c = NNCounter { count: 0 };
  assert(c.count != null, "always true");
}

// @EXPECT_WARNING: Redundant null coalescing
fn test_redundant_coalesce() {
  c = NNCounter { count: 0 };
  r = c.count ?? 99;
  assert(r == 0, "r: {r}");
}

struct NItem { value: integer }

fn test_no_warning_nullable_null_check() {
  it = NItem {};
  if it.value == null {
    assert(true, "ok");
  }
}

fn test_no_warning_nullable_coalesce() {
  it = NItem {};
  r = it.value ?? 42;
  assert(r == 0, "r: {r}");
}
