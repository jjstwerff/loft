//
// Store-leak smoke tests — transcribed from `tests/leak.rs`.
//
// The Rust tests in leak.rs assert `check_leaks()` after each run to
// confirm no Store records are orphaned.  The script runner does not
// expose `check_leaks` as a loft API, so these functions cannot assert
// leak counts directly.  They earn their keep by running under
// `cargo run --release` AND under debug builds: any store leak in a
// transcribed pattern trips the interpreter's end-of-program
// assertions in debug mode.
//
// Keep this file as a permanent regression surface: when a new leak
// pattern is discovered and fixed in `tests/leak.rs`, mirror the
// minimal reproducer here so the pattern stays exercised by the
// general test suite.

struct SlSf { sl_v: vector<float> }

fn sl_inner(sl_a: const SlSf, sl_b: const SlSf) -> SlSf {
  sl_r = SlSf { sl_v: [sl_a.sl_v[0] + sl_b.sl_v[0]] };
  sl_r
}

fn sl_wrap(sl_x: const SlSf) -> SlSf {
  sl_y = SlSf { sl_v: [1.0] };
  sl_inner(sl_x, sl_y)
}

// P105 class of leak: `r = S {...}; r` in the return path of a helper,
// chained through an outer wrapper, with const-vector struct params.
// The original bug dropped a store ref on the return; the fix lives in
// `scopes.rs::get_free_vars`.
fn test_local_var_return_leak() {
  sl_p = SlSf { sl_v: [2.0] };
  sl_q = sl_wrap(sl_p);
  assert(sl_q.sl_v[0] == 3.0, "sl_q.sl_v[0]={sl_q.sl_v[0]}");
}

fn sl_mul_inner(sl_ma: const SlSf, sl_mb: const SlSf) -> SlSf {
  sl_mr = SlSf { sl_v: [sl_ma.sl_v[0] * sl_mb.sl_v[0]] };
  sl_mr
}

fn sl_mul_wrap(sl_proj: const SlSf, sl_bx: float) -> SlSf {
  sl_model = SlSf { sl_v: [sl_bx] };
  sl_mul_inner(sl_proj, sl_model)
}

// GL-style repeated reassignment of a ref-returning call in a loop —
// the pattern that surfaced P122 (per-frame store growth in game loops).
// Each iteration must release the previous `mvp` store before binding
// the new one.
fn test_reassign_ref_call_in_loop() {
  sl_proj = SlSf { sl_v: [2.0] };
  sl_mvp = sl_mul_wrap(sl_proj, 1.0);
  assert(sl_mvp.sl_v[0] == 2.0, "first: {sl_mvp.sl_v[0]}");
  sl_mvp = sl_mul_wrap(sl_proj, 3.0);
  assert(sl_mvp.sl_v[0] == 6.0, "second: {sl_mvp.sl_v[0]}");
  sl_mvp = sl_mul_wrap(sl_proj, 5.0);
  assert(sl_mvp.sl_v[0] == 10.0, "third: {sl_mvp.sl_v[0]}");
  assert(sl_proj.sl_v[0] == 2.0, "sl_proj untouched: {sl_proj.sl_v[0]}");
}

// Control: identical structure but with the helper returning the
// struct literal directly — no intermediate `r = ...; r`.  Passing in
// the leak-sensitive pattern above and failing here would mean a
// regression in the baseline return path.
fn sl_direct_inner(sl_da: const SlSf, sl_db: const SlSf) -> SlSf {
  SlSf { sl_v: [sl_da.sl_v[0] + sl_db.sl_v[0]] }
}

fn sl_direct_wrap(sl_dx: const SlSf) -> SlSf {
  sl_dy = SlSf { sl_v: [1.0] };
  sl_direct_inner(sl_dx, sl_dy)
}

fn test_direct_return_no_leak() {
  sl_p = SlSf { sl_v: [2.0] };
  sl_q = sl_direct_wrap(sl_p);
  assert(sl_q.sl_v[0] == 3.0, "sl_q.sl_v[0]={sl_q.sl_v[0]}");
}

// Shifted var_nr variant: two unrelated locals before the `result = ...; result`
// return change the variable numbering and previously caused an off-by-one
// in the free-set calculation.
fn sl_sh_inner(sl_sha: const SlSf, sl_shb: const SlSf) -> SlSf {
  sl_shr = SlSf { sl_v: [sl_sha.sl_v[0] + sl_shb.sl_v[0]] };
  sl_shr
}

fn sl_sh_wrap(sl_shx: const SlSf) -> SlSf {
  sl_sh_dummy1 = 42;
  sl_sh_dummy2 = 99;
  sl_shy = SlSf { sl_v: [1.0] };
  sl_sh_result = sl_sh_inner(sl_shx, sl_shy);
  assert(sl_sh_dummy1 == 42, "sl_sh_dummy1");
  assert(sl_sh_dummy2 == 99, "sl_sh_dummy2");
  sl_sh_result
}

fn test_shifted_var_nr_return() {
  sl_sh_p = SlSf { sl_v: [2.0] };
  sl_sh_q = sl_sh_wrap(sl_sh_p);
  assert(sl_sh_q.sl_v[0] == 3.0, "sl_sh_q.sl_v[0]={sl_sh_q.sl_v[0]}");
}

// Deep chain: 3-level call stack where every intermediate creates its
// own ref-holding local.  Each level's store must be freed as control
// returns up the chain.
fn sl_dc_inner(sl_dca: const SlSf, sl_dcb: const SlSf) -> SlSf {
  sl_dcr = SlSf { sl_v: [sl_dca.sl_v[0] + sl_dcb.sl_v[0]] };
  sl_dcr
}

fn sl_dc_middle(sl_dcx: const SlSf) -> SlSf {
  sl_dcy = SlSf { sl_v: [10.0] };
  sl_dc_inner(sl_dcx, sl_dcy)
}

fn sl_dc_outer(sl_dcox: const SlSf) -> SlSf {
  sl_dcz = SlSf { sl_v: [sl_dcox.sl_v[0] + 100.0] };
  sl_dc_middle(sl_dcz)
}

fn test_deep_chain_return() {
  sl_dc_p = SlSf { sl_v: [1.0] };
  sl_dc_q = sl_dc_outer(sl_dc_p);
  assert(sl_dc_q.sl_v[0] == 111.0, "sl_dc_q.sl_v[0]={sl_dc_q.sl_v[0]}");
}
