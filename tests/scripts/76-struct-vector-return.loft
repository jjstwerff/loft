// P104 FIXED: test runner now filters library functions
// P105 FIXED: nested struct field access on vector elements
// P106 FIXED: same root cause as P105 — OpGetField now emitted for inline fields
// C54 FIXED: ** operator mapped to pow()

struct SvMat {
  vals: vector<float>
}

// P104: direct return works now
fn svr_identity() -> SvMat {
  SvMat { vals: [1.0, 0.0, 0.0, 1.0] }
}

fn test_p104_direct_return() {
  svr_m = svr_identity();
  assert(svr_m.vals.len() == 4, "has 4 elements");
  assert(svr_m.vals[0] == 1.0, "first is 1.0");
  assert(svr_m.vals[3] == 1.0, "last is 1.0");
}

// P105 FIXED: nested struct field access on vector elements
struct SvInner {
  ix: float not null,
  iy: float not null
}

struct SvOuter {
  items: vector<SvInner>
}

fn test_p105_inline_struct_in_vector() {
  svo = SvOuter { };
  svo.items += [SvInner { ix: 3.0, iy: 4.0 }];
  assert(svo.items.len() == 1, "one item added");
  assert(svo.items[0].ix == 3.0, "nested field ix");
  assert(svo.items[0].iy == 4.0, "nested field iy");
}

// P105: deeper nesting — struct containing struct in vector
struct SvP2 { x: float not null, y: float not null }
struct SvSeg { start: SvP2, end_p: SvP2 }
struct SvSegList { segs: vector<SvSeg> }

fn test_p105_nested_struct_in_vector() {
  sl = SvSegList {};
  sl.segs += [SvSeg { start: SvP2 { x: 1.0, y: 2.0 }, end_p: SvP2 { x: 3.0, y: 4.0 } }];
  assert(sl.segs[0].start.x == 1.0, "start.x");
  assert(sl.segs[0].start.y == 2.0, "start.y");
  assert(sl.segs[0].end_p.x == 3.0, "end_p.x");
  assert(sl.segs[0].end_p.y == 4.0, "end_p.y");
}

// P106 FIXED: nested vector in vector element
struct SvV2Inner { vals: vector<float> }
struct SvV2Outer { name: text, inner: SvV2Inner }
struct SvV2Top { items: vector<SvV2Outer> }

fn test_p106_nested_vector_in_vector_element() {
  t = SvV2Top {};
  o = SvV2Outer { name: "x", inner: SvV2Inner { vals: [1.0, 2.0] } };
  t.items += [o];
  assert(t.items.len() == 1, "one item");
  assert(t.items[0].name == "x", "name preserved");
  assert(t.items[0].inner.vals.len() == 2, "nested vec len preserved");
}

// C54: ** operator works
fn test_c54_exponentiation() {
  sv_val = 25.0;
  sv_root = sv_val ** 0.5;
  assert(sv_root == 5.0, "sqrt of 25 via **");
}
