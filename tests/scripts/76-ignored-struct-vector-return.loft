// P104 FIXED: test runner now filters library functions
// P105: Nested struct field access on vector elements (open — needs deeper fix)
// C54 FIXED: ** operator mapped to pow()

struct SvMat {
  vals: vector<float>
}

// P104: direct return works now
fn svr_identity() -> SvMat {
  SvMat { vals: [1.0, 0.0, 0.0, 1.0] }
}

fn test_p104_direct_return() {
  svr_m = svr_identity();
  assert(svr_m.vals.len() == 4, "has 4 elements");
  assert(svr_m.vals[0] == 1.0, "first is 1.0");
  assert(svr_m.vals[3] == 1.0, "last is 1.0");
}

// P105 workaround: avoid deep chained access on vector elements
struct SvInner {
  ix: float not null,
  iy: float not null
}

struct SvOuter {
  items: vector<SvInner>
}

fn test_p105_workaround() {
  svo = SvOuter { };
  svo.items += [SvInner { ix: 3.0, iy: 4.0 }];
  assert(svo.items.len() == 1, "one item added");
  // P105: svo.items[0].ix still crashes — needs deeper fix
}

// C54: ** operator works
fn test_c54_exponentiation() {
  sv_val = 25.0;
  sv_root = sv_val ** 0.5;
  assert(sv_root == 5.0, "sqrt of 25 via **");
}
