// Character and text index operations: char+char, text[i]+text[j], void lambda.

fn test_char_plus_char() {
  c = 'h';
  d = 'i';
  r = c + d;
  assert(r == "hi", "char+char: '{r}'");
}

fn test_text_index_plus_text_index() {
  a = "hello";
  r = a[0] + a[1];
  assert(r == "he", "text idx+idx: '{r}'");
}

fn test_lambda_void_body() {
  count = 0;
  f = fn(ct_x: integer) { count += ct_x; };
  f(10);
  f(32);
  assert(count == 42, "void lambda: {count}");
}
