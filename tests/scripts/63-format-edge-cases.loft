// Format edge cases: hex, binary, octal with padding, float precision,
// alignment, and sign — coverage for state/text.rs formatting paths.

fn test_hex_formatting() {
  assert("{255:#x}" == "0xff", "hex with prefix");
  assert("{255:04x}" == "00ff", "hex zero-padded 4");
  assert("{255:08x}" == "000000ff", "hex zero-padded 8");
  assert("{0:04x}" == "0000", "hex zero is 0000");
  assert("{4096:#x}" == "0x1000", "hex 4096");
}

fn test_binary_formatting() {
  assert("{10:b}" == "1010", "binary 10");
  assert("{255:b}" == "11111111", "binary 255");
  assert("{0:b}" == "0", "binary 0");
  assert("{1:b}" == "1", "binary 1");
}

fn test_octal_formatting() {
  assert("{8:o}" == "10", "octal 8");
  assert("{255:o}" == "377", "octal 255");
  assert("{0:o}" == "0", "octal 0");
}

fn test_float_precision() {
  assert("{3.14159:.1}" == "3.1", "float 1 decimal");
  assert("{3.14159:.5}" == "3.14159", "float 5 decimals");
  assert("{0.0:.2}" == "0.00", "float zero with precision");
  assert("{-1.5:.1}" == "-1.5", "negative float precision");
}

fn test_float_width_precision() {
  assert("{3.14:8.2}" == "    3.14", "float width 8 prec 2");
  assert("{-3.14:8.2}" == "   -3.14", "neg float width 8 prec 2");
  assert("{100.0:8.1}" == "   100.0", "float width 8 prec 1");
}

fn test_integer_alignment() {
  assert("{42:>6}" == "    42", "right-align width 6");
  assert("{-7:>5}" == "   -7", "right-align negative");
  assert("{42:6}" == "    42", "default width 6");
}

fn test_zero_padding() {
  assert("{7:03}" == "007", "zero-pad 3 digits");
  assert("{42:05}" == "00042", "zero-pad 5 digits");
  assert("{0:03}" == "000", "zero-pad zero");
}

fn test_signed_format() {
  assert("{42:+}" == "+42", "explicit positive sign");
  assert("{-42:+}" == "-42", "explicit negative sign");
  assert("{0:+}" == "+0", "explicit sign on zero");
}

fn test_long_formatting() {
  fln_n = 1000000;
  assert("{fln_n}" == "1000000", "long default");
  assert("{fln_n:>10}" == "   1000000", "long right-aligned");
}

fn test_char_and_bool_formatting() {
  fcb_c = 'A';
  assert("{fcb_c}" == "A", "char format default");
  assert("{true}" == "true", "bool true");
  assert("{false}" == "false", "bool false");
  assert("{true:^7}" == " true  ", "bool centered");
}

fn test_expression_in_format() {
  fex_x = 10;
  fex_y = 20;
  assert("{fex_x + fex_y}" == "30", "expression in format");
  assert("{fex_x * fex_y:05}" == "00200", "expression with format spec");
}

fn test_multiple_specs() {
  assert("{1:03}-{2:03}-{3:03}" == "001-002-003", "multiple format specs");
}
