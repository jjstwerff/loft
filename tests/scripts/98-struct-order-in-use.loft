// Regression test: struct field types must resolve correctly in use-loaded
// files regardless of definition order. Previously, structs defined before
// function bodies with `return null` had their field types reset to unknown(0).

pub struct Alpha {
  value: integer
}

pub struct Beta {
  name: text,
  count: integer
}

fn get_num() -> integer;
#native "n_ticks"

// Function with return null — this previously corrupted struct field types
pub fn make_alpha(x: integer) -> Alpha {
  if x < 0 { return null; }
  Alpha { value: x }
}

// Second struct construction after a function with return null
pub fn make_beta(n: text, c: integer) -> Beta {
  if c < 0 { return null; }
  Beta { name: n, count: c }
}

// Nested: struct construction using result of another function
pub fn make_pair() -> Beta {
  a = make_alpha(10);
  if !a { return null; }
  Beta { name: "test", count: a.value }
}

fn main() {
  // Basic construction
  a = make_alpha(42);
  assert(a.value == 42, "alpha value={a.value}");

  // Null path
  a2 = make_alpha(-1);
  assert(!a2, "alpha null");

  // Second struct
  b = make_beta("hello", 5);
  assert(b.name == "hello", "beta name={b.name}");
  assert(b.count == 5, "beta count={b.count}");

  // Nested
  p = make_pair();
  assert(p.name == "test", "pair name={p.name}");
  assert(p.count == 10, "pair count={p.count}");
}
