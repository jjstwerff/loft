// Test return null from functions of every nullable return type.
// Exercises native codegen: return null must emit the correct null sentinel.

fn maybe_int(x: integer) -> integer {
  if x < 0 { return null; }
  x * 2
}

fn maybe_long(x: integer) -> integer {
  if x < 0 { return null; }
  x as integer * 1000000
}

fn maybe_float(x: integer) -> float {
  if x < 0 { return null; }
  x as float * 1.5
}

fn maybe_text(x: integer) -> text {
  if x < 0 { return null; }
  "value={x}"
}

// return null from if-expression (C16 + null sentinel)
fn if_expr_null(x: integer) -> integer {
  val = if x > 0 { x * 10 } else { return null; };
  val + 1
}

fn if_expr_null_true(x: integer) -> integer {
  val = if x < 0 { return null; } else { x * 10 };
  val + 1
}

// chained early returns
fn clamp_or_null(x: integer, lo: integer, hi: integer) -> integer {
  if x < lo { return null; }
  if x > hi { return null; }
  x
}

// multiple return paths
fn classify(x: integer) -> text {
  if x < 0 { return "negative"; }
  if x == 0 { return "zero"; }
  "positive"
}

fn main() {
  // integer
  assert(maybe_int(5) == 10, "int non-null: {maybe_int(5)}");
  assert(!maybe_int(-1), "int null");

  // long
  assert(maybe_long(3) == 3000000, "long non-null: {maybe_long(3)}");
  assert(!maybe_long(-1), "long null");

  // float
  assert(maybe_float(4) == 6.0, "float non-null: {maybe_float(4)}");
  assert(!maybe_float(-1), "float null");

  // text
  assert(maybe_text(7) == "value=7", "text non-null");
  assert(!maybe_text(-1), "text null");

  // if-expression with return null (C16)
  assert(if_expr_null(5) == 51, "if-expr non-null: {if_expr_null(5)}");
  assert(!if_expr_null(-1), "if-expr null");
  assert(if_expr_null_true(5) == 51, "if-expr-true non-null: {if_expr_null_true(5)}");
  assert(!if_expr_null_true(-1), "if-expr-true null");

  // chained returns
  assert(clamp_or_null(5, 1, 10) == 5, "clamp ok");
  assert(!clamp_or_null(-5, 1, 10), "clamp low null");
  assert(!clamp_or_null(15, 1, 10), "clamp high null");

  // multiple text returns
  assert(classify(-3) == "negative", "classify neg");
  assert(classify(0) == "zero", "classify zero");
  assert(classify(7) == "positive", "classify pos");

  // return false from boolean function (not null — this is valid)
  assert(!check_neg(-1), "bool return false");
  assert(check_neg(1), "bool return true");
}

fn check_neg(x: integer) -> boolean {
  if x < 0 { return false; }
  true
}
