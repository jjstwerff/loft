// Float and single arithmetic, math functions, null, and conversions.
fn main() {
  // --- Arithmetic (f64) ---
  assert(1.5 + 0.5 == 2.0, "float add");
  assert(3.0 - 1.5 == 1.5, "float sub");
  assert(2.0 * 1.5 == 3.0, "float mul");
  assert(3.0 / 2.0 == 1.5, "float div");
  // --- Single (f32) ---
  x = 0.1f + 2 * 1.0f;
  assert(x == 2.1f, "single add");
  // --- Abs ---
  assert(abs(-2.5) == 2.5, "float abs negative");
  assert(abs(2.5) == 2.5, "float abs positive");
  // --- Round / ceil / floor ---
  assert(round(2.6) == 3.0, "round up");
  assert(round(2.4) == 2.0, "round down");
  assert(round(2.5) == 3.0, "round half up");
  assert(ceil(2.1) == 3.0, "ceil");
  assert(ceil(2.0) == 2.0, "ceil exact");
  assert(floor(2.9) == 2.0, "floor");
  assert(floor(2.0) == 2.0, "floor exact");
  // --- Pow / log ---
  assert(pow(2.0, 3.0) == 8.0, "pow 2^3");
  assert(pow(4.0, 0.5) == 2.0, "pow sqrt via pow");
  assert(log(pow(4.0, 5.0), 2.0) == 10.0, "log2 of 4^5");
  // --- Trig ---
  assert(ceil(sin(PI) + cos(PI) * 1000.0) == -1000.0, "sin and cos of PI");
  // --- PI constant ---
  assert(round(PI * 1000.0) == 3142.0, "PI rounded");
  // --- Null (NaN) ---
  n = 0.0;
  // 0.0 / 0.0 produces NaN which is null for float
  bad = n / n;
  assert(!bad, "float nan is null");
  // Null float comparisons: null is not equal to anything, not even itself.
  assert(!(bad == bad), "null == null is false");
  assert(bad != bad, "null != null is true");
  assert(bad != 0.0, "null != 0.0 is true");
  assert(!(bad == 0.0), "null == 0.0 is false");
  assert(!(bad < 0.0), "null < 0.0 is false");
  assert(!(bad <= 0.0), "null <= 0.0 is false");
  // Null-coalescing works correctly on floats:
  assert((bad ?? 99.0) == 99.0, "null ?? default returns default");
  // --- Comparisons ---
  assert(1.0 < 2.0, "float lt");
  assert(2.0 <= 2.0, "float le");
  assert(3.0 > 2.0, "float gt");
  assert(3.0 >= 3.0, "float ge");
  // --- Conversions ---
  assert(3 as float == 3.0, "int to float");
  assert("1.5" as float == 1.5, "text to float");
  assert("{1.5}" == "1.5", "float to text");
  assert(3.0 as integer == 3, "float to int truncates");
  assert(3l as float == 3.0, "long to float");
  // --- Negative floor, ceil, round ---
  assert(floor(-2.1) == -3.0, "floor of negative");
  assert(floor(-2.0) == -2.0, "floor of exact negative");
  assert(ceil(-2.9) == -2.0, "ceil of negative");
  assert(ceil(-3.0) == -3.0, "ceil of exact negative");
  assert(round(-2.6) == -3.0, "round negative down");
  assert(round(-2.4) == -2.0, "round negative up");
  // --- Truncation direction for negative float-to-int ---
  assert(-3.9 as integer == -3, "negative float truncates toward zero");
  assert(-0.9 as integer == 0, "near-zero negative float truncates to 0");
  assert(-3.0 as integer == -3, "exact negative float to int");
  // --- log edge cases ---
  assert(log(1.0, 10.0) == 0.0, "log(1, base) == 0 for any base");
  assert(log(10.0, 10.0) == 1.0, "log(base, base) == 1");
  // --- abs of zero ---
  assert(abs(0.0) == 0.0, "float abs zero");
  assert(abs(-0.0) == 0.0, "float abs negative zero");
  // --- Null (NaN) propagation ---
  bad = 0.0 / 0.0;
  assert(!(bad + 1.0), "nan + float is null");
  assert(!(bad * 2.0), "nan * float is null");
  assert(!(1.0 + bad), "float + nan is null");
  // --- Math domain boundaries: out-of-domain inputs produce NaN (null) ---
  assert(!sqrt(-1.0), "sqrt of negative is null");
  assert(!asin(2.0), "asin out of [-1,1] is null");
  assert(!acos(-2.0), "acos out of [-1,1] is null");
  assert(!pow(-1.0, 0.5), "pow(-1, 0.5) is null (complex result)");
  assert(!log(-1.0, 10.0), "log of negative base is null");
  // --- Log(0) is negative infinity (not null) ---
  log_zero = log(0.0, 10.0);
  assert(log_zero < -1000000.0, "log(0, base) is negative infinity");
  // --- Division producing positive infinity (not null) ---
  pos_inf = 1.0 / 0.0;
  assert(pos_inf > 1000000.0, "1.0/0.0 is positive infinity");
  // --- Special power cases ---
  assert(pow(0.0, 0.0) == 1.0, "0^0 == 1 by convention");
  assert(pow(2.0, 0.0) == 1.0, "x^0 == 1");
  assert(pow(0.0, 2.0) == 0.0, "0^n == 0 for n>0");
  // --- Trig inverse: asin, acos, atan ---
  assert(round(asin(1.0) * 10000.0) == round(PI / 2.0 * 10000.0), "asin(1) == PI/2");
  assert(acos(1.0) == 0.0, "acos(1) == 0");
  assert(round(atan(1.0) * 10000.0) == round(PI / 4.0 * 10000.0), "atan(1) == PI/4");
  assert(round(atan2(1.0, 1.0) * 10000.0) == round(PI / 4.0 * 10000.0), "atan2(1,1) == PI/4");
  // --- tan ---
  assert(round(tan(PI / 4.0) * 10000.0) == 10000.0, "tan(PI/4) == 1");
  // --- sqrt ---
  assert(sqrt(9.0) == 3.0, "sqrt(9) == 3");
  assert(sqrt(0.0) == 0.0, "sqrt(0) == 0");
  // --- Float comparison epsilon boundary (tolerance = 1e-9) ---
  assert(1.0 + 0.0000000005 == 1.0, "within float epsilon (5e-10): equal");
  assert(1.0 + 0.0000000015 != 1.0, "outside float epsilon (1.5e-9): not equal");
  // --- Single (f32) domain boundaries ---
  assert(!sqrt(-1.0f), "single sqrt of negative is null");
  assert(!asin(2.0f), "single asin out of domain is null");
  assert(!acos(-2.0f), "single acos out of domain is null");
  assert(!pow(-1.0f, 0.5f), "single pow(-1, 0.5) is null");
  // --- Single arithmetic ---
  assert(sin(0.0f) == 0.0f, "single sin(0) == 0");
  assert(cos(0.0f) == 1.0f, "single cos(0) == 1");
  assert(tan(0.0f) == 0.0f, "single tan(0) == 0");
  assert(pow(2.0f, 3.0f) == 8.0f, "single pow(2,3) == 8");
  assert(abs(-3.5f) == 3.5f, "single abs(-3.5) == 3.5");
  assert(sqrt(4.0f) == 2.0f, "single sqrt(4) == 2");
  assert(round(asin(1.0f) * 1000.0f) == round(PI as single / 2.0f * 1000.0f), "single asin(1) == PI/2");
  assert(acos(1.0f) == 0.0f, "single acos(1) == 0");
  // --- Single comparison epsilon boundary (tolerance = 1e-6) ---
  assert(1.0f + 0.0000005f == 1.0f, "within single epsilon (5e-7): equal");
  assert(1.0f + 0.0000015f != 1.0f, "outside single epsilon (1.5e-6): not equal");
  // --- Float-to-int cast edge cases ---
  nan_val = sqrt(-1.0);
  assert(!(nan_val as integer), "NaN as integer is null");
  assert(!(nan_val as long), "NaN as long is null");
  inf_pos = 1.0 / 0.0;
  assert(inf_pos as integer == 2147483647, "positive infinity as integer saturates to i32::MAX");
  inf_neg = -1.0 / 0.0;
  assert(!(inf_neg as integer), "negative infinity as integer is null (i32::MIN)");
  assert(!(inf_neg as long), "negative infinity as long is null (i64::MIN)");
  assert(inf_pos as long > 1000000000l, "positive infinity as long saturates");
  // --- Float infinity arithmetic (IEEE 754) ---
  assert(inf_pos + inf_pos > 1000000.0, "inf + inf is positive infinity");
  assert(!(inf_pos - inf_pos), "inf - inf is NaN (null)");
  assert(!(inf_pos * 0.0), "inf * 0.0 is NaN (null)");
  // --- NaN comparisons return false (not null) ---
  nan_cmp = 0.0 / 0.0;
  assert(!(nan_cmp < 0.0), "nan < 0.0 is false");
  assert(!(0.0 < nan_cmp), "0.0 < nan is false");
  assert(!(nan_cmp <= nan_cmp), "nan <= nan is false");
  // --- Truncation toward zero (not floor) ---
  assert((-3.9) as integer == -3, "(-3.9) as integer truncates toward zero");
  assert(3.9 as integer == 3, "3.9 as integer truncates toward zero");
}
