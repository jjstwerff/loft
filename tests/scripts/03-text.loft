// Text: concatenation, length, indexing, slicing, UTF-8, iteration, search.
fn main() {
  // --- Concatenation ---
  assert("hello" + " world" == "hello world", "text concat");
  assert("" + "x" == "x", "concat with empty");
  // --- Length (byte count) ---
  assert(len("hello") == 5, "len ascii");
  assert(len("😃") == 4, "len emoji 4 bytes");
  assert(len("♥") == 3, "len heart 3 bytes");
  assert(len("") == 0, "len empty");
  // --- Character indexing ---
  s = "ABCDE";
  assert(s[0] == 'A', "char at 0");
  assert(s[2] == 'C', "char at 2");
  assert(s[4] == 'E', "char at 4");
  // --- Byte slicing ---
  assert(s[1..4] == "BCD", "slice 1..4");
  assert(s[3..] == "DE", "open slice 3..");
  assert(s[0..2] == "AB", "explicit start slice");
  assert(s[..2] == "AB", "open-start slice");
  // --- UTF-8 slicing ---
  txt = "12😊🙃45";
  assert(txt[2..- 1] == "😊🙃4", "utf8 slice 2..-1");
  assert(txt[1..7] == "2😊🙃", "utf8 slice 1..7");
  // --- UTF-8 character iteration with #index and #next ---
  // "123😊🙃😋8": '1'@0,'2'@1,'3'@2,'😊'@3..7,'🙃'@7..11,'😋'@11..15,'8'@15..16
  chars =[];
  idxs =[];
  nxts =[];
  for c in "123😊🙃😋8" {
    chars +=[c];
    idxs +=[c#index];
    nxts +=[c#next];
  }
  assert("{chars}" == "['1','2','3','😊','🙃','😋','8']", "text iter chars");
  assert("{idxs}" == "[0,1,2,3,7,11,15]", "text iter #index values");
  assert("{nxts}" == "[1,2,3,7,11,15,16]", "text iter #next values");
  // --- #index filter during iteration ---
  result = "";
  for c in "Hi 😊!" {
    if c#index >= 3 {
      result += c;
    }
  }
  assert(result == "😊!", "text iter filter by #index");
  // --- Search functions ---
  assert("something".starts_with("some"), "starts_with");
  assert(!"something".starts_with("else"), "starts_with false");
  assert("something".ends_with("thing"), "ends_with");
  assert(!"something".ends_with("none"), "ends_with false");
  assert("something".find("th") == 4, "find returns byte offset");
  assert("something".find("xyz") == null, "find missing is null");
  assert("a longer text".contains("longer"), "contains true");
  assert(!"abc".contains("xyz"), "contains false");
  // --- Trim ---
  assert(trim("  hello  ") == "hello", "trim both sides");
  assert(trim("no spaces") == "no spaces", "trim unchanged");
  // --- Conversions ---
  assert("123" as integer == 123, "text to int");
  assert("1.5" as float == 1.5, "text to float");
  assert("{42}" == "42", "int to text");
  assert("{true}" == "true", "bool to text");
  // --- Case conversion ---
  assert("hello".to_uppercase() == "HELLO", "to_uppercase");
  assert("HELLO".to_lowercase() == "hello", "to_lowercase");
  assert("MiXeD".to_lowercase() == "mixed", "to_lowercase mixed case");
  assert("MiXeD".to_uppercase() == "MIXED", "to_uppercase mixed case");
  // --- Replace ---
  assert("hello world".replace("world", "loft") == "hello loft", "replace word");
  assert("aaa".replace("a", "bb") == "bbbbbb", "replace all occurrences");
  assert("hello".replace("xyz", "!") == "hello", "replace missing is unchanged");
  // --- rfind ---
  assert("abcabc".rfind("b") == 4, "rfind: last b at byte 4");
  assert("hello".rfind("l") == 3, "rfind: last l at byte 3");
  assert("hello".rfind("xyz") == null, "rfind missing is null");
  // --- Empty string iteration ---
  empty_count = 0;
  for _ in "" {
    empty_count += 1;
  }
  assert(empty_count == 0, "empty text iteration executes zero times");
  // --- Slice with equal boundaries ---
  assert("hello"[2..2] == "", "slice start==end is empty");
  assert("hello"[0..0] == "", "slice [0..0] is empty");
  // --- trim_start and trim_end ---
  assert("  hello".trim_start() == "hello", "trim_start removes leading spaces");
  assert("hello  ".trim_end() == "hello", "trim_end removes trailing spaces");
  assert("  hi  ".trim_start().trim_end() == "hi", "trim_start then trim_end");
  // --- Character append to text ---
  ca = "abc";
  ca += 'x';
  assert(ca == "abcx", "char append with +=");
  assert("abc" + 'd' == "abcd", "char concat with +");
  // --- Character predicate: is_alphanumeric ---
  assert('a'.is_alphanumeric(), "is_alphanumeric: letter");
  assert('Z'.is_alphanumeric(), "is_alphanumeric: uppercase letter");
  assert('5'.is_alphanumeric(), "is_alphanumeric: digit");
  assert(!'_'.is_alphanumeric(), "is_alphanumeric: underscore is false");
  assert(!' '.is_alphanumeric(), "is_alphanumeric: space is false");
  assert(!'.'.is_alphanumeric(), "is_alphanumeric: dot is false");
  // --- String parsing: find first non-identifier character ---
  // Mimics the pattern from string_parse test: scan until non-alnum and non-underscore.
  parse_pos = 0;
  for p in 0..20 {
    ch = "if_cond "[p];
    if !ch.is_alphanumeric() and ch != '_' {
      parse_pos = p;
      p# break;
    }
  }
  assert(parse_pos == 7, "parse identifier end at byte 7: {parse_pos}");
  // --- Optional result from rfind (nullable integer) ---
  // rfind returns null when not found; using it as an optional to slice.
  sep = "a/b/c".rfind("/");
  assert(sep, "rfind found: result is non-null");
  assert(sep == 3, "rfind last slash at byte 3: {sep}");
  assert("a/b/c"[sep + 1..] == "c", "slice after rfind: last component is c");
  missing = "hello".rfind("/");
  assert(!missing, "rfind missing returns null");
  // --- Null-coalescing on text rfind result ---
  pos = "no-slash".rfind("/") ?? 0;
  assert(pos == 0, "rfind ?? 0 gives 0 when missing: {pos}");
  // --- String as integer via format ---
  sum_fmt = 0;
  for t in 1..4 {
    sum_fmt += "0{t}0" as integer;
  }
  assert(sum_fmt == 60, "\"0{{t}}0\" as integer sum 010+020+030=60: {sum_fmt}");
  // --- join ---
  assert(join(["a", "b", "c"], ", ") == "a, b, c", "join three parts");
  assert(join(["x"], "-") == "x", "join single element has no separator");
  assert(join([], "-") == "", "join empty vector is empty string");
  assert(join(["hello", "world"], " ") == "hello world", "join with space");
  assert(join(["a", "b", "c"], "") == "abc", "join with empty separator");
  assert(join(["one"], "") == "one", "join single with empty separator");
  // --- Text-level predicates (whole-string classify) ---
  // Note: empty string has no characters so all predicates return true (vacuous).
  assert("hello".is_alphabetic(), "text is_alphabetic: all letters");
  assert(!"hello123".is_alphabetic(), "text is_alphabetic: mixed letter+digit is false");
  assert("12345".is_numeric(), "text is_numeric: all digits");
  assert(!"12a".is_numeric(), "text is_numeric: letter makes it false");
  assert("hello123".is_alphanumeric(), "text is_alphanumeric: letters and digits");
  assert(!"hello!".is_alphanumeric(), "text is_alphanumeric: punct makes it false");
  assert("hello".is_lowercase(), "text is_lowercase: all lower");
  assert(!"Hello".is_lowercase(), "text is_lowercase: capital makes it false");
  assert("HELLO".is_uppercase(), "text is_uppercase: all upper");
  assert(!"Hello".is_uppercase(), "text is_uppercase: lowercase letter makes it false");
  assert("   \t".is_whitespace(), "text is_whitespace: spaces and tab");
  assert(!" hello ".is_whitespace(), "text is_whitespace: letters make it false");
  assert(!"hello".is_control(), "text is_control: normal text returns false");
  // --- Character predicates (individual char classify) ---
  assert('a'.is_lowercase(), "char is_lowercase: 'a' is lower");
  assert(!'A'.is_lowercase(), "char is_lowercase: 'A' is false");
  assert(!'5'.is_lowercase(), "char is_lowercase: digit is false");
  assert('Z'.is_uppercase(), "char is_uppercase: 'Z' is upper");
  assert(!'z'.is_uppercase(), "char is_uppercase: 'z' is false");
  assert(!'3'.is_uppercase(), "char is_uppercase: digit is false");
  assert('5'.is_numeric(), "char is_numeric: digit");
  assert(!'a'.is_numeric(), "char is_numeric: letter is false");
  assert(!' '.is_numeric(), "char is_numeric: space is false");
  assert('a'.is_alphabetic(), "char is_alphabetic: letter");
  assert('Z'.is_alphabetic(), "char is_alphabetic: uppercase letter");
  assert(!'5'.is_alphabetic(), "char is_alphabetic: digit is false");
  assert(!' '.is_alphabetic(), "char is_alphabetic: space is false");
  // --- Non-ASCII character predicates ---
  assert('ä'.is_lowercase(), "char is_lowercase: non-ASCII lower");
  assert(!'Ä'.is_lowercase(), "char is_lowercase: non-ASCII upper is false");
  assert('Ñ'.is_uppercase(), "char is_uppercase: non-ASCII upper");
  assert(!'ñ'.is_uppercase(), "char is_uppercase: non-ASCII lower is false");
  assert('é'.is_alphabetic(), "char is_alphabetic: accented letter");
  // --- to_uppercase / to_lowercase on non-ASCII ---
  assert("café".to_uppercase() == "CAFÉ", "to_uppercase non-ASCII");
  assert("CAFÉ".to_lowercase() == "café", "to_lowercase non-ASCII");
  // --- Text-to-float parse edge cases ---
  assert(!("abc" as float), "parse non-numeric text to float yields null");
  assert(!("" as float), "parse empty text to float yields null");
  assert("3.14" as float == 3.14, "parse valid float text");
  assert("-2.5" as float == -2.5, "parse negative float text");
  // --- split ---
  parts = "a,b,c".split(',');
  assert(len(parts) == 3, "split 3 parts: len={len(parts)}");
  assert(parts[0] == "a", "split [0]={parts[0]}");
  assert(parts[1] == "b", "split [1]={parts[1]}");
  assert(parts[2] == "c", "split [2]={parts[2]}");
  nosep = "hello".split(',');
  assert(len(nosep) == 0, "split no separator: len={len(nosep)}");
  words = "one two three".split(' ');
  assert(len(words) == 3, "split by space: len={len(words)}");
  assert(words[0] == "one", "split by space [0]={words[0]}");
  assert(words[2] == "three", "split by space [2]={words[2]}");
  // --- join ---
  jn_abc = ["a", "b", "c"];
  assert(jn_abc.join(",") == "a,b,c", "join comma");
  assert(jn_abc.join(" ") == "a b c", "join space");
  assert(jn_abc.join("") == "abc", "join empty sep");
  jn_one = ["only"];
  assert(jn_one.join(",") == "only", "join single element");
  jn_empty: vector<text> = [];
  assert(jn_empty.join(",") == "", "join empty vector");
  // roundtrip: split then join recovers original
  assert("x-y-z".split('-').join("-") == "x-y-z", "split/join roundtrip");
  // --- A8: destination-passing — assign result to variable ---
  s = "Hello World";
  lo = s.to_lowercase();
  assert(lo == "hello world", "to_lowercase assign: {lo}");
  up = s.to_uppercase();
  assert(up == "HELLO WORLD", "to_uppercase assign: {up}");
  rep = s.replace("World", "Loft");
  assert(rep == "Hello Loft", "replace assign: {rep}");
  // A8: append via += (destination-passing path)
  buf = "prefix: ";
  buf += "mixed".to_uppercase();
  assert(buf == "prefix: MIXED", "to_uppercase append: {buf}");
  buf2 = "result: ";
  buf2 += "foo bar".replace("foo", "baz");
  assert(buf2 == "result: baz bar", "replace append: {buf2}");
  // A8: format string interpolation uses scratch-buffer path
  tag = "WORLD";
  everyone = s.replace("World", "everyone");
  msg = "hello {tag.to_lowercase()} and {everyone}";
  assert(msg == "hello world and Hello everyone", "format with text fns: {msg}");
}
