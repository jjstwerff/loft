// Test native codegen for struct + vector patterns.
// Must pass in both --interpret and --native modes.
// Exercises: OpDatabase, OpNewRecord, OpFinishRecord, OpFreeRef,
// OpAppendVector, OpCopyRecord, and vector field deep-copy.

struct NBox {
    width: integer,
    items: vector<integer>
}

fn make_nbox(n: integer) -> NBox {
    d: vector<integer> = [];
    for i in 0..n {
        d += [i * 10];
    }
    NBox { width: n, items: d }
}

fn sum_vec(v: vector<integer>) -> integer {
    s = 0;
    for i in 0..v.len() {
        s += v[i];
    }
    s
}

fn test_struct_vector_return() {
    b = make_nbox(5);
    assert(b.width == 5, "width: {b.width}");
    assert(b.items.len() == 5, "items len: {b.items.len()}");
    assert(b.items[0] == 0, "items[0]: {b.items[0]}");
    assert(b.items[4] == 40, "items[4]: {b.items[4]}");
    assert(sum_vec(b.items) == 100, "sum: {sum_vec(b.items)}");
}

fn test_struct_vector_literal() {
    b = NBox { width: 3, items: [10, 20, 30] };
    assert(b.width == 3, "literal width");
    assert(b.items.len() == 3, "literal items len");
    assert(b.items[1] == 20, "literal items[1]");
}

fn test_struct_vector_empty() {
    b = NBox { width: 0, items: [] };
    assert(b.width == 0, "empty width");
    assert(b.items.len() == 0, "empty items len");
}

fn test_struct_vector_field_access() {
    b = make_nbox(4);
    total = sum_vec(b.items);
    assert(total == 60, "field access sum: {total}");
}

fn test_struct_vector_in_loop() {
    total = 0;
    for i in 0..5 {
        b = make_nbox(3);
        total += sum_vec(b.items);
    }
    assert(total == 150, "loop total: {total}");
}

fn test() {
    test_struct_vector_return();
    test_struct_vector_literal();
    test_struct_vector_empty();
    test_struct_vector_field_access();
    test_struct_vector_in_loop();
}
