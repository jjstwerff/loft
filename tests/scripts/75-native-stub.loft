// PKG.1: Verify #native functions are detected and produce a clear error
// when the native library is not loaded.

// Declare a function with #native — no implementation loaded.
fn my_native_add(a: integer, b: integer) -> integer;
#native "n_my_native_add"

// @EXPECT_FAIL: native function 'n_my_native_add' not loaded
fn test_native_stub_panics() {
  result = my_native_add(1, 2);
  assert(result == 3, "should not reach here");
}
