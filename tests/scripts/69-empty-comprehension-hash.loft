// P99/C58: Empty struct comprehension + multiple hash types — fixed.
// Previously crashed with "index out of bounds: the len is N but the index is 65535"
// because field comprehensions used u16::MAX as a variable reference.

struct ECHEntry { word: text, freq: integer }
struct ECHMap { entries: vector<ECHEntry>, lookup: hash<ECHEntry[word]> }
struct ECHNum { id: integer not null, label: text }
struct ECHNumMap { data: vector<ECHNum>, lookup: hash<ECHNum[id]> }

fn test_empty_comprehension_with_two_hash_types() {
  m1 = ECHMap { };
  m1.entries = [for ech_d in 0..0 { ECHEntry { word: "", freq: 0 } }];
  assert(m1.entries.len() == 0, "empty via comprehension");
  m2 = ECHNumMap { };
  m2.data = [ECHNum { id: 1, label: "one" }];
  assert(m2.lookup[1].label == "one", "second hash type works");
}
