pub struct Hex { mat: integer not null, height: integer not null }
pub struct Chunk { cx: integer not null, cy: integer not null, cz: integer not null, hexes: vector<Hex> }
pub struct MatDef { name: text, r: integer not null }
pub struct WallDef { name: text, body: text }
pub struct ItemDef { name: text, kind: text }
pub struct Spawn { kind: text, count: integer not null }
pub struct Routine { name: text, npc: integer not null }
