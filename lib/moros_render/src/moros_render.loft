// moros_render — 3D geometry generation from moros_map data.
// Phase 6a per ../moros/doc/claude/SCENE_EDITOR_PLAN.md.

use moros_map;
use graphics;

// ── Constants ─────────────────────────────────────────────────────

// Hex grid geometry (flat-top orientation, unit size = 1.0).
// Hex width  = sqrt(3) ≈ 1.732
// Row height = 1.5

pub HEX_SIZE = 1.0;

// sqrt(3) approximation — loft has no sqrt() for floats yet.
pub HEX_WIDTH = 1.7320508;

// Vertical spacing between hex rows.
pub HEX_ROW_HEIGHT = 1.5;

// Height units to world-space Y scale.
pub HEIGHT_SCALE = 0.25;

// ── Hex coordinate → world position ──────────────────────────────

// Convert hex axial (q, r) + height to a 3D world position (centre).
// Flat-top hex layout:
//   x = q * hex_width + (r % 2) * (hex_width / 2)
//   y = height * HEIGHT_SCALE
//   z = r * HEX_ROW_HEIGHT
pub fn hex_to_world(q: integer, r: integer, height: integer) -> Vec3 {
  x = q as float * HEX_WIDTH + (r % 2) as float * (HEX_WIDTH / 2.0);
  y = height as float * HEIGHT_SCALE;
  z = r as float * HEX_ROW_HEIGHT;
  vec3(x, y, z)
}

// The 6 corner offsets of a flat-top unit hex (clockwise from top).
// Corner i has angle = 60° * i, measured from 12-o'clock.
// Using pre-computed sin/cos:
//   corner 0: (0, +1)           top
//   corner 1: (+√3/2, +0.5)    top-right
//   corner 2: (+√3/2, -0.5)    bottom-right
//   corner 3: (0, -1)           bottom
//   corner 4: (-√3/2, -0.5)    bottom-left
//   corner 5: (-√3/2, +0.5)    top-left
fn hex_corner_offset(i: integer) -> Vec2 {
  half_w = HEX_WIDTH / 2.0;
  if i == 0 { return vec2(0.0, 1.0); }
  if i == 1 { return vec2(half_w, 0.5); }
  if i == 2 { return vec2(half_w, -0.5); }
  if i == 3 { return vec2(0.0, -1.0); }
  if i == 4 { return vec2(0.0 - half_w, -0.5); }
  vec2(0.0 - half_w, 0.5)   // i == 5
}

// ── Dev-art material colours (Phase 6a.2) ─────────────────────────

// Map material index to an RGBA dev-art colour.
// Index 0 = default (grey grass), other indices from DEVELOPER_ART.md.
pub fn dev_art_color(mat: integer) -> integer {
  if mat == 0 { return rgb(128, 160, 80); }     // grass
  if mat == 1 { return rgb(160, 140, 120); }     // stone wall
  if mat == 2 { return rgb(180, 150, 100); }     // wood floor
  if mat == 3 { return rgb(100, 180, 60); }      // bright grass
  if mat == 4 { return rgb(140, 130, 125); }     // stone stair
  if mat == 5 { return rgb(200, 180, 140); }     // sand
  if mat == 6 { return rgb(60, 100, 180); }      // water
  if mat == 7 { return rgb(80, 80, 80); }        // dark rock
  if mat == 8 { return rgb(220, 200, 160); }     // plaster
  if mat == 9 { return rgb(100, 60, 40); }       // dirt
  rgb(200, 200, 200)                             // default: light grey
}

// ── Hex surface geometry (Phase 6a.3) ─────────────────────────────

// Emit a flat hex surface into a mesh.  Produces 7 vertices (centre +
// 6 corners) and 6 triangles (fan from centre).  Returns the base
// vertex index so callers can reference the vertices.
pub fn emit_hex_surface(m: &Mesh, q: integer, r: integer, height: integer) -> integer {
  centre = hex_to_world(q, r, height);
  up = vec3(0.0, 1.0, 0.0);   // flat surface normal
  base = len(m.vertices);
  // Centre vertex
  m.vertices += [vertex(centre, up, vec2(0.5, 0.5))];
  // 6 corner vertices
  for ci in 0..6 {
    off = hex_corner_offset(ci);
    pos = vec3(centre.x + off.x, centre.y, centre.z + off.y);
    u = (off.x / HEX_WIDTH) + 0.5;
    v = (off.y / 1.0) * 0.5 + 0.5;
    m.vertices += [vertex(pos, up, vec2(u, v))];
  }
  // 6 triangles: fan from centre to each edge
  for ti in 0..6 {
    next = (ti + 1) % 6;
    tri = Triangle { a: base, b: base + 1 + ti, c: base + 1 + next };
    m.triangles += [tri];
  }
  base
}

// ── Wall geometry (Phase 6a.5) ────────────────────────────────────

// Emit a wall quad between two hex corners at floor_y and ceil_y.
// c1/c2 are 3D positions of the wall's bottom-left and bottom-right.
pub fn emit_wall_quad(m: &Mesh, c1: Vec3, c2: Vec3, floor_y: float, ceil_y: float) {
  // Normal: cross product of (c2-c1) × (up).
  dx = c2.x - c1.x;
  dz = c2.z - c1.z;
  len_xz = sqrt(dx * dx + dz * dz);
  nx = 0.0 - dz / len_xz;  // perpendicular in XZ plane
  nz = dx / len_xz;
  normal = vec3(nx, 0.0, nz);
  base = len(m.vertices);
  // 4 corners: bottom-left, bottom-right, top-right, top-left
  m.vertices += [vertex(vec3(c1.x, floor_y, c1.z), normal, vec2(0.0, 0.0))];
  m.vertices += [vertex(vec3(c2.x, floor_y, c2.z), normal, vec2(1.0, 0.0))];
  m.vertices += [vertex(vec3(c2.x, ceil_y, c2.z), normal, vec2(1.0, 1.0))];
  m.vertices += [vertex(vec3(c1.x, ceil_y, c1.z), normal, vec2(0.0, 1.0))];
  // Two triangles: (0,1,2) + (0,2,3)
  m.triangles += [Triangle { a: base, b: base + 1, c: base + 2 }];
  m.triangles += [Triangle { a: base, b: base + 2, c: base + 3 }];
}

// ── Slope face geometry (Phase 6a.4) ──────────────────────────────

// Emit a slope triangle between two adjacent hex corners at different
// heights.  Used for terrain cliffs between hexes of different height.
pub fn emit_slope_face(m: &Mesh, c1: Vec3, c2: Vec3, y_low: float, y_high: float) {
  // Slope normal: approximate as the average of horizontal and vertical.
  dx = c2.x - c1.x;
  dz = c2.z - c1.z;
  len_xz = sqrt(dx * dx + dz * dz);
  nx = 0.0 - dz / len_xz;
  nz = dx / len_xz;
  dy = y_high - y_low;
  len_slope = sqrt(len_xz * len_xz + dy * dy);
  ny = len_xz / len_slope;
  normal = vec3(nx * dy / len_slope, ny, nz * dy / len_slope);
  base = len(m.vertices);
  // Quad: low-left, low-right, high-right, high-left
  m.vertices += [vertex(vec3(c1.x, y_low, c1.z), normal, vec2(0.0, 0.0))];
  m.vertices += [vertex(vec3(c2.x, y_low, c2.z), normal, vec2(1.0, 0.0))];
  m.vertices += [vertex(vec3(c2.x, y_high, c2.z), normal, vec2(1.0, 1.0))];
  m.vertices += [vertex(vec3(c1.x, y_high, c1.z), normal, vec2(0.0, 1.0))];
  tri1 = Triangle { a: base, b: base + 1, c: base + 2 };
  tri2 = Triangle { a: base, b: base + 2, c: base + 3 };
  m.triangles += [tri1];
  m.triangles += [tri2];
}

// ── Hex neighbour helpers ─────────────────────────────────────────

// Get the world-space position of hex corner `ci` (0-5) for hex (q,r,h).
pub fn hex_corner_world(q: integer, r: integer, height: integer, ci: integer) -> Vec3 {
  centre = hex_to_world(q, r, height);
  off = hex_corner_offset(ci);
  vec3(centre.x + off.x, centre.y, centre.z + off.y)
}

// Axial neighbour offsets for the 6 hex directions (flat-top).
// dir 0=N(+r), 1=NE(+q), 2=SE(+q,-r), 3=S(-r), 4=SW(-q), 5=NW(-q,+r)
fn neighbour_dq(dir: integer) -> integer {
  if dir == 1 || dir == 2 { return 1; }
  if dir == 4 || dir == 5 { return -1; }
  0
}

fn neighbour_dr(dir: integer) -> integer {
  if dir == 0 || dir == 5 { return -1; }
  if dir == 3 || dir == 2 { return 1; }
  0
}

// ── Linear stair geometry (Phase 6a.9 / MO.8a) ────────────────────

// Step count for a linear stair climbing from y_low to y_high.
// Rule of thumb: one step per HEIGHT_SCALE world-units of climb.
// Minimum 1 step (descending climbs count the same as ascending).
pub fn stair_step_count(y_low: float, y_high: float) -> integer {
  d = y_high - y_low;
  if d < 0.0 { d = 0.0 - d; }
  n = (d / HEIGHT_SCALE) as integer;
  if n < 1 { 1 } else { n }
}

// Emit a linear stair with `step_count` uniform steps from `p_low`
// (front-centre at the low end) to `p_high` (front-centre at the
// high end).  `width` is the lateral size perpendicular to travel.
// Each step contributes 8 vertices (4 riser + 4 tread) and 4
// triangles (2 riser + 2 tread).  No geometry is emitted when the
// step count is non-positive or the horizontal distance is zero.
pub fn emit_linear_stair(
  m: &Mesh, p_low: Vec3, p_high: Vec3, width: float, step_count: integer
) {
  if step_count <= 0 { return; }
  ls_dx = p_high.x - p_low.x;
  ls_dz = p_high.z - p_low.z;
  ls_dy = p_high.y - p_low.y;
  horiz = sqrt(ls_dx * ls_dx + ls_dz * ls_dz);
  if horiz == 0.0 { return; }
  fwd_x = ls_dx / horiz;
  fwd_z = ls_dz / horiz;
  // 90° rotation in XZ for the lateral direction.
  side_x = 0.0 - fwd_z;
  side_z = fwd_x;
  stair_half_w = width / 2.0;
  step_run  = horiz / step_count as float;
  step_rise = ls_dy / step_count as float;
  stair_up = vec3(0.0, 1.0, 0.0);
  // Riser normal points backward (against travel direction).
  riser_n = vec3(0.0 - fwd_x, 0.0, 0.0 - fwd_z);
  for ls_i in 0..step_count {
    i_f = ls_i as float;
    fx = p_low.x + fwd_x * step_run * i_f;
    fz = p_low.z + fwd_z * step_run * i_f;
    y_bot = p_low.y + step_rise * i_f;
    y_top = p_low.y + step_rise * (i_f + 1.0);
    lx = side_x * stair_half_w;
    lz = side_z * stair_half_w;
    // Riser quad — vertical, faces backward.
    r_bl = vec3(fx - lx, y_bot, fz - lz);
    r_br = vec3(fx + lx, y_bot, fz + lz);
    r_tr = vec3(fx + lx, y_top, fz + lz);
    r_tl = vec3(fx - lx, y_top, fz - lz);
    rb = len(m.vertices);
    m.vertices += [vertex(r_bl, riser_n, vec2(0.0, 0.0))];
    m.vertices += [vertex(r_br, riser_n, vec2(1.0, 0.0))];
    m.vertices += [vertex(r_tr, riser_n, vec2(1.0, 1.0))];
    m.vertices += [vertex(r_tl, riser_n, vec2(0.0, 1.0))];
    m.triangles += [Triangle { a: rb, b: rb + 1, c: rb + 2 }];
    m.triangles += [Triangle { a: rb, b: rb + 2, c: rb + 3 }];
    // Tread quad — horizontal, faces up.
    bx = fx + fwd_x * step_run;
    bz = fz + fwd_z * step_run;
    t_fl = vec3(fx - lx, y_top, fz - lz);
    t_fr = vec3(fx + lx, y_top, fz + lz);
    t_br = vec3(bx + lx, y_top, bz + lz);
    t_bl = vec3(bx - lx, y_top, bz - lz);
    tb = len(m.vertices);
    m.vertices += [vertex(t_fl, stair_up, vec2(0.0, 0.0))];
    m.vertices += [vertex(t_fr, stair_up, vec2(1.0, 0.0))];
    m.vertices += [vertex(t_br, stair_up, vec2(1.0, 1.0))];
    m.vertices += [vertex(t_bl, stair_up, vec2(0.0, 1.0))];
    m.triangles += [Triangle { a: tb, b: tb + 1, c: tb + 2 }];
    m.triangles += [Triangle { a: tb, b: tb + 2, c: tb + 3 }];
  }
}

// ── Spiral stair geometry (Phase 6a.10 / MO.8b) ───────────────────

// Emit a spiral stair with `step_count` pie-slice treads fanning
// around the Y-axis at `centre` (base).  Each tread covers
// `angle_deg_per_step` of sweep and sits `rise_per_step` higher in
// Y than the previous (so step i is at y = centre.y + rise_per_step
// * (i + 1)).  `inner_r` is the newel-side radius; `outer_r` is the
// rail-side radius.
//
// Each tread is a flat trapezoidal quad (inner-front, inner-back,
// outer-back, outer-front) with an upward normal: 4 vertices + 2
// triangles per step.  Non-positive step count, negative inner_r,
// or outer_r <= inner_r emit nothing.  The central newel cylinder
// is not drawn here — emit it separately (Phase 6a.8 cylinder post).
pub fn emit_spiral_stair(
  m: &Mesh, centre: Vec3, inner_r: float, outer_r: float,
  rise_per_step: float, step_count: integer, angle_deg_per_step: float
) {
  if step_count <= 0 { return; }
  if inner_r < 0.0 || outer_r <= inner_r { return; }
  deg_to_rad = PI / 180.0;
  up_ss = vec3(0.0, 1.0, 0.0);
  for ss_i in 0..step_count {
    i_ss = ss_i as float;
    angle_start = (i_ss * angle_deg_per_step) * deg_to_rad;
    angle_end = ((i_ss + 1.0) * angle_deg_per_step) * deg_to_rad;
    tread_y = centre.y + rise_per_step * (i_ss + 1.0);
    cos_s = cos(angle_start);
    sin_s = sin(angle_start);
    cos_e = cos(angle_end);
    sin_e = sin(angle_end);
    // Winding: inner-front → inner-back → outer-back → outer-front
    // (clockwise from above → normal points +Y, matches the linear
    // stair tread convention above).
    i_front = vec3(centre.x + inner_r * cos_s, tread_y, centre.z + inner_r * sin_s);
    i_back  = vec3(centre.x + inner_r * cos_e, tread_y, centre.z + inner_r * sin_e);
    o_back  = vec3(centre.x + outer_r * cos_e, tread_y, centre.z + outer_r * sin_e);
    o_front = vec3(centre.x + outer_r * cos_s, tread_y, centre.z + outer_r * sin_s);
    ss_base = len(m.vertices);
    m.vertices += [vertex(i_front, up_ss, vec2(0.0, 0.0))];
    m.vertices += [vertex(i_back,  up_ss, vec2(0.0, 1.0))];
    m.vertices += [vertex(o_back,  up_ss, vec2(1.0, 1.0))];
    m.vertices += [vertex(o_front, up_ss, vec2(1.0, 0.0))];
    m.triangles += [Triangle { a: ss_base, b: ss_base + 1, c: ss_base + 2 }];
    m.triangles += [Triangle { a: ss_base, b: ss_base + 2, c: ss_base + 3 }];
  }
}

// ── Scene builder (Phase 6a.13) ───────────────────────────────────

// Find or create a mesh by material name, emit a hex surface into it.
// Uses the map's material index as the mesh name for grouping.
fn emit_to_material(meshes: vector<Mesh>, mat: integer, q: integer, r: integer, height: integer) {
  mat_name = "{mat}";
  for em in meshes {
    if em.name == mat_name {
      emit_hex_surface(em, q, r, height);
      return;
    }
  }
  meshes += [mesh(mat_name)];
  nm = meshes[len(meshes) - 1];
  emit_hex_surface(nm, q, r, height);
}

// Emit wall geometry for a hex's 3 stored edges (N, NE, SE).
fn emit_hex_walls(wall_mesh: &Mesh, q: integer, r: integer, height: integer, h: Hex) {
  floor_y = height as float * HEIGHT_SCALE;
  ceil_y = floor_y + 1.0;   // 1 unit tall walls
  if h.h_wall_n != 0 {
    c1 = hex_corner_world(q, r, height, 5);   // top-left
    c2 = hex_corner_world(q, r, height, 0);   // top
    emit_wall_quad(wall_mesh, c1, c2, floor_y, ceil_y);
  }
  if h.h_wall_ne != 0 {
    c1 = hex_corner_world(q, r, height, 0);   // top
    c2 = hex_corner_world(q, r, height, 1);   // top-right
    emit_wall_quad(wall_mesh, c1, c2, floor_y, ceil_y);
  }
  if h.h_wall_se != 0 {
    c1 = hex_corner_world(q, r, height, 1);   // top-right
    c2 = hex_corner_world(q, r, height, 2);   // bottom-right
    emit_wall_quad(wall_mesh, c1, c2, floor_y, ceil_y);
  }
}

// Build meshes for all visible hexes in a map.
// Returns a vector of meshes grouped by material index.
// Also includes a "walls" mesh for all wall geometry.
pub fn build_hex_meshes(map: Map) -> vector<Mesh> {
  meshes: vector<Mesh> = [];
  wall_mesh = mesh("walls");
  for bm_c in map.m_chunks {
    for bm_h in bm_c.ck_hexes {
      q = bm_c.ck_cx * 32 + bm_h#index / 32;
      r = bm_c.ck_cz * 32 + bm_h#index % 32;
      emit_to_material(meshes, bm_h.h_material, q, r, bm_h.h_height);
      emit_hex_walls(wall_mesh, q, r, bm_h.h_height, bm_h);
    }
  }
  if len(wall_mesh.vertices) > 0 {
    meshes += [wall_mesh];
  }
  meshes
}

// Summary statistics for a built scene.
pub fn scene_vertex_count(meshes: vector<Mesh>) -> integer {
  total = 0;
  for sm in meshes { total = total + len(sm.vertices); }
  total
}

pub fn scene_triangle_count(meshes: vector<Mesh>) -> integer {
  total = 0;
  for sm in meshes { total = total + len(sm.triangles); }
  total
}
