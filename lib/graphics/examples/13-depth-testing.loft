#!/usr/bin/env -S loft --native
// Depth Testing — overlapping rotating cubes on a grey floor. The renderer
// enables depth testing by default; this example just describes the scene
// and lets the pipeline do its job.
//
// Loft constructions used:
//   scene::{Scene, Camera, material_color, node_at, directional_light}
//   render::{create_renderer, render_frame, destroy}
use mesh;
use math;
use scene;
use render;

fn render_native() {
  sc13 = scene::Scene { name: "depth_testing" };
  ci13 = sc13.add_mesh(mesh::cube());
  fi13 = sc13.add_mesh(mesh::plane("floor", 8.0, 8.0));
  floor_m13 = sc13.add_material(scene::material_color("floor", 0.45, 0.45, 0.5));
  red13 = sc13.add_material(scene::material_color("red", 0.9, 0.2, 0.15));
  blue13 = sc13.add_material(scene::material_color("blue", 0.15, 0.3, 0.9));
  sc13.add_node(scene::node_at("floor", fi13, floor_m13, math::mat4_identity()));
  sc13.add_node(scene::node_at("near_cube", ci13, red13,
    math::mat4_translate(-1.0, 0.5, 1.0)));
  sc13.add_node(scene::node_at("far_cube", ci13, blue13,
    math::mat4_translate(1.5, 0.5, -2.0)));
  sc13.add_light(scene::directional_light("sun", 1.0, 0.95, 0.9, 3.0,
    math::normalize3(math::vec3(-1.0, -2.0, -1.0))));
  cam13 = scene::Camera { name: "main", fov: 45.0, near: 0.1, far: 15.0,
    position: math::vec3(3.0, 3.0, 5.0),
    target: math::vec3(0.0, 0.0, 0.0) };
  r13 = render::create_renderer(800, 600, "13 - Depth Testing");
  start13 = ticks();
  for _ in 0..3000 {
    t13 = (ticks() - start13) as float / 1000000.0;
    sc13.nodes[1].transform = math::mat4_trs(-1.0, 0.5, 1.0, t13 * 0.5, 1.0, 1.0, 1.0);
    sc13.nodes[2].transform = math::mat4_trs(1.5, 0.5, -2.0, t13 * 0.3, 1.0, 1.0, 1.0);
    if !r13.render_frame(sc13, cam13) { break; }
  }
  r13.destroy();
}

fn main() { render_native(); }
