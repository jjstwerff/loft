// Graphics library — 2D pixel canvas with drawing primitives.

use math;
use mesh;
use scene;
use glb;

// RGBA color packed as a single integer: 0xAARRGGBB.
// Alpha: 255 = fully opaque, 0 = fully transparent.
// Use rgba() to construct and r()/g()/b()/a() to extract channels.

// Pack RGBA channels into a single integer using bitwise ops.
// Layout: bits 24..31 = alpha, 16..23 = red, 8..15 = green, 0..7 = blue.
// Loft integers are 64-bit signed post-2c, so the packed value fits
// directly — no widening cast needed.
pub fn rgba(cr: integer, cg: integer, cb: integer, ca: integer) -> integer {
  ((ca & 255) << 24) | ((cr & 255) << 16) | ((cg & 255) << 8) | (cb & 255)
}

pub fn rgb(cr: integer, cg: integer, cb: integer) -> integer {
  rgba(cr, cg, cb, 255)
}

pub fn color_r(color: integer) -> integer { (color >> 16) & 255 }
pub fn color_g(color: integer) -> integer { (color >> 8) & 255 }
pub fn color_b(color: integer) -> integer { color & 255 }
pub fn color_a(color: integer) -> integer {
  // integer is i64 post-2c, so the shift is logical on the high byte.
  ((color & 0xFF000000) >> 24) & 255
}

// A 2D pixel canvas backed by a flat vector of RGBA integers.
// Pixels are stored row-major: data[y * width + x].

pub struct Canvas {
  width: integer not null,
  height: integer not null,
  data: vector<integer>
}

// Create a canvas filled with a solid color.
pub fn canvas(cw: integer, ch: integer, fill_color: integer) -> Canvas {
  result = Canvas { width: cw, height: ch };
  result.data = [for _ in 0..cw * ch { fill_color }];
  result
}

// Get pixel color at (x, y). Returns 0 if out of bounds.
pub fn get_pixel(self: const Canvas, gx: integer, gy: integer) -> integer {
  if gx < 0 or gx >= self.width or gy < 0 or gy >= self.height {
    0
  } else {
    self.data[gy * self.width + gx]
  }
}

// Set pixel color at (x, y). No-op if out of bounds.
pub fn set_pixel(self: Canvas, sx: integer, sy: integer, color: integer) {
  if sx >= 0 and sx < self.width and sy >= 0 and sy < self.height {
    self.data[sy * self.width + sx] = color;
  }
}

// Fill the entire canvas with a solid color.
pub fn clear(self: Canvas, color: integer) {
  for cl_i in 0..self.width * self.height {
    self.data[cl_i] = color;
  }
}

// Alpha-blend src over dst. Both are 0xAARRGGBB packed integers.
// Uses standard "src over" compositing: out = src * alpha + dst * (1 - alpha).
pub fn blend(dst: integer, src: integer) -> integer {
  sa = color_a(src);
  if sa == 255 { return src; }
  if sa == 0 { return dst; }
  inv = 255 - sa;
  br = (color_r(src) * sa + color_r(dst) * inv) / 255;
  bg = (color_g(src) * sa + color_g(dst) * inv) / 255;
  bb = (color_b(src) * sa + color_b(dst) * inv) / 255;
  ba = sa + (color_a(dst) * inv) / 255;
  rgba(br, bg, bb, ba)
}

// Draw a pixel with alpha blending at (x, y).
pub fn blend_pixel(self: Canvas, bx: integer, by: integer, color: integer) {
  if bx >= 0 and bx < self.width and by >= 0 and by < self.height {
    idx = by * self.width + bx;
    self.data[idx] = blend(self.data[idx], color);
  }
}

// Fill a rectangle with a solid color. Clipped to canvas bounds.
pub fn fill_rect(self: Canvas, rx: integer, ry: integer, rw: integer, rh: integer, color: integer) {
  x0 = if rx < 0 { 0 } else { rx };
  y0 = if ry < 0 { 0 } else { ry };
  x1 = if rx + rw > self.width { self.width } else { rx + rw };
  y1 = if ry + rh > self.height { self.height } else { ry + rh };
  for fr_y in y0..y1 {
    for fr_x in x0..x1 {
      self.data[fr_y * self.width + fr_x] = color;
    }
  }
}

// Draw a horizontal line from (x0, y) to (x1, y). Clipped.
pub fn hline(self: Canvas, hx0: integer, hx1: integer, hy: integer, color: integer) {
  if hy < 0 or hy >= self.height { return; }
  left = if hx0 < 0 { 0 } else { hx0 };
  right = if hx1 > self.width { self.width } else { hx1 };
  for hl_x in left..right {
    self.data[hy * self.width + hl_x] = color;
  }
}

// Draw a vertical line from (x, y0) to (x, y1). Clipped.
pub fn vline(self: Canvas, vx: integer, vy0: integer, vy1: integer, color: integer) {
  if vx < 0 or vx >= self.width { return; }
  top = if vy0 < 0 { 0 } else { vy0 };
  bottom = if vy1 > self.height { self.height } else { vy1 };
  for vl_y in top..bottom {
    self.data[vl_y * self.width + vx] = color;
  }
}

// Draw a rectangle outline (1px border). Clipped.
pub fn draw_rect(self: Canvas, drx: integer, dry: integer, drw: integer, drh: integer, color: integer) {
  self.hline(drx, drx + drw, dry, color);
  self.hline(drx, drx + drw, dry + drh - 1, color);
  self.vline(drx, dry, dry + drh, color);
  self.vline(drx + drw - 1, dry, dry + drh, color);
}

// --- GL2.2: Bresenham line drawing ---

// Draw a line from (x0, y0) to (x1, y1) using Bresenham's algorithm.
// Handles all octants. Each pixel is set (no blending).
pub fn draw_line(self: Canvas, lx0: integer, ly0: integer, lx1: integer, ly1: integer, color: integer) {
  dx = if lx1 > lx0 { lx1 - lx0 } else { lx0 - lx1 };
  dy = if ly1 > ly0 { ly1 - ly0 } else { ly0 - ly1 };
  sx = if lx0 < lx1 { 1 } else { -1 };
  sy = if ly0 < ly1 { 1 } else { -1 };
  err = dx - dy;
  cx = lx0;
  cy = ly0;
  for _ in 0..dx + dy + 1 {
    self.set_pixel(cx, cy, color);
    if cx == lx1 and cy == ly1 { break; }
    e2 = 2 * err;
    if e2 > -dy {
      err -= dy;
      cx += sx;
    }
    if e2 < dx {
      err += dx;
      cy += sy;
    }
  }
}

// --- GL2.3: Circle and ellipse ---

// Draw a circle outline using the midpoint algorithm.
// Center at (cx, cy) with the given radius. Clipped via set_pixel.
pub fn draw_circle(self: Canvas, ccx: integer, ccy: integer, radius: integer, color: integer) {
  cx = 0;
  cy = radius;
  d = 1 - radius;
  for _ in 0..radius * 4 + 4 {
    if cx > cy { break; }
    // Draw all 8 octant-symmetric points.
    self.set_pixel(ccx + cx, ccy + cy, color);
    self.set_pixel(ccx - cx, ccy + cy, color);
    self.set_pixel(ccx + cx, ccy - cy, color);
    self.set_pixel(ccx - cx, ccy - cy, color);
    self.set_pixel(ccx + cy, ccy + cx, color);
    self.set_pixel(ccx - cy, ccy + cx, color);
    self.set_pixel(ccx + cy, ccy - cx, color);
    self.set_pixel(ccx - cy, ccy - cx, color);
    if d < 0 {
      d += 2 * cx + 3;
    } else {
      d += 2 * (cx - cy) + 5;
      cy -= 1;
    }
    cx += 1;
  }
}

// Fill a circle (solid disk). Center at (cx, cy), given radius.
pub fn fill_circle(self: Canvas, fcx: integer, fcy: integer, radius: integer, color: integer) {
  cx = 0;
  cy = radius;
  d = 1 - radius;
  for _ in 0..radius * 4 + 4 {
    if cx > cy { break; }
    self.hline(fcx - cx, fcx + cx + 1, fcy + cy, color);
    self.hline(fcx - cx, fcx + cx + 1, fcy - cy, color);
    self.hline(fcx - cy, fcx + cy + 1, fcy + cx, color);
    self.hline(fcx - cy, fcx + cy + 1, fcy - cx, color);
    if d < 0 {
      d += 2 * cx + 3;
    } else {
      d += 2 * (cx - cy) + 5;
      cy -= 1;
    }
    cx += 1;
  }
}

// Fill an axis-aligned ellipse (solid). Center (cx, cy), radii (rx, ry).
pub fn fill_ellipse(self: Canvas, fex: integer, fey: integer, ferx: integer, fery: integer, color: integer) {
  fe_x = 0;
  fe_y = fery;
  fe_rx2 = ferx * ferx;
  fe_ry2 = fery * fery;
  fe_d1 = fe_ry2 - fe_rx2 * fery + fe_rx2 / 4;
  for _ in 0..ferx + fery + 1 {
    if fe_ry2 * fe_x > fe_rx2 * fe_y { break; }
    self.hline(fex - fe_x, fex + fe_x + 1, fey + fe_y, color);
    self.hline(fex - fe_x, fex + fe_x + 1, fey - fe_y, color);
    if fe_d1 < 0 {
      fe_d1 += fe_ry2 * (2 * fe_x + 3);
    } else {
      fe_d1 += fe_ry2 * (2 * fe_x + 3) + fe_rx2 * (-2 * fe_y + 2);
      fe_y -= 1;
    }
    fe_x += 1;
  }
  fe_d2 = fe_ry2 * (fe_x * 2 + 1) * (fe_x * 2 + 1) / 4 + fe_rx2 * (fe_y - 1) * (fe_y - 1) - fe_rx2 * fe_ry2;
  for _ in 0..ferx + fery + 1 {
    if fe_y < 0 { break; }
    self.hline(fex - fe_x, fex + fe_x + 1, fey + fe_y, color);
    self.hline(fex - fe_x, fex + fe_x + 1, fey - fe_y, color);
    if fe_d2 > 0 {
      fe_d2 += fe_rx2 * (-2 * fe_y + 3);
    } else {
      fe_d2 += fe_ry2 * (2 * fe_x + 2) + fe_rx2 * (-2 * fe_y + 3);
      fe_x += 1;
    }
    fe_y -= 1;
  }
}

// Draw an axis-aligned ellipse outline. Center (cx, cy), radii (rx, ry).
pub fn draw_ellipse(self: Canvas, ecx: integer, ecy: integer, erx: integer, ery: integer, color: integer) {
  // Midpoint ellipse algorithm — two regions.
  ex = 0;
  ey = ery;
  rx2 = erx * erx;
  ry2 = ery * ery;
  // Region 1: dy/dx > -1
  d1 = ry2 - rx2 * ery + rx2 / 4;
  for _ in 0..erx + ery + 1 {
    if ry2 * ex > rx2 * ey { break; }
    self.set_pixel(ecx + ex, ecy + ey, color);
    self.set_pixel(ecx - ex, ecy + ey, color);
    self.set_pixel(ecx + ex, ecy - ey, color);
    self.set_pixel(ecx - ex, ecy - ey, color);
    if d1 < 0 {
      d1 += ry2 * (2 * ex + 3);
    } else {
      d1 += ry2 * (2 * ex + 3) + rx2 * (-2 * ey + 2);
      ey -= 1;
    }
    ex += 1;
  }
  // Region 2: dy/dx <= -1
  d2 = ry2 * (ex * 2 + 1) * (ex * 2 + 1) / 4 + rx2 * (ey - 1) * (ey - 1) - rx2 * ry2;
  for _ in 0..erx + ery + 1 {
    if ey < 0 { break; }
    self.set_pixel(ecx + ex, ecy + ey, color);
    self.set_pixel(ecx - ex, ecy + ey, color);
    self.set_pixel(ecx + ex, ecy - ey, color);
    self.set_pixel(ecx - ex, ecy - ey, color);
    if d2 > 0 {
      d2 += rx2 * (-2 * ey + 3);
    } else {
      d2 += ry2 * (2 * ex + 2) + rx2 * (-2 * ey + 3);
      ex += 1;
    }
    ey -= 1;
  }
}

// --- GL2.4: Cubic Bezier curves ---

// Draw a cubic Bezier curve from (bx0,by0) to (bx3,by3) with control points
// (bx1,by1) and (bx2,by2). Uses adaptive subdivision — splits until segments
// are flat enough, then draws with Bresenham lines.
// Flatness threshold: max deviation of control points from the chord.
pub fn draw_bezier(self: Canvas, bx0: integer, by0: integer, bx1: integer, by1: integer, bx2: integer, by2: integer, bx3: integer, by3: integer, color: integer) {
  // Stack-based adaptive subdivision. Each segment = 8 entries (4 points × 2 coords).
  // Use a stack pointer instead of shrinking vectors.
  bz_sx = [for _ in 0..0 { 0 }];
  bz_sy = [for _ in 0..0 { 0 }];
  bz_sx += [bx0]; bz_sx += [bx1]; bz_sx += [bx2]; bz_sx += [bx3];
  bz_sy += [by0]; bz_sy += [by1]; bz_sy += [by2]; bz_sy += [by3];
  bz_top = 4;  // stack pointer (next free index)
  for _ in 0..1000 {
    if bz_top == 0 { break; }
    // Pop segment (read 4 values, then decrease pointer)
    bz_p0x = bz_sx[bz_top - 4]; bz_p1x = bz_sx[bz_top - 3];
    bz_p2x = bz_sx[bz_top - 2]; bz_p3x = bz_sx[bz_top - 1];
    bz_p0y = bz_sy[bz_top - 4]; bz_p1y = bz_sy[bz_top - 3];
    bz_p2y = bz_sy[bz_top - 2]; bz_p3y = bz_sy[bz_top - 1];
    bz_top -= 4;
    // Flatness test: cross product distances of control points from chord
    bz_dx = bz_p3x - bz_p0x;
    bz_dy = bz_p3y - bz_p0y;
    bz_d1 = (bz_p1x - bz_p3x) * bz_dy - (bz_p1y - bz_p3y) * bz_dx;
    bz_d2 = (bz_p2x - bz_p3x) * bz_dy - (bz_p2y - bz_p3y) * bz_dx;
    if bz_d1 < 0 { bz_d1 = -bz_d1; }
    if bz_d2 < 0 { bz_d2 = -bz_d2; }
    bz_flat = if bz_d1 > bz_d2 { bz_d1 } else { bz_d2 };
    bz_chord2 = bz_dx * bz_dx + bz_dy * bz_dy;
    if bz_flat * bz_flat <= bz_chord2 or bz_chord2 == 0 {
      self.draw_line(bz_p0x, bz_p0y, bz_p3x, bz_p3y, color);
    } else {
      // de Casteljau subdivision at t=0.5
      bz_m01x = (bz_p0x + bz_p1x) / 2; bz_m01y = (bz_p0y + bz_p1y) / 2;
      bz_m12x = (bz_p1x + bz_p2x) / 2; bz_m12y = (bz_p1y + bz_p2y) / 2;
      bz_m23x = (bz_p2x + bz_p3x) / 2; bz_m23y = (bz_p2y + bz_p3y) / 2;
      bz_m012x = (bz_m01x + bz_m12x) / 2; bz_m012y = (bz_m01y + bz_m12y) / 2;
      bz_m123x = (bz_m12x + bz_m23x) / 2; bz_m123y = (bz_m12y + bz_m23y) / 2;
      bz_mx = (bz_m012x + bz_m123x) / 2; bz_my = (bz_m012y + bz_m123y) / 2;
      // Push second half first (so first half is popped next)
      // Grow vectors if needed
      if bz_top + 8 > bz_sx.len() {
        bz_sx += [0]; bz_sx += [0]; bz_sx += [0]; bz_sx += [0];
        bz_sx += [0]; bz_sx += [0]; bz_sx += [0]; bz_sx += [0];
        bz_sy += [0]; bz_sy += [0]; bz_sy += [0]; bz_sy += [0];
        bz_sy += [0]; bz_sy += [0]; bz_sy += [0]; bz_sy += [0];
      }
      bz_sx[bz_top] = bz_mx; bz_sx[bz_top+1] = bz_m123x;
      bz_sx[bz_top+2] = bz_m23x; bz_sx[bz_top+3] = bz_p3x;
      bz_sy[bz_top] = bz_my; bz_sy[bz_top+1] = bz_m123y;
      bz_sy[bz_top+2] = bz_m23y; bz_sy[bz_top+3] = bz_p3y;
      bz_top += 4;
      if bz_top + 4 > bz_sx.len() {
        bz_sx += [0]; bz_sx += [0]; bz_sx += [0]; bz_sx += [0];
        bz_sy += [0]; bz_sy += [0]; bz_sy += [0]; bz_sy += [0];
      }
      bz_sx[bz_top] = bz_p0x; bz_sx[bz_top+1] = bz_m01x;
      bz_sx[bz_top+2] = bz_m012x; bz_sx[bz_top+3] = bz_mx;
      bz_sy[bz_top] = bz_p0y; bz_sy[bz_top+1] = bz_m01y;
      bz_sy[bz_top+2] = bz_m012y; bz_sy[bz_top+3] = bz_my;
      bz_top += 4;
    }
  }
}

// --- GL2.6: Wu anti-aliased line ---

// Draw an anti-aliased line using Xiaolin Wu's algorithm.
// Uses blend_pixel for sub-pixel coverage.
pub fn draw_aa_line(self: Canvas, ax0: integer, ay0: integer, ax1: integer, ay1: integer, color: integer) {
  aa_dx = if ax1 > ax0 { ax1 - ax0 } else { ax0 - ax1 };
  aa_dy = if ay1 > ay0 { ay1 - ay0 } else { ay0 - ay1 };
  aa_steep = aa_dy > aa_dx;
  // If steep, we step along y instead of x.
  // Map to canonical form: always step along the longer axis.
  aa_x0 = if aa_steep { ay0 } else { ax0 };
  aa_y0 = if aa_steep { ax0 } else { ay0 };
  aa_x1 = if aa_steep { ay1 } else { ax1 };
  aa_y1 = if aa_steep { ax1 } else { ay1 };
  // Ensure we draw left-to-right
  if aa_x0 > aa_x1 {
    aa_tmp = aa_x0; aa_x0 = aa_x1; aa_x1 = aa_tmp;
    aa_tmp = aa_y0; aa_y0 = aa_y1; aa_y1 = aa_tmp;
  }
  aa_run = aa_x1 - aa_x0;
  if aa_run == 0 {
    // Single pixel
    self.set_pixel(ax0, ay0, color);
    return;
  }
  // Fixed-point gradient: rise * 256 / run
  aa_rise = aa_y1 - aa_y0;
  aa_grad256 = aa_rise * 256 / aa_run;
  // y in fixed-point (8 fractional bits)
  aa_yf = aa_y0 * 256;
  aa_cr = graphics::color_r(color);
  aa_cg = graphics::color_g(color);
  aa_cb = graphics::color_b(color);
  for aa_xi in aa_x0..aa_x1 + 1 {
    aa_yi = aa_yf / 256;
    aa_frac = aa_yf - aa_yi * 256;
    if aa_frac < 0 { aa_frac += 256; aa_yi -= 1; }
    aa_a1 = 255 - aa_frac;
    aa_a2 = aa_frac;
    aa_c1 = graphics::rgba(aa_cr, aa_cg, aa_cb, aa_a1);
    aa_c2 = graphics::rgba(aa_cr, aa_cg, aa_cb, aa_a2);
    if aa_steep {
      self.blend_pixel(aa_yi, aa_xi, aa_c1);
      if aa_a2 > 0 { self.blend_pixel(aa_yi + 1, aa_xi, aa_c2); }
    } else {
      self.blend_pixel(aa_xi, aa_yi, aa_c1);
      if aa_a2 > 0 { self.blend_pixel(aa_xi, aa_yi + 1, aa_c2); }
    }
    aa_yf += aa_grad256;
  }
}

// --- GL2.5: Triangle fill (scanline) ---

// Fill a triangle with vertices (tx0,ty0), (tx1,ty1), (tx2,ty2).
// Uses flat-top/flat-bottom decomposition with scanline fill.
pub fn fill_triangle(self: Canvas, tx0: integer, ty0: integer, tx1: integer, ty1: integer, tx2: integer, ty2: integer, color: integer) {
  // Sort vertices by y: ta_y <= tb_y <= tc_y
  ta_x = tx0; ta_y = ty0;
  tb_x = tx1; tb_y = ty1;
  tc_x = tx2; tc_y = ty2;
  if ta_y > tb_y { tr_t = ta_x; ta_x = tb_x; tb_x = tr_t; tr_t = ta_y; ta_y = tb_y; tb_y = tr_t; }
  if tb_y > tc_y { tr_t = tb_x; tb_x = tc_x; tc_x = tr_t; tr_t = tb_y; tb_y = tc_y; tc_y = tr_t; }
  if ta_y > tb_y { tr_t = ta_x; ta_x = tb_x; tb_x = tr_t; tr_t = ta_y; ta_y = tb_y; tb_y = tr_t; }
  if ta_y == tc_y { return; }  // degenerate
  for tr_y in ta_y..tc_y + 1 {
    // x along edge A→C (the long edge, always valid)
    tr_xac = ta_x + (tc_x - ta_x) * (tr_y - ta_y) / (tc_y - ta_y);
    // x along the short edge (A→B or B→C depending on scanline)
    tr_xother = tr_xac;
    if tr_y < tb_y and tb_y != ta_y {
      tr_xother = ta_x + (tb_x - ta_x) * (tr_y - ta_y) / (tb_y - ta_y);
    }
    if tr_y >= tb_y and tc_y != tb_y {
      tr_xother = tb_x + (tc_x - tb_x) * (tr_y - tb_y) / (tc_y - tb_y);
    }
    if tr_y >= tb_y and tc_y == tb_y {
      tr_xother = tb_x;
    }
    tr_left = if tr_xac < tr_xother { tr_xac } else { tr_xother };
    tr_right = if tr_xac > tr_xother { tr_xac } else { tr_xother };
    self.hline(tr_left, tr_right + 1, tr_y, color);
  }
}

// Native: write packed pixel data to a PNG file.
fn save_png_raw(path: text, width: integer, height: integer, data: const vector<integer>) -> boolean;
#native "loft_save_png"

// Save canvas as a PNG file. Automatically uses RGBA if any pixel has alpha < 255,
// otherwise uses RGB. Returns true on success.
pub fn save_png(self: const Canvas, path: text) -> boolean {
  save_png_raw(path, self.width, self.height, self.data)
}

// --- OpenGL (GL5) ---
// Native OpenGL functions for window management and rendering.
// Names match the symbols registered via loft_register_v1 in the cdylib.

// Create a window with an OpenGL 3.3 context. Returns true on success.
pub fn gl_create_window(width: integer, height: integer, title: text) -> boolean;
#native "loft_gl_create_window"

// Open a borderless fullscreen window at the primary monitor's native
// resolution. Returns true on success. Read the actual viewport size
// afterwards with `gl_window_width` / `gl_window_height` if you need
// to set up an aspect-aware camera.
pub fn gl_create_fullscreen_window(title: text) -> boolean;
#native "loft_gl_create_fullscreen_window"

// Toggle fullscreen on the existing window (runtime flip, cheaper
// than recreating the GL context — textures / VAOs / shaders
// survive).  Pass `true` for borderless fullscreen, `false` for
// windowed.  Browsers (WASM) require a user gesture to enter
// fullscreen; calling outside one is non-fatal.
pub fn gl_set_fullscreen(on: boolean);
#native "loft_gl_set_fullscreen"

// Poll window events. Returns false when the window should close.
pub fn gl_poll_events() -> boolean;
#native "loft_gl_poll_events"

// Swap buffers (present the frame).
pub fn gl_swap_buffers();
#native "loft_gl_swap_buffers"

// Clear the screen with an RGBA color (packed as 0xRRGGBBAA).
pub fn gl_clear(color: integer);
#native "loft_gl_clear"

// Destroy the window and OpenGL context.
pub fn gl_destroy_window();
#native "loft_gl_destroy_window"

// Compile and link a shader program. Returns the program ID (0 on failure).
pub fn gl_create_shader(vertex_source: text, fragment_source: text) -> integer;
#native "loft_gl_create_shader"

// Use a shader program for subsequent draw calls.
pub fn gl_use_shader(program: integer);
