pub fn audio_load(path: text) -> integer;
#native "loft_audio_load"
// Play a loaded clip at the given volume (0.0-1.0). Returns playback handle.
pub fn audio_play(clip: integer, volume: float) -> integer;
#native "loft_audio_play"
// Stop a playing clip by its playback handle.
pub fn audio_stop(sink: integer);
#native "loft_audio_stop"
// Set volume of a playing clip (0.0-1.0).
pub fn audio_set_volume(sink: integer, volume: float);
#native "loft_audio_set_volume"
// Play raw PCM samples (mono, values -1.0 to 1.0) at the given sample rate.
// Returns playback handle, or null on failure.
pub fn audio_play_raw(samples: vector<single>, sample_rate: integer, volume: float) -> integer;
