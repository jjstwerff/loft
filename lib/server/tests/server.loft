// Server smoke test: verify structs and listen/close work.
// Full integration requires concurrent client+server (parallel {} with threading).
use server;

fn main() {
  // Verify Server struct creation
  srv = server::listen(18082);
  assert(srv.handle >= 0, "listen returned handle={srv.handle}");

  // Close immediately — no accept needed
  srv.close();
  assert(true, "server created and closed");
}
