#rust"@v1 - @v2"
fn OpMulSingle(v1: single, v2: single) -> single;
#rust"@v1 * @v2"
fn OpDivSingle(v1: single, v2: single) -> single;
#rust"@v1 / @v2"
fn OpRemSingle(v1: single, v2: single) -> single;
#rust"@v1 % @v2"
fn OpMathFuncSingle(fn_id: const i8, v1: single) -> single;
#rust"match @fn_id {{ 0 => @v1.cos(), 1 => @v1.sin(), 2 => @v1.tan(), 3 => @v1.acos(), 4 => @v1.asin(), 5 => @v1.atan(), 6 => @v1.ceil(), 7 => @v1.floor(), 8 => @v1.round(), 9 => @v1.sqrt(), _ => f32::NAN }}"
// Cosine. Use for circular motion: x = r * cos(angle).
pub fn cos(both: single) -> single {
  OpMathFuncSingle(0, both)
}
// Sine. Use for circular motion: y = r * sin(angle).

pub fn sin(both: single) -> single {
  OpMathFuncSingle(1, both)
}
// Tangent. Use for slopes and perspective projection.

pub fn tan(both: single) -> single {
  OpMathFuncSingle(2, both)
}
// Arc cosine. Returns the angle (in radians) whose cosine is v.

pub fn acos(both: single) -> single {
  OpMathFuncSingle(3, both)
}
// Arc sine. Returns the angle whose sine is v.

pub fn asin(both: single) -> single {
  OpMathFuncSingle(4, both)
}
// Arc tangent of a single value. Returns angle in (-PI/2, PI/2).

pub fn atan(both: single) -> single {
  OpMathFuncSingle(5, both)
}
// Round up to the nearest integer value.
// Use to compute required buffer sizes from fractional counts.

pub fn ceil(both: single) -> single {
  OpMathFuncSingle(6, both)
}
// Round down to the nearest integer value.
// Use to convert a float position to a tile index.

pub fn floor(both: single) -> single {
  OpMathFuncSingle(7, both)
}
// Round to the nearest integer value (half rounds away from zero).

pub fn round(both: single) -> single {
  OpMathFuncSingle(8, both)
}
// Square root. Use for distances and normalization.

pub fn sqrt(both: single) -> single {
  OpMathFuncSingle(9, both)
}

fn OpMathFunc2Single(fn_id: const i8, v1: single, v2: single) -> single;
#rust"match @fn_id {{ 0 => @v1.atan2(@v2), 1 => @v1.log(@v2), _ => f32::NAN }}"
// Arc tangent of y/x, preserving the correct quadrant.
// Use instead of atan when you have separate x/y components.
pub fn atan2(both: single, v2: single) -> single {
  OpMathFunc2Single(0, both, v2)
}
// Logarithm of v in the given base.
// Use for converting between scales (e.g., decibels).

pub fn log(both: single, v2: single) -> single {
  OpMathFunc2Single(1, both, v2)
}

fn OpPowSingle(v1: single, v2: single) -> single;
#rust"@v1.powf(@v2)"
// Raises base to the power exp.
// Use for exponential growth curves and scaling.
pub fn pow(both: single, v2: single) -> single {
  OpPowSingle(both, v2)
}

fn OpEqSingle(v1: single, v2: single) -> boolean;
#rust"!@v1.is_nan() && !@v2.is_nan() && (@v1 - @v2).abs() < 0.000_001f32"
