// Call a predefined system function (but not an operator).
fn OpStaticCall(call: const u16);
// Create a DbRef that points INTO the current stack frame (not into a data store).
//
// `pos` is a compile-time u16 offset.  At runtime the produced DbRef is:
//   { store_nr: stack_cur.store_nr,
//     rec:      stack_cur.rec,
//     pos:      stack_cur.pos + State::stack_pos - pos }
//
// Intended uses:
//   1. Obtain a typed pointer to a variable's stack slot (e.g. to pass a struct
//      field by borrowed reference without copying it to a store).
//   2. Pre-initialise a borrowed Reference/Vector variable to a null-state before
//      an if/else branch (Option A sub-3 of ASSIGNMENT.md): the pre-init DbRef
//      points into the dep-variable's slot and is overwritten by OpPutRef when the
//      real assignment is reached inside the branch.
//
// IMPORTANT LIMITATIONS:
//   • The resulting DbRef uses stack_cur.store_nr, which is the *stack frame* store.
//     This store index is NOT a valid data store — using the DbRef to access a
//     struct field (e.g. last.val) will panic with an index-out-of-bounds on the
//     stores array.  OpCreateStack DbRefs must always be overwritten by OpPutRef
//     before any field access is attempted.
//   • The `pos` argument must equal (stack.position_before_op − dep_var.stack_pos)
//     so that the produced DbRef.pos = stack_cur.pos + dep_var.stack_pos — a
//     pointer into the dep variable's own slot.  Using the raw variable number
//     instead of this offset (the old pre-fix bug) produces a garbage DbRef.
fn OpCreateStack(pos: const u16) -> reference;
// Read a text from a stack position.
fn OpGetStackText(r: reference) -> text[r];
// Read a reference from a stack position.
fn OpGetStackRef(r: reference, fld: const u16) -> reference;
// Write a reference from a stack position.
fn OpSetStackRef(r: reference, v1: reference);
// Append a text to a stack text variable.
fn OpAppendStackText(pos: const u16, v1: text);
// Append a character to a stack text variable.
fn OpAppendStackCharacter(pos: const u16, v1: character);
// Clear a stack text variable.
fn OpClearStackText(pos: const u16);
// Read the lock state of the store containing a reference.
// Returns true when the store is locked against writes.
fn get_store_lock(r: reference) -> boolean;
// Lock the store containing a reference, preventing further writes.
// Only `true` is accepted from loft code via d#lock = true.
// A non-const variable may also use d#lock = false to unlock.
fn set_store_lock(r: reference, locked: boolean);
// --- Parallel ---
// Internal: run a loft function over every element of a vector in parallel.
// Not part of the public API — use the `par(b=worker(a), N)` for-loop clause instead.
fn parallel_for_int(func: text, input: reference, element_size: integer, threads: integer) -> reference;
// Internal: compiler-checked parallel map.
// The compiler rewrites `par(...)` clauses into calls to this function.
// Raw 5-arg internal signature; not callable from user code.
fn parallel_for(input: reference, element_size: integer, return_size: integer, threads: integer, func: integer) -> reference;
// Internal: read element idx from a parallel_for result reference.
// Emitted by the compiler for the `par(...)` syntax; do not call directly.
fn parallel_get_int(r: reference, idx: integer) -> integer;
fn parallel_get_long(r: reference, idx: integer) -> long;
fn parallel_get_float(r: reference, idx: integer) -> float;
fn parallel_get_bool(r: reference, idx: integer) -> boolean;
