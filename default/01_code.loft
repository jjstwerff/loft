#rust"!@v1.is_nan() && !@v2.is_nan() && @v1 < @v2"
fn OpLeSingle(v1: single, v2: single) -> boolean;
#rust"!@v1.is_nan() && !@v2.is_nan() && @v1 <= @v2"
