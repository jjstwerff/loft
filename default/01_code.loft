// --- Collections ---
// Operations on vector<T> — the primary ordered collection type.
// Vectors are grown by appending with += and elements are accessed by index.
// All structures are passed by reference instead of by value
type vector size(4);
type sorted size(4);
// All vectors are referenced by the field that points towards them.
