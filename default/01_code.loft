// --- Types ---
// Primitive types built into lav.
// True or false value.
pub type boolean size(1);
// 32-bit signed integer.
pub type integer size(4);
// 64-bit signed integer. Use when values exceed ~2 billion.
pub type long size(8);
// 32-bit floating-point. Good for graphics and performance-sensitive math.
pub type single size(4);
// 64-bit floating-point. Use when precision matters.
pub type float size(8);
// UTF-8 string.
pub type text size(4);
// A single Unicode code point.
pub type character size(4);
// Integer subtypes for compact storage in struct fields. Behave as integer in expressions.
// 0 – 255, 1 byte.
pub type u8 = integer limit(0, 255) size(1);
// -128 – 127, 1 byte.
pub type i8 = integer limit(-128, 127) size(1);
// 0 – 65535, 2 bytes.
pub type u16 = integer limit(0, 65535) size(2);
// -32768 – 32767, 2 bytes.
pub type i16 = integer limit(-32768, 32767) size(2);
// Full 32-bit integer range, 4 bytes.
pub type i32 = integer size(4);
// General operations
fn OpGoto(step: const i8);
#rust"s.code_pos = (s.code_pos as i32 + i32::from(@step)) as u32;"
fn OpGotoWord(step: const i16);
#rust"s.code_pos = (s.code_pos as i32 + i32::from(@step)) as u32;"
fn OpGotoFalse(step: const i8, if_false: boolean);
#rust"if !@if_false {{s.code_pos = (s.code_pos as i32 + i32::from(@step)) as u32;}}"
fn OpGotoFalseWord(step: const i16, if_false: boolean);
#rust"if !@if_false {{s.code_pos = (s.code_pos as i32 + i32::from(@step)) as u32;}}"
fn OpCall(size: const u16, to: const i32);
#rust"s.fn_call(@size, @to);"
fn OpReturn(ret: const u16, value: const u8, discard: const u16);
#rust"s.fn_return(@ret, @value, @discard);"
fn OpFreeStack(value: const u8, discard: const u16);
#rust"s.free_stack(@value, @discard);"
fn OpReserveFrame(size: const u16);
#rust"s.reserve_frame(@size);"
// Boolean operations
fn OpConstTrue() -> boolean;
#rust"true"
fn OpConstFalse() -> boolean;
#rust"false"
fn OpCastTextFromBool(v1: boolean) -> text;
#rust"if @v1 {{\"true\"}} else {{\"false\"}}"
fn OpVarBool(pos: const u16) -> boolean;
#rust"*s.get_var::<bool>(@pos)"
fn OpPutBool(var: const u16, value: boolean);
#rust"s.put_var(@var, @value);"
fn OpNot(v1: boolean) -> boolean;
#rust"!@v1"
// --- Math ---
// Functions for numeric computation.
// All trigonometric functions work in radians.
// Both single and float variants exist for every function —
// choose single for speed, float for precision.
